<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MenShop</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="sticky-top bg-white shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">MenShop</a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMenu">
                    <ul class="navbar-nav mx-auto">
                        
                           
                            <li class="nav-item dropdown-mega">
                                <a class="nav-link" asp-controller="Product" asp-action="Index">
                                    SẢN PHẨM <i class="bi bi-chevron-down" style="font-size: 10px;"></i>
                                </a>
                                <div class="mega-menu-wrapper">
                                    <div class="container py-4">
                                        <div class="row">
                                            <div class="col-md-4">
                                                <h6 class="fw-bold text-uppercase mb-3 text-dark border-bottom pb-2">ÁO MENSHOP</h6>
                                                <ul class="list-unstyled mega-links">
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="AoThun">Áo thun</a></li>
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="AoSoMi">Áo sơ mi</a></li>
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="AoPolo">Áo Polo</a></li>
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="Hoodie">Hoodie / Cardigan</a></li>
                                                </ul>
                                            </div>
                                            <div class="col-md-4">
                                                <h6 class="fw-bold text-uppercase mb-3 text-dark border-bottom pb-2">QUẦN MENSHOP</h6>
                                                <ul class="list-unstyled mega-links">
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="QuanShort">Quần Short</a></li>
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="QuanJean">Quần Jean</a></li>
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="QuanTay">Quần Tây / Kaki</a></li>
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="QuanJogger">Quần Jogger</a></li>
                                                </ul>
                                            </div>
                                            <div class="col-md-4">
                                                <h6 class="fw-bold text-uppercase mb-3 text-dark border-bottom pb-2">GỢI Ý LÊN ĐỒ</h6>
                                                <ul class="list-unstyled mega-links">
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="SetCongSo">Set đồ công sở</a></li>
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="SetTheThao">Set đồ thể thao</a></li>
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="SetMuaDong">Set mùa đông</a></li>
                                                    <li><a asp-controller="Product" asp-action="Index" asp-route-category="SetMuaHe">Set mùa hè</a></li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </li>
                        <li class="nav-item"><a class="nav-link text-danger fw-bold" asp-controller="Home" asp-action="Sale">SALE</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="AboutUs">Về Chúng Tôi</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Liên Hệ </a></li>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold text-primary" asp-controller="Admin" asp-action="Index">Quản Lý</a>
                            </li>
                        }
                    </ul>
                    
                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom mt-5 py-4 border-top">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <h5 class="fw-bold">MenShop TORANO</h5>
                    <p class="small text-muted">Hệ thống thời trang nam nam tính, lịch lãm.</p>
                </div>
                <div class="col-md-3">
                    <h5 class="fw-bold">Liên hệ</h5>
                    <p class="small">Hotline: 0964942121<br>Email: cskh@@torano.vn</p>
                </div>
                <div class="col-md-3">
                    <h5 class="fw-bold">Chính sách</h5>
                    <ul class="list-unstyled small">
                        <li><a href="#" class="text-decoration-none text-dark">Đổi trả hàng</a></li>
                        <li><a href="#" class="text-decoration-none text-dark">Bảo mật thông tin</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5 class="fw-bold">Đăng ký nhận tin</h5>
                    <div class="input-group">
                        <input type="email" class="form-control form-control-sm" placeholder="Email...">
                        <button class="btn btn-danger btn-sm">GỬI</button>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>