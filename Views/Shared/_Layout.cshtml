<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MenShop</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="sticky-top bg-white shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">MenShop</a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMenu">
                    <ul class="navbar-nav mx-auto">
                        
                           
                            <li class="nav-item dropdown-mega">
                                <a class="nav-link" asp-controller="Product" asp-action="Index">
                                    SẢN PHẨM 
                                </a>
                            </li>
                        <li class="nav-item"><a class="nav-link text-danger fw-bold" asp-controller="Home" asp-action="Sale">SALE</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="AboutUs">Về Chúng Tôi</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Liên Hệ </a></li>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link fw-bold text-primary" asp-controller="Admin" asp-action="Index">Quản Lý</a>
                            </li>
                        }
                    </ul>
                    
                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom">
        <div class="container">
            <div class="row">
                <div class="col-md-3 mb-4">
                    <h5 class="footer-title">Thời trang nam MENSHOP</h5>
                    <p class="footer-text">
                        Hệ thống thời trang cho phái mạnh hàng đầu Việt Nam, hướng tới phong cách nam tính, lịch lãm và trẻ trung.
                    </p>
                    <div class="social-icons mb-3">
                        <a href="https://www.facebook.com/share/1CFgziQLd4/?mibextid=wwXIfr"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-twitter"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-tiktok"></i></a>
                        <a href="#"><i class="bi bi-youtube"></i></a>
                    </div>
                    <h6 class="footer-subtitle">Phương thức thanh toán</h6>
                    <div class="payment-methods-text">
                        <span class="payment-badge">COD</span>
                        <span class="payment-badge">VNPAY</span>
                        <span class="payment-badge">BANK TRANSFER</span>
                    </div>


                </div>

                <div class="col-md-3 mb-4">
                    <h5 class="footer-title">Thông tin liên hệ</h5>
                    <ul class="list-unstyled footer-text">
                        <li><strong>Địa chỉ:</strong> Tầng 8, Tòa nhà 311-313 Trường Chinh, Phường Phương Liệt, Thành phố Hà Nội, Việt Nam</li>
                        <li><strong>Điện thoại:</strong> 0964942121</li>
                        <li><strong>Fax:</strong> 0904636356</li>
                        <li><strong>Email:</strong> cskh@menshop.vn</li>
                    </ul>
                    <h6 class="footer-subtitle">Phương thức vận chuyển</h6>
                    <div class="shipping-methods-text">
                        <span class="shipping-badge">Giao hàng tiết kiệm</span>
                        <span class="shipping-badge">Hỏa tốc</span>
                    </div>
                </div>

                <div class="col-md-3 mb-4">
                    <h5 class="footer-title">Nhóm liên kết</h5>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Tìm kiếm</a></li>
                        <li><a href="#">Giới thiệu</a></li>
                        <li><a href="#">Chính sách đổi trả</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                        <li><a href="#">Tuyển dụng</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5 class="footer-title">Tổng đài hỗ trợ</h5>
                    <div class="support-box p-3 border border-secondary rounded">
                        <div class="mb-3">
                            <span class="d-block footer-text small text-uppercase">Mua hàng online:</span>
                            <a href="tel:0964942121" class="h5 text-decoration-none fw-bold">0964.94.21.21</a>
                        </div>
                        <div class="mb-3">
                            <span class="d-block footer-text small text-uppercase">Góp ý, khiếu nại:</span>
                            <a href="tel:0904636356" class="h5 text-white text-decoration-none fw-bold">0904.63.63.56</a>
                        </div>
                        <p class="footer-text small mb-0 mt-2">
                            <i class="bi bi-clock"></i> Làm việc: 24/7 (Cả CN & Lễ)
                        </p>
                    </div>
                </div>

                
            </div>
        </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>