<link href="~/css/cart/shoppingCart.css" asp-append-version="true" rel="stylesheet" />
@model ShopQuanAo.Models.BEAN.Entity.ShoppingCart
@{
    ViewData["Title"] = "Giỏ Hàng";
}

<div class="cart-page">
    <div class="container">
        <div class="cart-header">
            <h1 class="cart-title">Giỏ Hàng</h1>
            <span class="cart-badge" id="headerItemCount">Chưa chọn sản phẩm</span>
        </div>

        @if (Model.CartDetails == null || !Model.CartDetails.Any())
        {
            <div class="cart-empty">
                <svg class="cart-empty-icon" viewBox="0 0 80 80" fill="none">
                    <circle cx="40" cy="40" r="38" stroke="currentColor" stroke-width="2" />
                    <path d="M24 28h4l4 20h16l4-14H32" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    <circle cx="34" cy="52" r="2" fill="currentColor" />
                    <circle cx="46" cy="52" r="2" fill="currentColor" />
                </svg>
                <h3>Giỏ hàng của bạn đang trống</h3>
                <p>Hãy khám phá bộ sưu tập và thêm sản phẩm yêu thích.</p>
                <a href="/Product" class="btn-checkout" style="display:inline-block;width:auto;padding:.85rem 2.5rem;">
                    Khám phá ngay
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="cart-table-wrap">
                        <table class="cart-table">
                            <thead>
                                <tr>
                                    <th style="width:5%"><input type="checkbox" id="selectAll" checked class="form-check-input"></th>
                                    <th style="width:40%">Sản phẩm</th>
                                    <th>Đơn giá</th>
                                    <th>Số lượng</th>
                                    <th class="text-end">Thành tiền</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="cartTableBody">
                                @foreach (var item in Model.CartDetails)
                                {
                                    var maxQty = item.Product?.ProductSizes?.FirstOrDefault(ps => ps.Size?.SizeName == item.Size)?.Quantity ?? 0;
                                    // FIX 1: Ép sang decimal để tránh tràn số (Overflow) cho giá tiền lớn
                                    var subtotalVal = (decimal)item.UnitPrice * item.Quantity;
                                    
                                    <tr id="row-@item.Id" class="cart-row" data-price="@item.UnitPrice">
                                        <td>
                                            <input type="checkbox" class="form-check-input item-checkbox" checked data-id="@item.Id">
                                        </td>
                                        <td data-label="Sản phẩm">
                                            <div class="product-cell">
                                                <div class="product-img-wrap">
                                                    <img src="@(string.IsNullOrEmpty(item.Product?.Image) ? "/images/placeholder.png" : item.Product.Image)" alt="@item.Product?.ProductName" />
                                                </div>
                                                <div class="product-info">
                                                    <div class="product-name">@item.Product?.ProductName</div>
                                                    <span class="product-size">Size @item.Size</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td data-label="Đơn giá" class="price-cell">
                                            @item.UnitPrice.ToString("N0")₫
                                        </td>
                                        <td data-label="Số lượng">
                                            <div class="qty-control">
                                                <button class="qty-btn" onclick="changeQty(@item.Id, -1, @maxQty)">−</button>
                                                <input class="qty-input" type="number" id="qty-@item.Id"
                                                       value="@item.Quantity" min="1" max="@maxQty"
                                                       onchange="setQty(@item.Id, this.value, @maxQty)" readonly />
                                                <button class="qty-btn" onclick="changeQty(@item.Id, 1, @maxQty)">+</button>
                                            </div>
                                        </td>
                                        <td data-label="Thành tiền" class="subtotal-cell subtotal-val" id="sub-@item.Id" data-value="@subtotalVal">
                                            @subtotalVal.ToString("N0")₫
                                        </td>
                                        <td>
                                            <button class="remove-btn" onclick="removeItem(@item.Id)" title="Xóa">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="cart-summary">
                        <div class="summary-title">Tóm tắt đơn hàng</div>
                        <div class="summary-row">
                            <span>Số lượng chọn</span>
                            <span id="summaryCount">0 sản phẩm</span>
                        </div>
                        <div class="summary-row">
                            <span>Tạm tính</span>
                            <span id="summarySubtotal">0₫</span>
                        </div>
                        <div class="summary-row">
                            <span>Phí vận chuyển</span>
                            <span>Tính khi thanh toán</span>
                        </div>
                        <hr class="summary-divider" />
                        <div class="summary-total">
                            <span>Tổng cộng</span>
                            <span class="total-amount" id="summaryTotal">0₫</span>
                        </div>
                        <button onclick="proceedToCheckout()" class="btn-checkout w-100 mt-3 border-0">Tiến hành thanh toán</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="cart-toast" id="cartToast">
    <span id="toastMsg">Đã cập nhật giỏ hàng</span>
</div>

@section Scripts {
    <script>
        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        }

        function formatVND(n) {
            let val = parseFloat(n) || 0;
            return new Intl.NumberFormat('vi-VN').format(Math.round(val)) + '₫';
        }

        function calculateSummary() {
            let total = 0;
            let count = 0;
            const checkedBoxes = document.querySelectorAll('.item-checkbox:checked');
            
            checkedBoxes.forEach(cb => {
                const row = cb.closest('.cart-row');
                if (row) {
                    const qtyInput = row.querySelector('.qty-input');
                    const subtotalEl = row.querySelector('.subtotal-val');
                    const qty = parseInt(qtyInput.value) || 0;
                    
                    // FIX 2: Xóa bỏ dấu chấm/phẩy render từ C# trước khi parse số trong JS
                    let rawVal = subtotalEl.getAttribute('data-value').toString().replace(/[^0-9.-]/g, '');
                    const subtotal = parseFloat(rawVal) || 0;
                    
                    total += subtotal;
                    count += qty;
                }
            });

            document.getElementById('summaryTotal').textContent = formatVND(total);
            document.getElementById('summarySubtotal').textContent = formatVND(total);
            document.getElementById('summaryCount').textContent = count + ' sản phẩm';
            
            const headerCount = document.getElementById('headerItemCount');
            if (headerCount) {
                headerCount.textContent = count > 0 ? count + ' sản phẩm được chọn' : 'Chưa chọn sản phẩm';
            }
        }

        async function updateQty(cartDetailId, quantity) {
            try {
                const formData = new FormData();
                formData.append('cartDetailId', cartDetailId);
                formData.append('quantity', quantity);
                formData.append('__RequestVerificationToken', getToken());

                const res = await fetch('/Cart/UpdateQuantity', { method: 'POST', body: formData });
                const result = await res.json();

                if (result.success) {
                    const subEl = document.getElementById('sub-' + cartDetailId);
                    if (subEl) {
                        // FIX 3: Truy cập đúng cấp dữ liệu result.data.subtotal
                        const newSubtotal = result.data.subtotal;
                        subEl.setAttribute('data-value', newSubtotal);
                        subEl.textContent = formatVND(newSubtotal);
                    }
                    calculateSummary();
                } else {
                    showToast(result.message, true);
                    setTimeout(() => location.reload(), 1000);
                }
            } catch (err) {
                showToast('Lỗi kết nối', true);
            }
        }

        // --- Các hàm phụ giữ nguyên ---
        function changeQty(id, delta, maxQty) {
            const input = document.getElementById('qty-' + id);
            const currentVal = parseInt(input.value) || 1;
            const newVal = currentVal + delta;
            if (newVal >= 1 && newVal <= maxQty) {
                input.value = newVal;
                updateQty(id, newVal);
            } else if (newVal > maxQty) {
                showToast(`Chỉ còn ${maxQty} sản phẩm trong kho`, true);
            }
        }

        function setQty(id, val, maxQty) {
            let newVal = Math.max(1, Math.min(maxQty, parseInt(val) || 1));
            document.getElementById('qty-' + id).value = newVal;
            updateQty(id, newVal);
        }

        document.getElementById('selectAll')?.addEventListener('change', function() {
            document.querySelectorAll('.item-checkbox').forEach(cb => cb.checked = this.checked);
            calculateSummary();
        });

        document.addEventListener('change', function(e) {
            if (e.target.classList.contains('item-checkbox')) calculateSummary();
        });

        function proceedToCheckout() {
            const selected = Array.from(document.querySelectorAll('.item-checkbox:checked')).map(cb => cb.dataset.id);
            if (selected.length === 0) { showToast("Vui lòng chọn ít nhất 1 sản phẩm", true); return; }
            window.location.href = "/Checkout?selectedIds=" + selected.join(',');
        }

        async function removeItem(cartDetailId) {
            if(!confirm("Xóa sản phẩm này?")) return;
            const formData = new FormData();
            formData.append('cartDetailId', cartDetailId);
            formData.append('__RequestVerificationToken', getToken());
            const res = await fetch('/Cart/RemoveItem', { method: 'POST', body: formData });
            const data = await res.json();
            if(data.success) location.reload();
        }

        document.addEventListener('DOMContentLoaded', calculateSummary);
    </script>
}
@Html.AntiForgeryToken()