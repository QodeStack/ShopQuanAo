<link href="~/css/shoppingCart.css" asp-append-version="true" rel="stylesheet"/>
@model ShopQuanAo.Models.ShoppingCart
@{
    ViewData["Title"] = "Giỏ Hàng";
    var total = Model.CartDetails?.Sum(cd => cd.UnitPrice * cd.Quantity) ?? 0;
    var itemCount = Model.CartDetails?.Sum(cd => cd.Quantity) ?? 0;
}

<div class="cart-page">
<div class="container">

    <div class="cart-header">
        <h1 class="cart-title">Giỏ Hàng</h1>
        <span class="cart-badge" id="headerItemCount">
            @(itemCount > 0 ? $"{itemCount} sản phẩm" : "Trống")
        </span>
    </div>

    @if (Model.CartDetails == null || !Model.CartDetails.Any())
    {
        <div class="cart-empty">
            <svg class="cart-empty-icon" viewBox="0 0 80 80" fill="none">
                <circle cx="40" cy="40" r="38" stroke="currentColor" stroke-width="2"/>
                <path d="M24 28h4l4 20h16l4-14H32" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="34" cy="52" r="2" fill="currentColor"/>
                <circle cx="46" cy="52" r="2" fill="currentColor"/>
            </svg>
            <h3>Giỏ hàng của bạn đang trống</h3>
            <p>Hãy khám phá bộ sưu tập và thêm sản phẩm yêu thích.</p>
            <a href="/Products" class="btn-checkout" style="display:inline-block;width:auto;padding:.85rem 2.5rem;">
                Khám phá ngay
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Cart Items -->
            <div class="col-lg-8">
                <div class="cart-table-wrap">
                    <table class="cart-table">
                        <thead>
                            <tr>
                                <th style="width:45%">Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th>Số lượng</th>
                                <th class="text-end">Thành tiền</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="cartTableBody">
                            @foreach (var item in Model.CartDetails)
{
    
        var maxQty = item.Product?.ProductSizes?
            .FirstOrDefault(ps => ps.Size?.SizeName == item.Size)?.Quantity ?? 999;
    
    <tr id="row-@item.Id">
        <td data-label="Sản phẩm">
            <div class="product-cell">
                <div class="product-img-wrap">
                    @if (!string.IsNullOrEmpty(item.Product?.Image))
                    {
                        <img src="@item.Product.Image" alt="@item.Product?.ProductName" />
                    }
                    else
                    {
                        <img src="/images/placeholder.png" alt="No image" />
                    }
                </div>
                <div class="product-info">
                    <div class="product-name">@item.Product?.ProductName</div>
                    <span class="product-size">@item.Size</span>
                </div>
            </div>
        </td>
        <td data-label="Đơn giá" class="price-cell">
            @item.UnitPrice.ToString("N0")₫
        </td>
        <td data-label="Số lượng">
            <div class="qty-control">
                <button class="qty-btn" onclick="changeQty(@item.Id, -1, @maxQty)">−</button>
                <input class="qty-input" type="number" id="qty-@item.Id"
                       value="@item.Quantity" min="1" max="@maxQty"
                       data-max="@maxQty"
                       onchange="setQty(@item.Id, this.value, @maxQty)" />
                <button class="qty-btn" onclick="changeQty(@item.Id, 1, @maxQty)">+</button>
            </div>
        </td>
        <td data-label="Thành tiền" class="subtotal-cell" id="sub-@item.Id">
            @((item.UnitPrice * item.Quantity).ToString("N0"))₫
        </td>
        <td>
            <button class="remove-btn" onclick="removeItem(@item.Id)" title="Xóa">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </td>
    </tr>
}
                        </tbody>
                    </table>
                </div>

                <div class="cart-actions">
                    <div style="display:flex;gap:.6rem;">
                        <button class="btn-clear" onclick="clearCart()">Xóa tất cả</button>
                        <a href="/Products" class="btn-continue">← Tiếp tục mua</a>
                    </div>
                </div>
            </div>

            <!-- Summary -->
            <div class="col-lg-4">
                <div class="cart-summary">
                    <div class="summary-title">Tóm tắt đơn hàng</div>

                    <div class="summary-row">
                        <span>Số lượng</span>
                        <span id="summaryCount">@itemCount sản phẩm</span>
                    </div>
                    <div class="summary-row">
                        <span>Tạm tính</span>
                        <span id="summarySubtotal">@total.ToString("N0")₫</span>
                    </div>
                    <div class="summary-row">
                        <span>Phí vận chuyển</span>
                        <span>Tính khi thanh toán</span>
                    </div>

                    <hr class="summary-divider" />

                    <div class="summary-total">
                        <span>Tổng cộng</span>
                        <span class="total-amount" id="summaryTotal">@total.ToString("N0")₫</span>
                    </div>

                    <a href="/Checkout" class="btn-checkout">Tiến hành thanh toán</a>
                    <p class="summary-note">Bạn sẽ chọn phương thức vận chuyển ở bước tiếp theo</p>
                </div>
            </div>
        </div>
    }

</div>
</div>

<!-- Toast -->
<div class="cart-toast" id="cartToast">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <polyline points="20 6 9 17 4 12"/>
    </svg>
    <span id="toastMsg">Đã cập nhật giỏ hàng</span>
</div>

@section Scripts {
<script>
    function getToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    }

    function formatVND(n) {
        return new Intl.NumberFormat('vi-VN').format(Math.round(n)) + '₫';
    }

    function showToast(msg, isError = false) {
        const t = document.getElementById('cartToast');
        document.getElementById('toastMsg').textContent = msg;
        t.classList.toggle('error', isError);
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 2800);
    }

    function updateSummary(total, cartCount) {
        if (document.getElementById('summaryTotal'))
            document.getElementById('summaryTotal').textContent = formatVND(total);
        if (document.getElementById('summarySubtotal'))
            document.getElementById('summarySubtotal').textContent = formatVND(total);
        if (document.getElementById('summaryCount'))
            document.getElementById('summaryCount').textContent = cartCount + ' sản phẩm';
        if (document.getElementById('headerItemCount'))
            document.getElementById('headerItemCount').textContent = cartCount > 0 ? cartCount + ' sản phẩm' : 'Trống';
        // Update navbar badge if exists
        const badge = document.getElementById('cartNavBadge');
        if (badge) badge.textContent = cartCount;
    }

    function changeQty(id, delta, maxQty) {
        const input = document.getElementById('qty-' + id);
        const currentVal = parseInt(input.value || 1);
        const newVal = Math.max(1, Math.min(maxQty, currentVal + delta));
        if (newVal === currentVal) {
            if (delta > 0) showToast(`Đã đạt số lượng tối đa (${maxQty})`, true);
            return;
        }
        input.value = newVal;
        updateQty(id, newVal);
    }

    function setQty(id, val, maxQty) {
        let newVal = parseInt(val) || 1;
        if (newVal > maxQty) {
            newVal = maxQty;
            showToast(`Chỉ còn ${maxQty} sản phẩm trong kho`, true);
        }
        newVal = Math.max(1, newVal);
        document.getElementById('qty-' + id).value = newVal;
        updateQty(id, newVal);
    }

    async function updateQty(cartDetailId, quantity) {
        const row = document.getElementById('row-' + cartDetailId);
        row?.classList.add('row-loading');

        try {
            const formData = new FormData();
            formData.append('cartDetailId', cartDetailId);
            formData.append('quantity', quantity);
            formData.append('__RequestVerificationToken', getToken());

            const res = await fetch('/Cart/UpdateQuantity', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();
            if (data.success) {
                const subEl = document.getElementById('sub-' + cartDetailId);
                if (subEl) subEl.textContent = formatVND(data.subtotal);
                updateSummary(data.total, data.cartCount);
                if (quantity <= 0) row?.remove();
            } else {
                showToast(data.message || 'Lỗi cập nhật', true);
            }
        } catch (err) {
            console.error(err);
            showToast('Không thể kết nối máy chủ', true);
        } finally {
            row?.classList.remove('row-loading');
        }
    }

    async function removeItem(cartDetailId) {
        const row = document.getElementById('row-' + cartDetailId);
        row?.classList.add('row-loading');

        try {
            const formData = new FormData();
            formData.append('cartDetailId', cartDetailId);
            formData.append('__RequestVerificationToken', getToken());

            const res = await fetch('/Cart/RemoveItem', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();
            if (data.success) {
                row?.style.setProperty('transition', 'opacity .25s, max-height .3s');
                row?.style.setProperty('opacity', '0');
                row?.style.setProperty('max-height', '0');
                setTimeout(() => {
                    row?.remove();
                    updateSummary(data.total, data.cartCount);
                    if (data.cartCount === 0) location.reload();
                }, 320);
                showToast('Đã xóa sản phẩm');
            } else {
                showToast(data.message || 'Lỗi xóa sản phẩm', true);
                row?.classList.remove('row-loading');
            }
        } catch (err) {
            console.error(err);
            showToast('Không thể kết nối máy chủ', true);
            row?.classList.remove('row-loading');
        }
    }

    async function clearCart() {
        if (!confirm('Bạn chắc chắn muốn xóa toàn bộ giỏ hàng?')) return;

        try {
            const formData = new FormData();
            formData.append('__RequestVerificationToken', getToken());

            const res = await fetch('/Cart/ClearCart', {
                method: 'POST',
                body: formData
            });
            const data = await res.json();
            if (data.success) location.reload();
        } catch (err) {
            console.error(err);
            showToast('Không thể kết nối máy chủ', true);
        }
    }
</script>
@Html.AntiForgeryToken()
}
