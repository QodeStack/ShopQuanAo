<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick.css" integrity="sha512-wR4oNhLBHf7smjy0K4oqzdWumd+r5/+6QO/vDda76MW5iug4PT7v86FoEkySIJft3XA0Ae6axhIvHrqwm793Nw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick-theme.css" integrity="sha512-6lLUdeQ5uheMFbWm3CP271l14RsX1xtx+J5x2yeIDkkiBpeVTNhTqijME7GgRKKi6hCqovwCoBTlRBEC20M8Mg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet">

<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

@{
    ViewData["Title"] = "Home Page";
}

<div class="container-fluid p-0">

    <!-- ══════════ HERO SLIDER ══════════ -->
    <section class="hero-wrapper">
    <div class="hero-slider">
        <div class="slide">
            <img src="https://res.cloudinary.com/dqklxt0mz/image/upload/pixverse_i2i_ori_f875e47e-209c-45e1-8ff6-3329b9b0afd9_snvgor.jpg" alt="SS2025 Collection">
        </div>
        <div class="slide">
            <img src="https://res.cloudinary.com/dqklxt0mz/image/upload/v1774837343/pixverse_i2i_ori_b2e5ae3d-9807-4b79-92a9-f7684e5e5f0c_eefilq.jpg" alt="New Arrivals">
        </div>
    </div>
    </section>
    <div class="hero-overlay">
        <div class="hero-tag text-white">Bộ sưu tập 2025</div>
        <h1 class="hero-title text-white">Định nghĩa<br>phong cách<br>của bạn</h1>
        <a href="#" class="hero-cta text-white">Khám phá ngay <span class="arrow">→</span></a>
    </div>

    <section class="best-seller-section container my-5">

        <h2 class="text-center best-title mb-4">Best Seller</h2>

        <div class="row g-4">

            <div class="col-md-3 col-6">
                <div class="product-card">
                    <img src="@Url.Content("~/Image/aothun.webp")" alt="">
                </div>
            </div>

            <div class="col-md-3 col-6">
                <div class="product-card">
                    <img src="@Url.Content("~/Image/quanau.webp")" alt="">
                </div>
            </div>

            <div class="col-md-3 col-6">
                <div class="product-card">
                    <img src="@Url.Content("~/Image/quankaki.webp")" alt="">
                </div>
            </div>

            <div class="col-md-3 col-6">
                <div class="product-card">
                    <img src="@Url.Content("~/Image/somi.webp")" alt="">
                </div>
            </div>

        </div>
    </section>

    <!-- ══════════ SESSION 3 — Phong Cách Riêng ══════════ -->
    <section class="Portfolio">
        <div class="container">
            <h1>Phong Cách Riêng </h1>
            <div class="grid-item">

                <div class="item item-1">
                    <div class="content">
                        <img src="@Url.Content("~/Image/setthetheoPC.png")" alt="Portfolio 1" />
                        <div class="overlay">
                            <a data-fancybox="gallery" data-src="@Url.Content("~/Image/setthetheoPC.png")">
                                <i class="fa fa-plus"></i>
                            </a>
                            <h1>Set Thể Thao</h1>
                            <a href="#" class="btn-detail">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
                
                <div class="item item-2">
                    <div class="content">
                        <img src="@Url.Content("~/Image/aothunPC.webp")" alt="Portfolio 2" />
                        <div class="overlay">
                            <a data-fancybox="gallery" data-src="@Url.Content("~/Image/aothunPC.webp")">
                                <i class="fa fa-plus"></i>
                            </a>
                            <h1>Áo Thun</h1>
                            <a href="#" class="btn-detail">Xem chi tiết</a>
                        </div>
                    </div>
                </div>

                <div class="item item-3">
                    <div class="content">
                        <img src="@Url.Content("~/Image/jackhoodie.jpg")" alt="Portfolio 3" />
                        <div class="overlay">
                            <a data-fancybox="gallery" data-src="@Url.Content("~/Image/jackhoodie.jpg")">
                                <i class="fa fa-plus"></i>
                            </a>
                            <h1>Áo Khoác Hoodie</h1>
                            <a href="#" class="btn-detail">Xem chi tiết</a>
                        </div>
                    </div>
                </div>

                <div class="item item-4">
                    <div class="content">
                        <img src="@Url.Content("~/Image/poloPC.webp")" alt="Portfolio 4" />
                        <div class="overlay">
                            <a data-fancybox="gallery" data-src="@Url.Content("~/Image/poloPC.webp")">
                                <i class="fa fa-plus"></i>
                            </a>
                            <h1>Áo Polo</h1>
                            <a href="#" class="btn-detail">Xem chi tiết</a>
                        </div>
                    </div>
                </div>

                <div class="item item-5">
                    <div class="content">
                        <img src="@Url.Content("~/Image/sethePC.jpg")" alt="Portfolio 5" />
                        <div class="overlay">
                            <a data-fancybox="gallery" data-src="@Url.Content("~/Image/sethePC.jgp")">
                                <i class="fa fa-plus"></i>
                            </a>
                            <h1>Set Mùa Hè</h1>
                            <a href="#" class="btn-detail">Xem chi tiết</a>
                        </div>
                    </div>
                </div>

                <div class="item item-6">
                    <div class="content">
                        <img src="@Url.Content("~/Image/hthsomi.png")" alt="Portfolio 6" />
                        <div class="overlay">
                            <a data-fancybox="gallery" data-src="@Url.Content("~/Image/hthsomi.png")">
                                <i class="fa fa-plus"></i>
                            </a>
                            <h1>Áo Sơ Mi</h1>
                            <a href="#" class="btn-detail">Xem chi tiết</a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>


    <!-- ══════════ SESSION 5 — blog-section ══════════ -->
    <section class="blog-section py-5">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="blog-main-title">OUR BLOG</h2>
                <p class="blog-sub-title text-uppercase">Đón đầu xu hướng, định hình phong cách</p>
            </div>

            <div class="row">
                <div class="col-md-4 mb-4"> 
                    <div class="blog-card">
                        <div class="blog-img-wrapper">
                            <img src="https://mensfolio.vn/wp-content/uploads/2026/01/incollage_save-5.jpeg" class="img-fluid blog-img">
                                <div class="blog-overlay"></div>
                            </div>
                            <div class="blog-content text-center mt-3">
                                <h5 class="blog-item-title"><a href="#">XU HƯỚNG 2026: SỰ LÊN NGÔI CỦA PHONG CÁCH OLD MONEY</a></h5>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 mb-4">
                        <div class="blog-card">
                            <div class="blog-img-wrapper">
                            <img src="https://cdn.giaiphap.shopee.vn/ops-shopee-files-live/live/shopee-blog/2025/08/8d96db81-phoi-do-voi-quan-short-nam-2.jpg" class="img-fluid blog-img">
                                    <div class="blog-overlay"></div>
                                </div>
                                <div class="blog-content text-center mt-3">
                                    <h5 class="blog-item-title"><a href="#">5 CÁCH PHỐI ĐỒ VỚI QUẦN SHORT NAM CHO MÙA HÈ NĂNG ĐỘNG</a></h5>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 mb-4">
                            <div class="blog-card">
                                <div class="blog-img-wrapper">
                            <img src="https://5sfashion.vn/storage/upload/images/ckeditor/dWB0gYamYjN6IQjD7s1pXbYc0eN7CoAW11wyGHGA.jpg" class="img-fluid blog-img">
                                        <div class="blog-overlay"></div>
                                    </div>
                                    <div class="blog-content text-center mt-3">
                                <h5 class="blog-item-title"><a href="#">3 CÁCH DIỆN SƠ MI ĐẸP NHẤT</a></h5>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

    <!-- ══════════ SESSION 6 — service-policy ══════════ -->
    <section class="service-policy border-top border-bottom py-4 bg-white">
        <div class="container">
            <div class="row">
                <div class="col-md-3 d-flex align-items-center mb-3 mb-md-0">
                    <div class="policy-icon me-3">
                        <i class="fa-solid fa-box-open fa-2x"></i>
                    </div>
                    <div class="policy-text">
                        <h6 class="fw-bold mb-1">Miễn phí vận chuyển</h6>
                        <p class="small text-muted mb-0">Áp dụng cho mọi đơn hàng từ 500k</p>
                    </div>
                </div>

                <div class="col-md-3 d-flex align-items-center mb-3 mb-md-0">
                    <div class="policy-icon me-3">
                        <i class="fa-solid fa-arrow-rotate-left fa-2x"></i>
                    </div>
                    <div class="policy-text">
                        <h6 class="fw-bold mb-1">Đổi hàng dễ dàng</h6>
                        <p class="small text-muted mb-0">7 ngày đổi hàng vì bất kì lí do gì</p>
                    </div>
                </div>

                <div class="col-md-3 d-flex align-items-center mb-3 mb-md-0">
                    <div class="policy-icon me-3">
                        <i class="fa-solid fa-headset fa-2x"></i>
                    </div>
                    <div class="policy-text">
                        <h6 class="fw-bold mb-1">Hỗ trợ nhanh chóng</h6>
                        <p class="small text-muted mb-0">HOTLINE 24/7 : 0964942121</p>
                    </div>
                </div>

                <div class="col-md-3 d-flex align-items-center">
                    <div class="policy-icon me-3">
                        <i class="fa-solid fa-credit-card fa-2x"></i>
                    </div>
                    <div class="policy-text">
                        <h6 class="fw-bold mb-1">Thanh toán đa dạng</h6>
                        <p class="small text-muted mb-0">Thanh toán khi nhận hàng, Napas, Visa, Chuyển Khoản</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>

