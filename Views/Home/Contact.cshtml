@{
    ViewData["Title"] = "Liên Hệ";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<link rel="stylesheet" href="~/css/contact.css" asp-append-version="true" />

<header class="page-header">
    <div class="container">
        <h1>Trang Liên Hệ</h1>
    </div>
</header>

<main class="contact-container">
    <div class="container">
        <div class="row g-0 shadow-sm">
            
            <div class="col-md-7 border border-dark p-4 p-lg-5 bg-white">
                <h2 class="fw-bold text-uppercase mb-4">Gửi tin nhắn</h2>
                <form action="#" method="post">
                    <div class="row">
                        <div class="col-sm-6 mb-3">
                            <label class="small fw-bold text-uppercase">Họ tên *</label>
                            <input type="text" class="form-control" required>
                        </div>
                        <div class="col-sm-6 mb-3">
                            <label class="small fw-bold text-uppercase">Email *</label>
                            <input type="email" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="small fw-bold text-uppercase">Số điện thoại</label>
                        <input type="tel" class="form-control">
                    </div>
                    <div class="mb-4">
                        <label class="small fw-bold text-uppercase">Nội dung</label>
                        <textarea class="form-control" rows="4" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-black">Gửi yêu cầu</button>
                </form>
            </div>

            <div class="col-md-5">
                <div class="contact-info-block border border-dark border-start-0">
                    <h3 class="text-uppercase fw-bold mb-4">Thông tin</h3>
                    
                    <div class="info-item">
                        <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
                        <div class="info-text"><strong>Địa chỉ</strong> 123 Đường ABC, Quận 1, TP.HCM</div>
                    </div>

                    <div class="info-item">
                        <div class="info-icon"><i class="fas fa-phone-alt"></i></div>
                        <div class="info-text"><strong>Hotline</strong> 0901 234 567</div>
                    </div>

                    <div class="info-item">
                        <div class="info-icon"><i class="fas fa-envelope"></i></div>
                        <div class="info-text"><strong>Email</strong> support@menshop.vn</div>
                    </div>

                    <div class="map-wrapper">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.424167419767!2d106.699479315334!3d10.7756586620993!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f4730628e7d%3A0x70fe93bc6603a68e!2zR29vZ2xlIFZp4buHdCBOYW0!5e0!3m2!1svi!2s!4v1650000000000!5m2!1svi!2s" 
                                width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                    </div>
                </div>
            </div>

        </div>
    </div>
</main>