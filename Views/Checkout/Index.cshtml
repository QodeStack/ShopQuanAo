@model ShopQuanAo.Models.BEAN.DTO.PlaceOrderDto
@{
    ViewData["Title"] = "Thanh toán";
    
    // Lấy thông tin giỏ hàng và tổng tiền từ ViewBag
    var cart = ViewBag.Cart as ShopQuanAo.Models.BEAN.Entity.ShoppingCart;
    var totalAmount = ViewBag.TotalAmount != null ? Convert.ToDouble(ViewBag.TotalAmount) : 0;
}

<div class="container mt-4 mb-5">
    <form asp-action="PlaceOrder" asp-controller="Checkout" method="post">
        <div class="row">
            <div class="col-lg-7 pe-lg-4">
                
                <div class="card border-0 shadow-sm mb-4 rounded-3">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-4">Thông tin giao hàng</h5>
                        
                        <div class="mb-3">
                            <input asp-for="Name" class="form-control bg-light" placeholder="Nhập họ và tên" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <div class="input-group">
                                <input asp-for="MobileNumber" class="form-control bg-light" placeholder="Nhập số điện thoại" />
                                <span class="input-group-text bg-light">
                                    <img src="https://upload.wikimedia.org/wikipedia/commons/2/21/Flag_of_Vietnam.svg" width="24" alt="VN">
                                </span>
                            </div>
                            <span asp-validation-for="MobileNumber" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <input asp-for="Email" class="form-control bg-light" placeholder="Nhập email (không bắt buộc)" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <input type="text" class="form-control bg-light" value="Vietnam" readonly />
                        </div>
                        
                        <div class="mb-3">
                            <input asp-for="Address" class="form-control bg-light" placeholder="Nhập địa chỉ đầy đủ (Số nhà, tên đường, Phường/Xã, Quận/Huyện...)" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4 rounded-3">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-3">Phương thức vận chuyển</h5>
                        <div class="border rounded p-3 d-flex align-items-center">
                            <input class="form-check-input me-3 fs-5 m-0" type="radio" name="ShippingMethod" value="Freeship" id="shipFree" checked>
                            <label class="form-check-label w-100 d-flex align-items-center mb-0" for="shipFree" style="cursor: pointer;">
                                <i class="bi bi-truck fs-4 me-2" style="color: #1a2b4c;"></i>
                                <span class="fw-normal">Freeship đơn hàng</span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4 rounded-3">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-3">Hình thức thanh toán</h5>
                        <div class="border rounded">
                            <div class="p-3 d-flex align-items-center">
                                <input class="form-check-input me-3 fs-5 m-0" type="radio" asp-for="PaymentMethod" value="COD" id="payCOD" checked>
                                <label class="form-check-label w-100 d-flex align-items-center mb-0" for="payCOD" style="cursor: pointer;">
                                    <span class="badge me-2 py-2 px-2" style="background-color: #1a2b4c; font-size: 0.9rem;">COD</span>
                                    <span class="fw-normal">Thanh toán khi giao hàng (COD)</span>
                                </label>
                            </div>
                            <div class="p-3 border-top bg-light text-dark" style="font-size: 0.95rem;">
                                - Khách hàng được kiểm tra hàng trước khi nhận hàng.<br>
                                - Freeship đơn từ 399K
                            </div>
                            
                            <div class="p-3 border-top d-flex align-items-center bg-white">
                                <input class="form-check-input me-3 fs-5 m-0" type="radio" asp-for="PaymentMethod" value="ChuyenKhoan" id="payBank">
                                <label class="form-check-label w-100 d-flex align-items-center mb-0" for="payBank" style="cursor: pointer;">
                                    <span class="badge me-2 py-2 px-2 text-white" style="background-color: #0d6efd; font-size: 0.9rem;">
                                        <i class="bi bi-qr-code-scan"></i> QR
                                    </span>
                                    <span class="fw-normal">Chuyển khoản ngân hàng (Quét mã tự động)</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="col-lg-5">
                <div class="card border-0 shadow-sm mb-4 rounded-3">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-4">Giỏ hàng</h5>
                        
                        @if (cart != null && cart.CartDetails != null)
                        {
                            foreach (var item in cart.CartDetails)
                            {
                                string imgSrc = string.IsNullOrEmpty(item.Product.Image) ? "/images/no-image.png" : item.Product.Image;
                                <div class="d-flex mb-3 align-items-center">
                                    <div class="me-3">
                                        <img src="@imgSrc" alt="@item.Product.ProductName" class="rounded" style="width: 70px; height: 90px; object-fit: cover; border: 1px solid #eee;" onerror="this.src='/images/no-image.png'">
                                    </div>
                                    
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h6 class="mb-1 fw-bold text-uppercase" style="font-size: 0.9rem;">@item.Product.ProductName</h6>
                                            <span class="text-muted"><i class="bi bi-bag-check"></i></span>
                                        </div>
                                        <div class="text-muted small mb-2 bg-light d-inline-block px-2 py-1 rounded">
                                            Size @item.Size
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <span class="fw-bold">@item.UnitPrice.ToString("N0")đ</span>
                                            <span class="badge bg-light text-dark border px-3 py-2">SL: @item.Quantity</span>
                                        </div>
                                    </div>
                                </div>
                                @if (item != cart.CartDetails.Last())
                                {
                                    <hr class="text-muted opacity-25">
                                }
                            }
                        }
                    </div>
                </div>

                <div class="card border-0 shadow-sm mb-4 rounded-3">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-3">Mã khuyến mãi</h5>
                        
                        <div class="input-group mb-3 border rounded p-1" style="cursor: pointer;" data-bs-toggle="modal" data-bs-target="#voucherModal">
                            <span class="input-group-text bg-white border-0 text-muted"><i class="bi bi-ticket-perforated"></i></span>
                            <input type="text" class="form-control border-0 shadow-none bg-white" placeholder="Bấm vào đây để chọn mã" readonly style="cursor: pointer;">
                            <button class="btn border-0 text-dark" type="button"><i class="bi bi-chevron-right"></i></button>
                        </div>
                        
                        <div class="input-group">
                            <input type="text" id="voucherCodeInput" class="form-control bg-light" placeholder="Hoặc nhập mã tại đây...">
                            <button class="btn btn-dark px-4" type="button" id="btnApplyVoucher">Áp dụng</button>
                        </div>
                        <div id="voucherMessage" class="mt-2 small fw-bold"></div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-4">Tóm tắt đơn hàng</h5>
                        
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tổng tiền hàng</span>
                            <span class="fw-bold">@totalAmount.ToString("N0")đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Phí vận chuyển</span>
                            <span class="fw-bold text-success">Miễn phí</span>
                        </div>

                        <div class="d-flex justify-content-between mb-3 d-none" id="discountRow">
                            <span class="text-muted">Giảm giá (<span id="appliedVoucherName"></span>)</span>
                            <span class="fw-bold text-danger" id="discountAmountText">-0đ</span>
                        </div>
                        
                        <hr class="text-muted opacity-25 my-3">
                        
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="fw-bold text-dark">Tổng thanh toán</span>
                            <span class="fw-bold fs-5 text-dark" id="finalTotalAmount">@totalAmount.ToString("N0")đ</span>
                        </div>
                        
                        @if (cart != null && cart.CartDetails != null)
                        {
                            foreach (var item in cart.CartDetails)
                            {
                                <input type="hidden" name="SelectedIds" value="@item.Id" />
                            }
                        }
                        
                        <input type="hidden" asp-for="VoucherCode" id="hiddenVoucherCode" />

                        <button type="submit" class="btn btn-dark w-100 py-3 fw-bold rounded-3">Đặt hàng</button>
                    </div>
                </div>

            </div>
        </div>
    </form>
</div>

<div class="modal fade" id="voucherModal" tabindex="-1" aria-labelledby="voucherModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold" id="voucherModalLabel"><i class="bi bi-ticket-perforated me-2"></i>Chọn Mã Khuyến Mãi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                @if (ViewBag.Vouchers != null)
                {
                    var voucherList = ViewBag.Vouchers as List<ShopQuanAo.Models.BEAN.Entity.Voucher>;
                    if (voucherList != null && voucherList.Any())
                    {
                        foreach (var v in voucherList)
                        {
                            if (!v.IsPublic) continue;

                            bool isEligible = totalAmount >= v.MinOrderAmount;
                            string opacityClass = isEligible ? "" : "opacity-50";
                      
                            <div class="card mb-3 border-0 shadow-sm @opacityClass">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="pe-3 border-end border-2 border-warning" style="min-width: 100px;">
                                            <h6 class="fw-bold mb-0 text-dark">@v.Code</h6>
                                        </div>
                                        <div class="flex-grow-1 px-3">
                                            <p class="mb-1 fw-bold text-danger">Giảm @v.DiscountAmount.ToString("N0")đ</p>
                                            <p class="mb-0 text-muted" style="font-size: 0.75rem;">Đơn tối thiểu @v.MinOrderAmount.ToString("N0")đ</p>
                                        </div>
                                        <div>
                                            @if (isEligible)
                                            {
                                                <button type="button" class="btn btn-outline-dark btn-sm rounded-pill fw-bold" onclick="selectVoucher('@v.Code')">Dùng</button>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Không đủ ĐK</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1"></i>
                            <p class="mt-3 mb-0">Hiện tại chưa có mã giảm giá nào.</p>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    
    <style>
        .form-control:focus, .form-check-input:focus {
            box-shadow: none;
            border-color: #1a2b4c;
        }

        .form-check-input:checked {
            background-color: #1a2b4c;
            border-color: #1a2b4c;
        }
    </style>

    <script>
        const originalTotal = @Convert.ToInt32(totalAmount);
        
        function selectVoucher(code) {
            var modalEl = document.getElementById('voucherModal');
            var modal = bootstrap.Modal.getInstance(modalEl);
            if (modal) { modal.hide(); }
            document.getElementById('voucherCodeInput').value = code;
            document.getElementById('btnApplyVoucher').click();
        }

        document.getElementById('btnApplyVoucher').addEventListener('click', async function () {
            const codeInput = document.getElementById('voucherCodeInput');
            const code = codeInput.value.trim();
            const messageEl = document.getElementById('voucherMessage');

            if (!code) {
                messageEl.innerHTML = '<span class="text-danger">Vui lòng nhập mã khuyến mãi.</span>';
                return;
            }

            const btn = this;
            const originalBtnText = btn.innerText;
            btn.innerText = "Đang kiểm tra...";
            btn.disabled = true;

            try {
                const response = await fetch('/Checkout/ApplyVoucher', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ code: code, orderTotal: originalTotal })
                });

                const data = await response.json();
                
                if (data.success) {
                    messageEl.innerHTML = '<span class="text-success"><i class="bi bi-check-circle"></i> ' + data.message + '</span>';
                    const discount = data.discountAmount;
                    let newTotal = originalTotal - discount;
                    if (newTotal < 0) newTotal = 0;

                    document.getElementById('appliedVoucherName').innerText = data.voucherCode;
                    document.getElementById('discountAmountText').innerText = '-' + discount.toLocaleString('vi-VN') + 'đ';
                    document.getElementById('discountRow').classList.remove('d-none');
                    document.getElementById('finalTotalAmount').innerText = newTotal.toLocaleString('vi-VN') + 'đ';
                    document.getElementById('hiddenVoucherCode').value = data.voucherCode;
                    codeInput.readOnly = true;
                } else {
                    messageEl.innerHTML = '<span class="text-danger"><i class="bi bi-exclamation-circle"></i> ' + data.message + '</span>';
                    document.getElementById('discountRow').classList.add('d-none');
                    document.getElementById('finalTotalAmount').innerText = originalTotal.toLocaleString('vi-VN') + 'đ';
                    document.getElementById('hiddenVoucherCode').value = '';
                    codeInput.readOnly = false;
                }
            } catch (error) {
                messageEl.innerHTML = '<span class="text-danger">Lỗi hệ thống. Vui lòng thử lại sau.</span>';
            } finally {
                if (!document.getElementById('hiddenVoucherCode').value) {
                    btn.disabled = false;
                }
                btn.innerText = originalBtnText;
            }
        });
    </script>
}