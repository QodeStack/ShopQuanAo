@{
    ViewData["Title"] = "Đặt hàng thành công";
    int orderId = ViewBag.OrderId ?? 0;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
    /* Chỉ apply cho OrderSuccess page, không ảnh hưởng header */
    .order-success-wrapper {
        background: #ffffff;
        min-height: 100vh;
        padding: 40px 20px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
    }

    /* Success Card */
    .success-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(10px);
        animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        overflow: hidden;
        position: relative;
    }

    .success-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #00b4db 0%, #0083b0 100%);
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Success Icon */
    .success-icon-wrap {
        animation: scaleIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes scaleIn {
        0% {
            opacity: 0;
            transform: scale(0.5) rotate(-180deg);
        }
        100% {
            opacity: 1;
            transform: scale(1) rotate(0deg);
        }
    }

    .success-icon-circle {
        background: linear-gradient(135deg, #00b4db 0%, #0083b0 100%) !important;
        color: white !important;
        box-shadow: 0 10px 30px rgba(0, 180, 219, 0.3);
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            box-shadow: 0 10px 30px rgba(0, 180, 219, 0.3), 0 0 0 0 rgba(0, 180, 219, 0.7);
        }
        50% {
            box-shadow: 0 10px 30px rgba(0, 180, 219, 0.3), 0 0 0 10px rgba(0, 180, 219, 0);
        }
    }

    .success-icon-circle i {
        animation: checkMark 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes checkMark {
        0% {
            transform: scale(0) rotate(-180deg);
        }
        100% {
            transform: scale(1) rotate(0deg);
        }
    }

    /* Title */
    .order-title {
        font-size: 2.5rem;
        color: #1a1a1a;
        letter-spacing: -0.5px;
        font-weight: 800;
        margin-bottom: 1.5rem !important;
    }

    /* Order Info */
    .order-info-text p {
        font-size: 1rem;
        color: #666;
        line-height: 1.6;
    }

    .order-id-badge {
        display: inline-block;
        background: linear-gradient(135deg, #1a2b4c 0%, #0083b0 100%) !important;
        color: white !important;
        font-size: 1.75rem;
        font-weight: 700;
        padding: 15px 40px !important;
        border-radius: 50px !important;
        box-shadow: 0 10px 25px rgba(0, 131, 176, 0.3);
        letter-spacing: 1px;
        transition: all 0.3s ease;
        cursor: default;
    }

    .order-id-badge:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(0, 131, 176, 0.4);
    }

    /* Note Text */
    .note-text {
        color: #888;
        font-size: 1rem;
        line-height: 1.8;
        background: rgba(0, 180, 219, 0.05);
        padding: 20px;
        border-radius: 12px;
        border-left: 4px solid #00b4db;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 2rem;
    }

    .action-buttons a {
        flex: 1;
        min-width: 200px;
        padding: 15px 35px !important;
        border-radius: 50px !important;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        border: 2px solid #1a2b4c;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .action-buttons a.btn-outline-dark {
        background: transparent;
        color: #1a2b4c;
        border-color: #1a2b4c;
    }

    .action-buttons a.btn-outline-dark:hover {
        background: #1a2b4c;
        color: white;
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(26, 43, 76, 0.3);
    }

    .action-buttons a.btn-dark {
        background: linear-gradient(135deg, #1a2b4c 0%, #0083b0 100%);
        color: white;
        border-color: transparent;
    }

    .action-buttons a.btn-dark:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(0, 131, 176, 0.4);
        background: linear-gradient(135deg, #0083b0 0%, #1a2b4c 100%);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .order-title {
            font-size: 2rem;
            margin-bottom: 1rem !important;
        }

        .order-id-badge {
            font-size: 1.5rem !important;
            padding: 12px 30px !important;
        }

        .action-buttons {
            flex-direction: column;
            gap: 12px;
        }

        .action-buttons a {
            width: 100%;
            min-width: unset;
        }

        .note-text {
            font-size: 0.95rem;
            padding: 15px;
        }

        .order-info-text p {
            font-size: 0.95rem;
        }

        .success-card {
            padding: 2rem 1.5rem !important;
        }
    }

    @@media (max-width: 576px) {
        .success-icon-circle {
            width: 100px !important;
            height: 100px !important;
        }

        .success-icon-circle i {
            font-size: 3rem !important;
        }

        .order-title {
            font-size: 1.75rem;
        }

        .order-id-badge {
            font-size: 1.25rem !important;
            padding: 10px 25px !important;
        }
    }
</style>

<div class="order-success-wrapper">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card border-0 success-card p-5">

                <!-- Success Icon -->
                <div class="success-icon-wrap text-center mb-4">
                    <div class="success-icon-circle d-flex align-items-center justify-content-center mx-auto" style="width: 120px; height: 120px;">
                        <i class="bi bi-check-circle" style="font-size: 3.5rem;"></i>
                    </div>
                </div>

                <!-- Title -->
                <h1 class="order-title text-center">ĐẶT HÀNG THÀNH CÔNG!</h1>

                <!-- Order Info -->
                <div class="order-info-text text-center mb-4">
                    <p>Cảm ơn bạn đã mua sắm tại cửa hàng của chúng tôi.</p>
                    <p class="mb-4">Mã đơn hàng của bạn là:</p>
                    <div>
                        <div class="order-id-badge">
                            #@orderId
                        </div>
                    </div>
                </div>

                <!-- Note -->
                <p class="note-text text-center mb-5 w-100">
                    <strong style="color: #0083b0;">Hệ thống đã ghi nhận đơn hàng</strong><br/>
                    Chúng tôi xác nhận đơn hàng và tiến hành giao hàng trong thời gian sớm nhất.
                </p>

                <!-- Action Buttons -->
                <div class="action-buttons">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark">
                        <i class="bi bi-house"></i> Về trang chủ
                    </a>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-dark">
                        <i class="bi bi-bag-check"></i> Tiếp tục mua sắm
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Confetti animation (tuỳ chọn)
        function createConfetti() {
            const colors = ['#00b4db', '#0083b0', '#1a2b4c', '#ffd700', '#ff6b6b'];
            const confettiPieces = 50;

            for (let i = 0; i < confettiPieces; i++) {
                const confetti = document.createElement('div');
                confetti.style.position = 'fixed';
                confetti.style.width = '10px';
                confetti.style.height = '10px';
                confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                confetti.style.borderRadius = '50%';
                confetti.style.left = Math.random() * window.innerWidth + 'px';
                confetti.style.top = '-10px';
                confetti.style.opacity = '0.7';
                confetti.style.pointerEvents = 'none';
                confetti.style.zIndex = '9999';

                document.body.appendChild(confetti);

                const duration = Math.random() * 2 + 2;
                const xOffset = (Math.random() - 0.5) * window.innerWidth;

                confetti.animate([
                    { transform: 'translateY(0) translateX(0) rotate(0deg)', opacity: 0.7 },
                    { transform: `translateY(${window.innerHeight + 100}px) translateX(${xOffset}px) rotate(360deg)`, opacity: 0 }
                ], {
                    duration: duration * 1000,
                    easing: 'cubic-bezier(0.25, 0.46, 0.45, 0.94)'
                });

                setTimeout(() => confetti.remove(), duration * 1000);
            }
        }

        // Trigger confetti on page load
        window.addEventListener('load', createConfetti);
    </script>
}