@{
    ViewData["Title"] = "Thanh toán đơn hàng";
    
    int orderId = ViewBag.OrderId ?? 0;
    double amount = ViewBag.TotalAmount ?? 0;

    // CẤU HÌNH API VIETQR
    string bankBin = "970422"; // MB Bank
    string bankAccount = "9615210022006"; // STK của bạn
    string accountName = "NGUYEN DUONG TUAN KIET";
    string orderCode = $"MENSHOP {orderId}";

    string encodedInfo = Uri.EscapeDataString(orderCode);
    string encodedName = Uri.EscapeDataString(accountName);
    string qrUrl = $"https://img.vietqr.io/image/{bankBin}-{bankAccount}-compact2.png?amount={amount}&addInfo={encodedInfo}&accountName={encodedName}";
}

<div class="container my-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 p-4 mx-auto">
                <h4 class="fw-bolder mb-2 text-dark">Thanh toán đơn hàng #@orderId</h4>
                <p class="text-muted small mb-4">Mã QR sẽ hết hạn sau: <span id="countdownTimer" class="fw-bold text-danger fs-5">10:00</span></p>

                <div id="paymentContainer" class="p-4 border rounded bg-white shadow-sm position-relative">
                    <div id="loadingOverlay" class="position-absolute top-0 start-0 w-100 h-100 bg-white bg-opacity-75 d-flex flex-column align-items-center justify-content-center d-none" style="z-index: 10; border-radius: inherit;">
                        <div class="spinner-border text-primary mb-2" role="status" style="width: 3rem; height: 3rem;"></div>
                        <h6 class="fw-bold text-primary">Đang xác nhận thanh toán...</h6>
                    </div>

                    <img src="@qrUrl" alt="Mã QR Thanh Toán" class="img-fluid rounded border border-2 border-primary mb-3 p-2 shadow-sm" style="width: 250px; height: 250px; object-fit: contain;" />
                    
                    <div class="text-start bg-light p-3 rounded" style="font-size: 0.95rem;">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Ngân hàng:</span>
                            <span class="fw-bold">MB Bank</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Chủ tài khoản:</span>
                            <span class="fw-bold">@accountName</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Số tài khoản:</span>
                            <span class="fw-bold">@bankAccount</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Số tiền:</span>
                            <span class="fw-bold text-danger fs-5">@amount.ToString("N0")₫</span>
                        </div>
                        <div class="d-flex justify-content-between border-top pt-2 mt-2">
                            <span class="text-muted">Nội dung CK:</span>
                            <span class="fw-bold text-primary">@orderCode</span>
                        </div>
                    </div>
                </div>

                <div class="alert alert-warning mt-4 mb-0 small text-start">
                    <i class="bi bi-robot me-1"></i> Vui lòng không tắt trình duyệt. Hệ thống sẽ tự động chuyển trang khi bạn thanh toán thành công!
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    
    <script>
        // 1. Đồng hồ đếm ngược 10 phút
        let timeLeft = 600;
        const timerElement = document.getElementById("countdownTimer");
        const paymentContainer = document.getElementById("paymentContainer");

        const countdownInterval = setInterval(function () {
            if (timeLeft <= 0) {
                clearInterval(countdownInterval);
                clearInterval(pollingInterval); // Ngừng quét API
                timerElement.innerText = "00:00";
                paymentContainer.innerHTML = `
                    <div class="py-5">
                        <i class="bi bi-x-circle text-danger mb-3" style="font-size: 3rem;"></i>
                        <h5 class="fw-bold text-danger">Mã QR đã hết hạn</h5>
                        <p class="text-muted small">Vui lòng quay lại giỏ hàng và đặt lại đơn.</p>
                        <a href="/Cart" class="btn btn-outline-dark rounded-pill mt-2">Về giỏ hàng</a>
                    </div>`;
            } else {
                let m = Math.floor(timeLeft / 60);
                let s = timeLeft % 60;
                timerElement.innerText = (m < 10 ? "0" + m : m) + ":" + (s < 10 ? "0" + s : s);
                timeLeft--;
            }
        }, 1000);

        // 2. Chạy ngầm kiểm tra Database mỗi 3 giây
        const pollingInterval = setInterval(function () {
            fetch(`/Checkout/CheckPaymentStatus?orderId=@orderId`)
                .then(response => response.json())
                .then(data => {
                    if (data.isPaid) {
                        // Đã nhận được tiền -> Bật loading che mã QR -> Chuyển trang
                        clearInterval(pollingInterval);
                        clearInterval(countdownInterval);
                        document.getElementById("loadingOverlay").classList.remove("d-none");
                        
                        setTimeout(() => {
                            window.location.href = `/Checkout/OrderSuccess?orderId=@orderId`;
                        }, 1500); // Đợi 1.5s cho đẹp rồi mới chuyển trang
                    }
                })
                .catch(error => console.error("Lỗi đồng bộ:", error));
        }, 3000);
    </script>
}