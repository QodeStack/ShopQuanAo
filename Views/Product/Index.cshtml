@model List<ShopQuanAo.Models.Entity.Product>
@using ShopQuanAo.Models

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <title>Tất Cả Sản Phẩm</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/product.css" asp-append-version="true" />
</head>
<body>

    <div class="announce-bar">Miễn phí vận chuyển cho đơn hàng từ 500,000đ &nbsp;·&nbsp; Đổi trả trong 30 ngày</div>

    <button class="mobile-toggle-btn" onclick="document.getElementById('sidebar').classList.toggle('show')">
        <i class="bi bi-list"></i> &nbsp; Danh mục
    </button>

    <div class="layout">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-label">Danh mục</div>
            <div class="cat-all">
                <ahref ="@Url.Action("Index", "Product", new { categoryId = (int?)null })"
                       style="color:inherit;text-decoration:none;font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:@(ViewBag.CurrentCategoryId == null ? "600" : "400")">
                    Tất cả sản phẩm
                </a>
            </div>

            @foreach (var cat in (List<Categories>)ViewBag.Categories)
            {
                bool isActive = ViewBag.CurrentCategoryId != null && (int)ViewBag.CurrentCategoryId == cat.Id;
                <div class="cat-group">
                    <div class="cat-heading @(isActive ? "cat-heading-active" : "")">
                        <a href="@Url.Action("Index", "Product", new { categoryId = cat.Id })"
                               style="color:inherit;text-decoration:none;display:block;width:100%;">
                            @cat.CategoryName
                        </a>
                    </div>
                </div>
            }
        </aside>

        <main class="main-content">
            <div class="page-header">
                <div class="page-title-area">
                    <div class="page-eyebrow">Bộ sưu tập</div>
                    <h1 class="page-title">
                        @if (ViewBag.CurrentCategoryId != null)
                        {
                            var currentCat = ((List<Categories>)ViewBag.Categories)
                                .FirstOrDefault(c => c.Id == (int)ViewBag.CurrentCategoryId);
                            @(currentCat?.CategoryName ?? "Sản phẩm")
                        }
                        else
                        {
                            @:Tất cả sản phẩm
                        }
                    </h1>
                    <div class="product-count">@ViewBag.TotalCount sản phẩm</div>
                </div>
                <div class="header-right">
                    <form method="get" asp-action="Index" asp-controller="Product" id="searchForm">
                        <input type="hidden" name="categoryId" value="@(ViewBag.CurrentCategoryId ?? ViewBag.CurrentCategoryName)" />
                        <input type="hidden" name="price" value="@ViewBag.CurrentPrice" />
                        <div class="search-box" id="sbox">
                            <i class="bi bi-search search-icon"></i>
                            <input type="text" name="search" id="searchInput"
                                   placeholder="Tìm sản phẩm..."
                                   value="@ViewBag.CurrentSearch"
                                   autocomplete="off" />
                            <button type="button" class="search-clear" id="searchClear"
                                    style="display:@(ViewBag.CurrentSearch != null ? "flex" : "none")"
                                    onclick="clearSearch()">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </form>
                    <div class="filter-bar">
                        <div class="filter-item">
                            <button class="filter-btn @(!string.IsNullOrEmpty(ViewBag.CurrentRating as string) ? "active" : "")" onclick="toggleFilter('fRating')">
                                Đánh giá <i class="bi bi-chevron-down"></i>
                            </button>
                            <div class="filter-dropdown" id="fRating">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = ViewBag.CurrentPrice, rating = i, page = 1 })"
                                           class="@(ViewBag.CurrentRating?.ToString() == i.ToString() ? "active-filter" : "")">
                                        @for (int s = 0; s < i; s++)
                                        {
                                            <i class="bi bi-star-fill" style="color: #ffc107; font-size: 12px;"></i>
                                        }
                                        @(i < 5 ? " trở lên" : "")
                                    </a>
                                }
                            </div>
                        </div>
                        <!-- Trong phần filter-bar, thay filter giá: -->
                        <div class="filter-item">
                            <button class="filter-btn @(!string.IsNullOrEmpty(ViewBag.CurrentPrice as string) ? "active" : "")" onclick="toggleFilter('fPrice')">
                                Giá <i class="bi bi-chevron-down"></i>
                            </button>
                            <div class="filter-dropdown" id="fPrice">
                                @* Sửa 'category' thành 'categoryId' và dùng ViewBag.CurrentCategoryId *@
                                <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = "under500", page = 1 })"
                                   class="@(ViewBag.CurrentPrice == "under500" ? "active-filter" : "")">Dưới 500,000đ</a>
       
                                <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = "500to1000", page = 1 })"
                                   class="@(ViewBag.CurrentPrice == "500to1000" ? "active-filter" : "")">500,000đ – 1,000,000đ</a>
       
                                <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = "1000to2000", page = 1 })"
                                   class="@(ViewBag.CurrentPrice == "1000to2000" ? "active-filter" : "")">1,000,000đ – 2,000,000đ</a>
       
                                <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = "over2000", page = 1 })"
                                   class="@(ViewBag.CurrentPrice == "over2000" ? "active-filter" : "")">Trên 2,000,000đ</a>
                            </div>
                        </div>
                        <div class="filter-item">
                            <button class="filter-btn" onclick="toggleFilter('fSort')">
                                Sắp xếp <i class="bi bi-chevron-down"></i>
                            </button>
                            <div class="filter-dropdown" id="fSort">
                                <a href="#">Mới nhất</a>
                                <a href="#">Giá tăng dần</a>
                                <a href="#">Giá giảm dần</a>
                                <a href="#">Bán chạy</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="active-filters">
                @if (ViewBag.CurrentCategoryId != null)
                {
                    var activeCat = ((List<Categories>)ViewBag.Categories)
                        .FirstOrDefault(c => c.Id == (int)ViewBag.CurrentCategoryId);
                    <span class="filter-tag">
                        @activeCat?.CategoryName
                        <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch })" style="color:inherit;text-decoration:none;">
                            <i class="bi bi-x"></i>
                        </a>
                    </span>
                }
                else
                {
                    <span class="filter-tag">Tất cả <i class="bi bi-x"></i></span>
                }
                @if (!string.IsNullOrEmpty(ViewBag.CurrentPrice as string))
                {
                    var priceLabel = (ViewBag.CurrentPrice as string) switch
                    {
                        "under500" => "Dưới 500k",
                        "500to1000" => "500k – 1tr",
                        "1000to2000" => "1tr – 2tr",
                        "over2000" => "Trên 2tr",
                        _ => ""
                    };
                    <span class="filter-tag">
                        @priceLabel
                        <a href="@Url.Action("Index", "Product", new { category = ViewBag.CurrentCategoryId ?? ViewBag.CurrentCategoryName, search = ViewBag.CurrentSearch })" style="color:inherit;text-decoration:none;">
                            <i class="bi bi-x"></i>
                        </a>
                    </span>
                }
            </div>

            <div class="product-grid" id="productGrid">
                @if (!Model.Any())
                {
                    <div style="grid-column:1/-1;text-align:center;padding:80px 0;color:var(--light);font-size:14px;letter-spacing:1px;">
                        <i class="bi bi-box-seam" style="font-size:40px;display:block;margin-bottom:16px;opacity:0.3"></i>
                        Không có sản phẩm nào trong danh mục này.
                    </div>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <div class="product-card">
                            <div class="product-image">
                                <a href="@Url.Action("ProductDetail", "Product", new { id = item.Id })">
                                    <img src="@item.Image" alt="@item.ProductName" loading="lazy" />
                                </a>
                            </div>
                            <div class="product-info">
                                <div class="product-name">
                                    <a href="@Url.Action("ProductDetail", "Product", new { id = item.Id })">
                                        @item.ProductName
                                    </a>
                                </div>
                                <div class="product-price">@item.Price.ToString("N0")đ</div>
                            </div>
                        </div>
                    }
                }
            </div>

            @{
                int pg = (int)ViewBag.CurrentPage;
                int totalPgs = (int)ViewBag.TotalPages;
                int? fCatId = ViewBag.CurrentCategoryId;
                string fSearch = ViewBag.CurrentSearch;
                int pgStart = Math.Max(1, pg - 2);
                int pgEnd = Math.Min(totalPgs, pg + 2);
            }

            @if (totalPgs > 1)
            {
                <div class="pagination-area">

                    @if (pg > 1)
                    {
                        <a class="page-num" href="@Url.Action("Index", "Product", new { page = pg - 1, categoryId = fCatId, search = fSearch })">
                            <i class="bi bi-chevron-left" style="font-size:13px"></i>
                        </a>
                    }
                    else
                    {
                        <span class="page-num" style="opacity:0.3;cursor:default;"><i class="bi bi-chevron-left" style="font-size:13px"></i></span>
                    }

                    @if (pgStart > 1)
                    {
                        <a class="page-num" href="@Url.Action("Index", "Product", new { page = 1, categoryId = fCatId, search = fSearch })">1</a>
                        if (pgStart > 2)
                        {
                            <span class="page-num" style="border:none;color:var(--light);cursor:default;">…</span>
                        }
                    }

                    @for (int p = pgStart; p <= pgEnd; p++)
                    {
                        if (p == pg)
                        {
                            <span class="page-num active">@p</span>
                        }
                        else
                        {
                            <a class="page-num" href="@Url.Action("Index", "Product", new { page = p, categoryId = fCatId, search = fSearch, price = ViewBag.CurrentPrice })">@p</a>
                        }
                    }

                    @if (pgEnd < totalPgs)
                    {
                        if (pgEnd < totalPgs - 1)
                        {
                            <span class="page-num" style="border:none;color:var(--light);cursor:default;">…</span>
                        }
                        <a class="page-num" href="@Url.Action("Index", "Product", new { page = totalPgs, categoryId = fCatId, search = fSearch })">@totalPgs</a>
                    }

                    @if (pg < totalPgs)
                    {
                        <a class="page-num" href="@Url.Action("Index", "Product", new { page = pg + 1, categoryId = fCatId, search = fSearch })">
                            <i class="bi bi-chevron-right" style="font-size:13px"></i>
                        </a>
                    }
                    else
                    {
                        <span class="page-num" style="opacity:0.3;cursor:default;"><i class="bi bi-chevron-right" style="font-size:13px"></i></span>
                    }

                </div>

                <div style="text-align:center;font-size:12px;color:var(--light);margin-top:12px;letter-spacing:0.5px;">
                    Trang @pg / @totalPgs &nbsp;·&nbsp; @ViewBag.TotalCount sản phẩm
                </div>
            }

        </main>
    </div>

    <script src="~/js/product.js"></script>
</body>
</html>
