@model List<ShopQuanAo.Models.Entity.Product>
@using ShopQuanAo.Models

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <title>Tất Cả Sản Phẩm</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/product.css" asp-append-version="true" />
    
    <style>
        .out-of-stock-overlay {
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.75); color: #fff;
            padding: 8px 16px; border-radius: 4px;
            font-size: 14px; font-weight: 500; z-index: 10;
            pointer-events: none; white-space: nowrap; letter-spacing: 0.5px;
        }
        .product-image { position: relative; }
        .out-of-stock img { opacity: 0.4; }
    </style>
</head>
<body>
    <div class="announce-bar">Miễn phí vận chuyển cho đơn hàng từ 500,000đ &nbsp;·&nbsp; Đổi trả trong 30 ngày</div>

    <button class="mobile-toggle-btn" onclick="document.getElementById('sidebar').classList.toggle('show')">
        <i class="bi bi-list"></i> &nbsp; Danh mục
    </button>

    <div class="layout">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-label">Danh mục</div>
            <div class="cat-all">
                <a href="@Url.Action("Index", "Product", new { categoryId = (int?)null })"
                   style="color:inherit;text-decoration:none;font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:@(ViewBag.CurrentCategoryId == null ? "600" : "400")">
                    Tất cả sản phẩm
                </a>
            </div>

            @if (ViewBag.Categories != null)
            {
                foreach (var cat in (List<Categories>)ViewBag.Categories)
                {
                    bool isActive = ViewBag.CurrentCategoryId != null && (int)ViewBag.CurrentCategoryId == cat.Id;
                    <div class="cat-group">
                        <div class="cat-heading @(isActive ? "cat-heading-active" : "")">
                            <a href="@Url.Action("Index", "Product", new { categoryId = cat.Id })"
                               style="color:inherit;text-decoration:none;display:block;width:100%;">
                                @cat.CategoryName
                            </a>
                        </div>
                    </div>
                }
            }
        </aside>

        <main class="main-content">
            <div class="page-header">
                <div class="page-title-area">
                    <div class="page-eyebrow">Bộ sưu tập</div>
                    <h1 class="page-title">
                        @if (ViewBag.CurrentCategoryId != null && ViewBag.Categories != null)
                        {
                            var currentCat = ((List<Categories>)ViewBag.Categories)
                                .FirstOrDefault(c => c.Id == (int)ViewBag.CurrentCategoryId);
                            @Html.Raw(currentCat?.CategoryName ?? "Sản phẩm")
                        }
                        else
                        {
                            @:Tất cả sản phẩm
                        }
                    </h1>
                    <div class="product-count">@ViewBag.TotalCount sản phẩm</div>
                </div>

                <div class="header-right">
                    <form method="get" asp-action="Index" asp-controller="Product" id="searchForm">
                        <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategoryId" />
                        <input type="hidden" name="price" value="@ViewBag.CurrentPrice" />
                        <div class="search-box" id="sbox">
                            <i class="bi bi-search search-icon"></i>
                            <input type="text" name="search" id="searchInput"
                                   placeholder="Tìm sản phẩm..."
                                   value="@ViewBag.CurrentSearch"
                                   autocomplete="off" />
                            <button type="button" class="search-clear" id="searchClear"
                                    style="display:@(!string.IsNullOrEmpty(ViewBag.CurrentSearch) ? "flex" : "none")"
                                    onclick="clearSearch()">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </form>

                    <div class="filter-bar">
                        @* Filter Đánh giá *@
                        <div class="filter-item">
                            <button class="filter-btn @(ViewBag.CurrentRating != null ? "active" : "")" onclick="toggleFilter('fRating')">
                                Đánh giá <i class="bi bi-chevron-down"></i>
                            </button>
                            <div class="filter-dropdown" id="fRating">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = ViewBag.CurrentPrice, rating = i, page = 1 })"
                                       class="@(ViewBag.CurrentRating?.ToString() == i.ToString() ? "active-filter" : "")">
                                        @for (int s = 0; s < i; s++) { <i class="bi bi-star-fill" style="color: #ffc107; font-size: 12px;"></i> }
                                        @(i < 5 ? " trở lên" : "")
                                    </a>
                                }
                            </div>
                        </div>

                        @* Filter Giá *@
                        <div class="filter-item">
                            <button class="filter-btn @(!string.IsNullOrEmpty(ViewBag.CurrentPrice) ? "active" : "")" onclick="toggleFilter('fPrice')">
                                Giá <i class="bi bi-chevron-down"></i>
                            </button>
                            <div class="filter-dropdown" id="fPrice">
                                <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = "under500", page = 1 })">Dưới 500,000đ</a>
                                <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = "500to1000", page = 1 })">500k – 1tr</a>
                                <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = "1000to2000", page = 1 })">1tr – 2tr</a>
                                <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = "over2000", page = 1 })">Trên 2tr</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="active-filters" style="margin-bottom: 20px;">
                @if (ViewBag.CurrentCategoryId != null && ViewBag.Categories != null)
                {
                    var activeCat = ((List<Categories>)ViewBag.Categories).FirstOrDefault(c => c.Id == (int)ViewBag.CurrentCategoryId);
                    if (activeCat != null)
                    {
                        <span class="filter-tag">@activeCat.CategoryName <a href="@Url.Action("Index", "Product", new { search = ViewBag.CurrentSearch })"><i class="bi bi-x"></i></a></span>
                    }
                }
                @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
                {
                    <span class="filter-tag">Tìm kiếm: @ViewBag.CurrentSearch <a href="@Url.Action("Index", "Product", new { categoryId = ViewBag.CurrentCategoryId })"><i class="bi bi-x"></i></a></span>
                }
            </div>

            <div class="product-grid" id="productGrid">
                @if (Model == null || !Model.Any())
                {
                    <div style="grid-column:1/-1;text-align:center;padding:80px 0;opacity:0.5;">
                        <i class="bi bi-box-seam" style="font-size:40px;"></i>
                        <p>Không tìm thấy sản phẩm nào.</p>
                    </div>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        bool isOutOfStock = item.TotalQuantity <= 0;
                        <div class="product-card @(isOutOfStock ? "out-of-stock" : "")">
                            <div class="product-image">
                                @if (isOutOfStock)
                                {
                                    <div class="out-of-stock-overlay">Đã hết hàng</div>
                                }
                                <a href="@Url.Action("ProductDetail", "Product", new { id = item.Id })">
                                    <img src="@item.Image" alt="@item.ProductName" loading="lazy" />
                                </a>
                            </div>
                            <div class="product-info">
                                <div class="product-name">
                                    <a href="@Url.Action("ProductDetail", "Product", new { id = item.Id })">@item.ProductName</a>
                                </div>
                                <div class="product-price">
                                    @if (isOutOfStock)
                                    {
                                        <span style="color: #aaa; text-decoration: line-through;">@item.Price.ToString("N0")đ</span>
                                    }
                                    else
                                    {
                                        <span>@item.Price.ToString("N0")đ</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            @* Phân trang *@
            @{
                int pg = ViewBag.CurrentPage ?? 1;
                int totalPgs = ViewBag.TotalPages ?? 1;
                int pgStart = Math.Max(1, pg - 2);
                int pgEnd = Math.Min(totalPgs, pg + 2);
            }

            @if (totalPgs > 1)
            {
                <div class="pagination-area">
                    @if (pg > 1)
                    {
                        <a class="page-num" href="@Url.Action("Index", "Product", new { page = pg - 1, categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = ViewBag.CurrentPrice })"><i class="bi bi-chevron-left"></i></a>
                    }
                    
                    @if (pgStart > 1)
                    {
                        <a class="page-num" href="@Url.Action("Index", "Product", new { page = 1, categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch })">1</a>
                        if (pgStart > 2) { <span class="page-num" style="border:none;">...</span> }
                    }

                    @for (int p = pgStart; p <= pgEnd; p++)
                    {
                        <a class="page-num @(p == pg ? "active" : "")" href="@Url.Action("Index", "Product", new { page = p, categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = ViewBag.CurrentPrice })">@p</a>
                    }

                    @if (pgEnd < totalPgs)
                    {
                        if (pgEnd < totalPgs - 1) { <span class="page-num" style="border:none;">...</span> }
                        <a class="page-num" href="@Url.Action("Index", "Product", new { page = totalPgs, categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch })">@totalPgs</a>
                    }

                    @if (pg < totalPgs)
                    {
                        <a class="page-num" href="@Url.Action("Index", "Product", new { page = pg + 1, categoryId = ViewBag.CurrentCategoryId, search = ViewBag.CurrentSearch, price = ViewBag.CurrentPrice })"><i class="bi bi-chevron-right"></i></a>
                    }
                </div>
            }
        </main>
    </div>

    <script src="~/js/product.js"></script>
    <script>
        function clearSearch() {
            document.getElementById('searchInput').value = '';
            document.getElementById('searchForm').submit();
        }
        function toggleFilter(id) {
            const el = document.getElementById(id);
            const isVisible = el.style.display === 'block';
            document.querySelectorAll('.filter-dropdown').forEach(d => d.style.display = 'none');
            el.style.display = isVisible ? 'none' : 'block';
        }
    </script>
</body>
</html>