@model List<ShopQuanAo.Models.Entity.Product>
@{
    ViewData["Title"] = "Sale - MENSHOP";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">

<style>
    body, .sale-page {
        font-family: 'DM Sans', sans-serif !important;
        background-color: #fff;
    }

    /* --- BANNER SALE --- */
    .sale-hero {
        width: 100%;
        overflow: hidden;
        line-height: 0;
        margin-bottom: 30px;
    }
    .sale-hero img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: contain;
    }

    /* Sidebar */
    .filter-sidebar { border-right: 1px solid #f0f0f0; padding-right: 20px; }
    .sidebar-label { font-size: 14px; font-weight: 700; text-transform: uppercase; margin-bottom: 20px; color: #000; border-bottom: 2px solid #000; padding-bottom: 5px; display: inline-block; }
    .filter-list { list-style: none; padding: 0; }
    .filter-list li { margin-bottom: 12px; }
    .filter-list a { text-decoration: none; color: #666; font-size: 15px; transition: 0.2s; }
    .filter-list a:hover, .active-cat { color: #000 !important; font-weight: 700; }

    /* Grid 5 cột */
    .product-grid { 
        display: grid; 
        grid-template-columns: repeat(5, 1fr); 
        gap: 20px 15px; 
    }

    .product-card { border: 1px solid #f0f0f0; position: relative; transition: 0.3s; background: #fff; }
    .product-img-container { position: relative; overflow: hidden; aspect-ratio: 3/4; }
    .product-img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
    .product-card:hover .product-img { transform: scale(1.05); }

    .sale-tag { position: absolute; top: 10px; left: 10px; background: #ff0000; color: #fff; padding: 3px 8px; font-size: 11px; font-weight: 700; z-index: 2; }

    .product-info { padding: 12px; text-align: left; }
    .product-name a { font-size: 12px; color: #333; font-weight: 500; text-decoration: none; display: block; margin-bottom: 6px; text-transform: uppercase; line-height: 1.4; height: 34px; overflow: hidden; }
    
    .price-box { display: flex; gap: 8px; align-items: center; }
    .price-current { color: #ff0000; font-weight: 700; font-size: 14px; }
    .price-old { text-decoration: line-through; color: #999; font-size: 11px; }

    /* Style cho form sắp xếp */
    .sort-select {
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        border: none;
        border-bottom: 1px solid #ccc;
        cursor: pointer;
        padding: 5px;
        outline: none;
    }
</style>

<section class="sale-hero">
    <img src="~/Image/Banner_sanpham/Banner_sale.jpg" alt="Outlet Sale Banner">
</section>

<div class="container-fluid" style="padding: 0 40px;">
    <div class="row">
        <div class="col-lg-2">
            <aside class="filter-sidebar">
                <div class="sidebar-label">Danh mục sale</div>
                <ul class="filter-list">
                    <li><a href="@Url.Action("Sale", "Product")" class="@(ViewBag.CurrentCategoryId == null ? "active-cat" : "")">Tất cả</a></li>
                    @foreach (var cat in (ViewBag.Categories as List<ShopQuanAo.Models.Entity.Categories>) ?? new List<ShopQuanAo.Models.Entity.Categories>())
                    {
                        <li><a href="@Url.Action("Sale", "Product", new { categoryId = cat.Id, price = ViewBag.CurrentPrice })" class="@(ViewBag.CurrentCategoryId != null && (int)ViewBag.CurrentCategoryId == cat.Id ? "active-cat" : "")">@cat.CategoryName</a></li>
                    }
                </ul>
            </aside>
        </div>

        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-end mb-4 pb-2 border-bottom">
                <div>
                    <span style="font-size: 11px; color: red; font-weight: 700; text-transform: uppercase;">Outlet Sale</span>
                    <h2 style="font-weight: 700; text-transform: uppercase; margin: 0;">Tất cả đồ sale</h2>
                    <div style="font-size: 13px; color: #888; margin-top: 5px;">Có @ViewBag.TotalCount sản phẩm</div>
                </div>

                <div class="header-right">
                    <form method="get" action="@Url.Action("Sale", "Product")" id="sortForm">
                        <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategoryId" />
                        <select class="sort-select" name="price" onchange="this.form.submit()">
                            <option value="">Sắp xếp khoảng giá</option>
                            <option value="under500" selected="@(ViewBag.CurrentPrice == "under500")">Dưới 500k</option>
                            <option value="500to1000" selected="@(ViewBag.CurrentPrice == "500to1000")">500k - 1tr</option>
                            <option value="1000to2000" selected="@(ViewBag.CurrentPrice == "1000to2000")">1tr - 2tr</option>
                            <option value="over2000" selected="@(ViewBag.CurrentPrice == "over2000")">Trên 2tr</option>
                        </select>
                    </form>
                </div>
            </div>

            <div class="product-grid">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        int discount = item.Price > 0 ? (int)Math.Round((1 - (double)item.SalePrice / item.Price) * 100) : 0;
                        <div class="product-card">
                            <div class="product-img-container">
                                <span class="sale-tag">-@discount%</span>
                                <a href="@Url.Action("ProductDetail", "Product", new { id = item.Id })">
                                    <img src="@item.Image" class="product-img" alt="@item.ProductName">
                                </a>
                            </div>
                            <div class="product-info">
                                <div class="product-name">
                                    <a href="@Url.Action("ProductDetail", "Product", new { id = item.Id })">@item.ProductName</a>
                                </div>
                                <div class="price-box">
                                    <span class="price-current">@item.SalePrice.ToString("N0")₫</span>
                                    <span class="price-old">@item.Price.ToString("N0")₫</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>