@model List<ShopQuanAo.Models.BEAN.Entity.Product>
@{
    ViewData["Title"] = "Sale - MENSHOP";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<link href="~/css/Product/Product_Sale.css" asp-append-version="true" rel="stylesheet" />



<section class="sale-hero">
    <img src="~/Image/Banner_sanpham/Banner_sale.jpg" alt="Outlet Sale Banner">
</section>

<div class="container-fluid" style="padding: 0 50px;">
    <div class="row">
        <div class="col-lg-2">
            <aside class="filter-sidebar">
                <div class="sidebar-label">Danh mục sale</div>
                <ul class="filter-list">
                    <li>
                        <a href="@Url.Action("Sale", "Product")" 
                           class="@(ViewBag.CurrentCategoryId == null ? "active-cat" : "")">Tất cả sản phẩm</a>
                    </li>
                    @foreach (var cat in (ViewBag.Categories as List<ShopQuanAo.Models.BEAN.Entity.Categories>) ?? new List<ShopQuanAo.Models.BEAN.Entity.Categories>())
                    {
                        <li>
                            <a href="@Url.Action("Sale", "Product", new { categoryId = cat.Id, price = ViewBag.CurrentPrice })" 
                               class="@(ViewBag.CurrentCategoryId != null && (int)ViewBag.CurrentCategoryId == cat.Id ? "active-cat" : "")">
                                @cat.CategoryName
                            </a>
                        </li>
                    }
                </ul>
            </aside>
        </div>

        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-end mb-4 pb-3 border-bottom">
                <div>
                    <span class="page-eyebrow">Outlet Sale</span>
                    <h2 class="page-title">
                        @if (ViewBag.CurrentCategoryId != null)
                        {
                            var categories = ViewBag.Categories as List<ShopQuanAo.Models.BEAN.Entity.Categories>;
                            @(categories?.FirstOrDefault(c => c.Id == (int)ViewBag.CurrentCategoryId)?.CategoryName ?? "Sản phẩm")
                        }
                        else
                        {
                            @:Tất cả đồ sale
                        }
                    </h2>
                    <div class="product-count">Hiện có @ViewBag.TotalCount sản phẩm ưu đãi</div>
                </div>

                <div class="header-right">
                    <form method="get" action="@Url.Action("Sale", "Product")" id="sortForm">
                        <input type="hidden" name="categoryId" value="@ViewBag.CurrentCategoryId" />
                        <select class="sort-select" name="price" onchange="this.form.submit()">
                            <option value="">Sắp xếp khoảng giá</option>
                            <option value="under500" selected="@(ViewBag.CurrentPrice == "under500")">Dưới 500k</option>
                            <option value="500to1000" selected="@(ViewBag.CurrentPrice == "500to1000")">500k - 1tr</option>
                            <option value="1000to2000" selected="@(ViewBag.CurrentPrice == "1000to2000")">1tr - 2tr</option>
                            <option value="over2000" selected="@(ViewBag.CurrentPrice == "over2000")">Trên 2tr</option>
                        </select>
                    </form>
                </div>
            </div>

            <div class="product-grid">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        int discount = item.Price > 0 ? (int)Math.Round((1 - (double)item.SalePrice / item.Price) * 100) : 0;
                        <div class="product-card">
                            <div class="product-img-container">
                                <span class="sale-tag">-@discount%</span>
                                <a href="@Url.Action("ProductDetail", "Product", new { id = item.Id })">
                                    <img src="@item.Image" class="product-img" alt="@item.ProductName" loading="lazy">
                                </a>
                            </div>
                            <div class="product-info">
                                <div class="product-name">
                                    <a href="@Url.Action("ProductDetail", "Product", new { id = item.Id })">@item.ProductName</a>
                                </div>
                                <!-- Rating Section -->
                            @{
                                var reviews = ViewBag.AllReviews as Dictionary<int, List<ProductReview>>;
                                double avgRating = 0;
                                int reviewCount = 0;
                                
                                if (reviews != null && reviews.ContainsKey(item.Id))
                                {
                                    var productReviews = reviews[item.Id];
                                    if (productReviews.Any())
                                    {
                                        avgRating = productReviews.Average(r => r.Rating);
                                        reviewCount = productReviews.Count;
                                    }
                                }
                            }
                            
                            <div class="product-rating">
                                <div class="stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        @if (i <= avgRating)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                        else if (i - avgRating < 1 && i - avgRating > 0)
                                        {
                                            <i class="bi bi-star-half"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star"></i>
                                        }
                                    }
                                </div>
                                @if (reviewCount > 0)
                                {
                                    <span class="rating-value">@avgRating.ToString("0.0")</span>
                                    <span class="rating-count">(@reviewCount)</span>
                                }
                                else
                                {
                                    <span class="rating-count">(Chưa có đánh giá)</span>
                                }
                            </div>
                                <div class="price-box">
                                    <span class="price-current">@item.SalePrice.ToString("N0")₫</span>
                                    <span class="price-old">@item.Price.ToString("N0")₫</span>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div style="grid-column: 1/-1; text-align: center; padding: 80px 0; color: #999;">
                        <p>Không có sản phẩm nào phù hợp với bộ lọc.</p>
                    </div>
                }
            </div>

            @if (ViewBag.TotalPages > 1)
            {
                <div class="pagination-area">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <a class="page-num" href="@Url.Action("Sale", "Product", new { page = ViewBag.CurrentPage - 1, categoryId = ViewBag.CurrentCategoryId, price = ViewBag.CurrentPrice })">
                            &lt;
                        </a>
                    }

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <a href="@Url.Action("Sale", "Product", new { page = i, categoryId = ViewBag.CurrentCategoryId, price = ViewBag.CurrentPrice })" 
                           class="page-num @(ViewBag.CurrentPage == i ? "active" : "")">@i</a>
                    }

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <a class="page-num" href="@Url.Action("Sale", "Product", new { page = ViewBag.CurrentPage + 1, categoryId = ViewBag.CurrentCategoryId, price = ViewBag.CurrentPrice })">
                            &gt;
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>