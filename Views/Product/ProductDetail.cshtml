@model ShopQuanAo.Models.Entity.Product
@{
    ViewData["Title"] = Model.ProductName;
    Layout = "~/Views/Shared/_Layout.cshtml";
    // Kiểm tra xem tổng kho có bằng 0 không
    bool isAllOutOfStock = Model.TotalQuantity <= 0;
}

@* Phông chữ và Icon *@
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Mono&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    /* NỀN TỔNG THỂ */
    body { background-color: #f4f4f4; font-family: 'Inter', sans-serif; color: #1a1a1a; }

    /* KHUNG CHÍNH (CARD) */
    .product-card-container {
        background: #fff; max-width: 1200px; margin: 40px auto;
        padding: 40px; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    }

    .detail-layout { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 60px; }
    .detail-image img { width: 100%; border-radius: 12px; object-fit: cover; border: 1px solid #eee; }

    /* THÔNG TIN CHỮ */
    .detail-eyebrow { text-transform: uppercase; letter-spacing: 2px; font-size: 0.7rem; color: #888; margin-bottom: 10px; font-family: 'Space Mono', monospace; }
    .detail-name { font-size: 2.2rem; font-weight: 800; margin-bottom: 15px; line-height: 1.1; }
    .detail-price { font-size: 1.8rem; font-weight: 700; margin-bottom: 30px; }

    /* KHUNG MÃ GIẢM GIÁ */
    .promo-container { border: 1.5px dashed #000; border-radius: 8px; padding: 20px; margin-bottom: 25px; position: relative; }
    .promo-header { position: absolute; top: -12px; left: 20px; background: #fff; padding: 0 10px; font-weight: 800; font-size: 0.75rem; color: #000; display: flex; align-items: center; gap: 6px; }
    .promo-list { list-style: none; padding: 0; margin: 0; }
    .promo-item { font-size: 0.85rem; margin-bottom: 8px; cursor: pointer; transition: 0.2s; }
    .promo-item:hover { color: #ff3b3b; }
    .promo-item b { font-family: 'Space Mono', monospace; background: #f0f0f0; padding: 2px 6px; border-radius: 4px; }
    .promo-freeship { color: #000; font-weight: 600; margin-top: 10px; border-top: 1px solid #eee; padding-top: 10px; }

    /* CHỌN SIZE & SỐ LƯỢNG */
    .size-list { display: flex; gap: 10px; margin-bottom: 30px; }
    .size-btn { width: 52px; height: 52px; border: 1.5px solid #ddd; background: #fff; font-weight: 600; border-radius: 6px; cursor: pointer; transition: 0.2s; }
    .size-btn.active { background: #000; color: #fff; border-color: #000; }
    .size-btn.disabled { opacity: 0.3; cursor: not-allowed; background: #f9f9f9; text-decoration: line-through; }
    
    .purchase-actions { display: flex; gap: 15px; margin-top: 20px; }
    .quantity-picker { display: flex; align-items: center; border: 2px solid #000; border-radius: 6px; height: 55px; background: #fff; }
    
    /* MOD: Làm mờ nút khi bị khóa */
    .quantity-picker button { border: none; background: transparent; width: 45px; height: 100%; font-size: 1.2rem; cursor: pointer; }
    .quantity-picker button:disabled { opacity: 0.3; cursor: not-allowed; color: #ccc; }
    
    .quantity-picker input { width: 50px; border: none; text-align: center; font-weight: 700; outline: none; background: transparent; }
    .btn-add-cart { flex: 1; background: #000; color: #fff; border: none; font-weight: 700; border-radius: 6px; text-transform: uppercase; transition: 0.3s; }
    .btn-add-cart:disabled { background: #ccc; cursor: not-allowed; }

    /* TOAST */
    .toast-msg { position: fixed; top: 20px; right: 20px; padding: 15px 25px; border-radius: 8px; color: #fff; z-index: 9999; opacity: 0; pointer-events: none; transition: 0.3s; font-weight: 600; }
    .toast-msg.show { opacity: 1; }
    .toast-msg.success { background: #10b981; }
    .toast-msg.error { background: #ef4444; }
</style>

<div class="toast-msg" id="toast"></div>

<div class="product-card-container">
    <div class="detail-layout">
        <div class="detail-image">
            <img src="@Model.Image" alt="@Model.ProductName" />
        </div>

        <div class="detail-info">
            <div class="detail-eyebrow">MENSHOP EXCLUSIVE</div>
            <h1 class="detail-name">@Model.ProductName</h1>
            <div class="detail-price">@Model.Price.ToString("N0")₫</div>

            @if (isAllOutOfStock)
            {
                <div class="alert alert-danger py-2" style="font-size: 0.9rem; font-weight: 600;">
                    <i class="bi bi-exclamation-triangle-fill"></i> SẢN PHẨM NÀY HIỆN ĐÃ HẾT HÀNG TRÊN TOÀN HỆ THỐNG
                </div>
            }

            <div class="promo-container">
                <div class="promo-header">
                    <i class="bi bi-gift-fill"></i> KHUYẾN MÃI - ONLY ONLINE
                </div>
                <ul class="promo-list">
                    <li class="promo-item" onclick="copyCode('APR20')">🎫 Nhập mã <b>APR20</b> GIẢM 20K đơn từ 499K</li>
                    <li class="promo-item" onclick="copyCode('APR60')">🎫 Nhập mã <b>APR60</b> GIẢM 60K đơn từ 799K</li>
                    <li class="promo-item" onclick="copyCode('APR90')">🎫 Nhập mã <b>APR90</b> GIẢM 90K đơn từ 1099K</li>
                    <li class="promo-item" onclick="copyCode('APR150')">🎫 Nhập mã <b>APR150</b> GIẢM 150K đơn từ 1599K</li>
                    <li class="promo-item promo-freeship">🚚 <b>FREESHIP</b> đơn từ 399K</li>
                </ul>
            </div>

            <div class="option-row">
                <span class="option-label">KÍCH CỠ: <b id="sizeDisplay">Chưa chọn</b></span>
                <div class="size-list">
                    @if (ViewBag.AvailableSizes != null)
                    {
                        foreach (dynamic sizeItem in ViewBag.AvailableSizes)
                        {
                            bool isOutOfStock = sizeItem.Quantity <= 0;
                            <button type="button" 
                                    class="size-btn @(isOutOfStock ? "disabled" : "")" 
                                    data-size="@sizeItem.SizeName" 
                                    data-stock="@sizeItem.Quantity"
                                    @(isOutOfStock ? "disabled" : "")>
                                @sizeItem.SizeName
                            </button>
                        }
                    }
                </div>
            </div>

            <form id="cartForm" method="post" asp-controller="Cart" asp-action="AddToCart">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.Id" />
                <input type="hidden" name="size" id="selectedSize" value="" />
                
                <div class="purchase-actions">
                    <div class="quantity-picker">
                        @* Thêm ID btnMinus và btnPlus *@
                        <button type="button" id="btnMinus" onclick="changeQty(-1)">-</button>
                        <input type="number" name="quantity" id="buyQty" value="1" min="1" readonly />
                        <button type="button" id="btnPlus" onclick="changeQty(1)">+</button>
                    </div>
                    <button type="button" class="btn-add-cart" id="btnAddCart" @(isAllOutOfStock ? "disabled" : "")>
                        @(isAllOutOfStock ? "HẾT HÀNG" : "THÊM VÀO GIỎ")
                    </button>
                </div>
            </form>
            
            <button class="btn-wishlist w-100 mt-3 border py-2 bg-white rounded"><i class="bi bi-heart"></i> YÊU THÍCH</button>
        </div>
    </div>
</div>

<div class="container bg-white rounded-4 shadow-sm p-5 mb-5">
    <ul class="nav nav-tabs policy-tabs" id="policyTab" role="tablist">
        <li class="nav-item">
            <button class="nav-link active policy-tab-item" data-bs-toggle="tab" data-bs-target="#ship">CHÍNH SÁCH GIAO HÀNG</button>
        </li>
        <li class="nav-item">
            <button class="nav-link policy-tab-item" data-bs-toggle="tab" data-bs-target="#return">CHÍNH SÁCH ĐỔI TRẢ</button>
        </li>
    </ul>
    <div class="tab-content pt-4">
        <div class="tab-pane fade show active" id="ship">
            <div class="row">
                <div class="col-md-6">
                    <h6 class="fw-bold">Thời gian giao hàng:</h6>
                    <p class="small text-muted">- Nội thành Đà Nẵng: 1-2 ngày.<br>- Toàn quốc: 3-5 ngày làm việc.</p>
                </div>
                <div class="col-md-6">
                    <h6 class="fw-bold">Phí vận chuyển:</h6>
                    <p class="small text-muted">- Miễn phí cho đơn hàng từ 399k.<br>- Đồng giá 30k cho đơn hàng dưới 399k.</p>
                </div>
            </div>
        </div>
        <div class="tab-pane fade" id="return">
            <h6 class="fw-bold">Quy định đổi trả:</h6>
            <p class="small text-muted">
                - Hỗ trợ đổi size/mẫu trong vòng 7 ngày kể từ khi nhận hàng.<br>
                - Sản phẩm đổi phải còn nguyên tem mác, chưa qua sử dụng và giặt là.<br>
                - Miễn phí đổi hàng trong trường hợp lỗi do nhà sản xuất.
            </p>
        </div>
    </div>
</div>

<script>
    const isLoggedIn = @Json.Serialize(User.Identity.IsAuthenticated);
    let maxStock = 999; 

    // MOD: Hàm tự động khóa/mở nút +/- 
    function updateButtons() {
        const currentQty = parseInt(document.getElementById('buyQty').value);
        const btnMinus = document.getElementById('btnMinus');
        const btnPlus = document.getElementById('btnPlus');

        btnMinus.disabled = (currentQty <= 1);
        btnPlus.disabled = (currentQty >= maxStock);
    }

    function copyCode(code) {
        navigator.clipboard.writeText(code).then(() => {
            showToast("Đã sao chép mã: " + code, "success");
        });
    }

    function changeQty(val) {
        const selectedSize = document.getElementById('selectedSize').value;
        if (!selectedSize) {
            showToast("Vui lòng chọn kích cỡ trước!", "error");
            return;
        }

        const input = document.getElementById('buyQty');
        let newVal = parseInt(input.value) + val;

        if (newVal >= 1 && newVal <= maxStock) {
            input.value = newVal;
        }
        updateButtons();
    }

    document.querySelectorAll('.size-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const size = btn.dataset.size;
            maxStock = parseInt(btn.dataset.stock);

            document.getElementById('selectedSize').value = size;
            document.getElementById('sizeDisplay').textContent = size + " (Còn " + maxStock + " sp)";
            
            const qtyInput = document.getElementById('buyQty');
            if (parseInt(qtyInput.value) > maxStock) {
                qtyInput.value = maxStock;
            }
            updateButtons();
        });
    });

    document.getElementById('btnAddCart').addEventListener('click', async () => {
        const size = document.getElementById('selectedSize').value;
        if (!size) { showToast("Vui lòng chọn kích cỡ!", "error"); return; }
        if (!isLoggedIn) { showToast("Vui lòng đăng nhập để mua hàng!", "error"); return; }

        const form = document.getElementById('cartForm');
        try {
            const response = await fetch(form.action, { method: 'POST', body: new FormData(form) });
            if (response.ok) {
                showToast("Đã thêm vào giỏ hàng thành công!", "success");
            } else {
                showToast("Không thể thêm vào giỏ hàng!", "error");
            }
        } catch (error) { 
            showToast("Lỗi hệ thống, vui lòng thử lại!", "error"); 
        }
    });

    function showToast(msg, type) {
        const toast = document.getElementById('toast');
        toast.textContent = msg;
        toast.className = 'toast-msg show ' + type;
        setTimeout(() => { toast.className = 'toast-msg'; }, 3000);
    }

    // Khởi tạo trạng thái nút khi mới load trang
    updateButtons();
</script>