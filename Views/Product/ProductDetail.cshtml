@using ShopQuanAo.Models.BEAN.Entity
@model ShopQuanAo.Models.BEAN.Entity.Product
@{
    ViewData["Title"] = Model.ProductName;
    Layout = "~/Views/Shared/_Layout.cshtml";
    // Kiểm tra xem tổng kho có bằng 0 không
    bool isAllOutOfStock = Model.TotalQuantity <= 0;
}

@* Phông chữ và Icon *@
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Mono&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link href="~/css/Product/Product_Detail.css" asp-append-version="true" rel="stylesheet" />

<div class="toast-msg" id="toast"></div>

<div class="product-card-container">
    <div class="detail-layout">
        <div class="detail-image">
            <img src="@Model.Image" alt="@Model.ProductName" />
        </div>

        <div class="detail-info">
            <div class="detail-eyebrow">MENSHOP EXCLUSIVE</div>
            <h1 class="detail-name">@Model.ProductName</h1>
            <h6 class="brand-title">Thương hiệu : <span>@Model.BrandName</span></h6>

            <div class="product-rating-summary" style="margin: 10px 0; color: #ffb400;">
                @{
                    var reviews = ViewBag.Reviews as List<ProductReview> ?? new List<ProductReview>();
                    double avgRating = reviews.Any() ? reviews.Average(r => r.Rating) : 0;
                    int reviewCount = reviews.Count();
                }
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="bi @(i <= avgRating ? "bi-star-fill" : (i - avgRating < 1 && i - avgRating > 0 ? "bi-star-half" : "bi-star"))"></i>
                }
                <span style="color: #666; font-size: 14px; margin-left: 8px;">(@reviewCount đánh giá)</span>
            </div> 

            @* PHẦN GIÁ CẢ ĐÃ ĐƯỢC TÍCH HỢP SALE GIÁ *@
            <div class="detail-price">
                @if (Model.SalePrice > 0)
                {
                    <span class="price-sale">@Model.SalePrice.ToString("N0")₫</span>
                    <span class="price-old">@Model.Price.ToString("N0")₫</span>
                    <span class="price-percent">-@((int)Math.Round((1 - (double)Model.SalePrice / Model.Price) * 100))%</span>
                }
                else
                {
                    <span>@Model.Price.ToString("N0")₫</span>
                }
            </div>

            @if (isAllOutOfStock)
            {
                <div class="alert alert-danger py-2" style="font-size: 0.9rem; font-weight: 600;">
                    <i class="bi bi-exclamation-triangle-fill"></i> SẢN PHẨM NÀY HIỆN ĐÃ HẾT HÀNG TRÊN TOÀN HỆ THỐNG
                </div>
            }

            <div class="promo-container">
                <div class="promo-header"><i class="bi bi-gift-fill"></i> KHUYẾN MÃI - ONLY ONLINE</div>
                <ul class="promo-list">
                    <li class="promo-item" onclick="copyCode('APR20')">🎫 Nhập mã <b>APR20</b> GIẢM 20K đơn từ 499K</li>
                    <li class="promo-item" onclick="copyCode('APR150')">🎫 Nhập mã <b>APR150</b> GIẢM 150K đơn từ 1599K</li>
                    <li class="promo-item promo-freeship">🚚 <b>FREESHIP</b> đơn từ 399K</li>
                </ul>
            </div>

            <div class="option-row">
                <span class="option-label">KÍCH CỠ: <b id="sizeDisplay">Chưa chọn</b></span>
                <div class="size-list">
                    @if (ViewBag.AvailableSizes != null)
                    {
                        foreach (dynamic sizeItem in ViewBag.AvailableSizes)
                        {
                            bool isOutOfStock = sizeItem.Quantity <= 0;
                            <button type="button" 
                                    class="size-btn @(isOutOfStock ? "disabled" : "")" 
                                    data-size="@sizeItem.SizeName" 
                                    data-stock="@sizeItem.Quantity"
                                    @(isOutOfStock ? "disabled" : "")>
                                @sizeItem.SizeName
                            </button>
                        }
                    }
                </div>
            </div>

            <form id="cartForm" method="post" asp-controller="Cart" asp-action="AddToCart">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.Id" />
                <input type="hidden" name="size" id="selectedSize" value="" />
                
                <div class="purchase-actions">
                    <div class="quantity-picker">
                        <button type="button" id="btnMinus" onclick="changeQty(-1)">-</button>
                        <input type="number" name="quantity" id="buyQty" value="1" min="1" readonly />
                        <button type="button" id="btnPlus" onclick="changeQty(1)">+</button>
                    </div>
                    <button type="button" class="btn-add-cart" id="btnAddCart" @(isAllOutOfStock ? "disabled" : "")>
                        @(isAllOutOfStock ? "HẾT HÀNG" : "THÊM VÀO GIỎ")
                    </button>
                </div>
            </form>
            
            <button class="btn-wishlist w-100 mt-3 border py-2 bg-white rounded"><i class="bi bi-heart"></i> YÊU THÍCH</button>
        </div>
    </div>

    @* PHẦN ĐÁNH GIÁ *@
    <div class="product-reviews-section">
        <h3 class="reviews-title">Đánh giá sản phẩm</h3>
        @{
            Func<int, double> getPercent = (s) => reviewCount == 0 ? 0 : (reviews.Count(r => r.Rating == s) / (double)reviewCount) * 100;
        }

        <div class="rating-overview">
            <div class="rating-score">
                <h2>@avgRating.ToString("0.0")</h2>
                <div class="stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi @(i <= avgRating ? "bi-star-fill" : (i - avgRating < 1 && i - avgRating > 0 ? "bi-star-half" : "bi-star"))"></i>
                    }
                </div>
                <div class="text-muted">@reviewCount nhận xét</div>
            </div>

            <div class="rating-bars">
                @for (int i = 5; i >= 1; i--)
                {
                    <div class="bar-item">
                        <span>@i sao</span>
                        <div class="progress">
                            <div class="progress-bar" style="width: @getPercent(i)%"></div>
                        </div>
                        <span style="min-width: 30px">@getPercent(i).ToString("0")%</span>
                    </div>
                }
            </div>
        </div>

        <div class="reviews-list">
            @if (!reviews.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-chat-left-text" style="font-size: 3rem; color: #eee;"></i>
                    <p class="mt-3 text-muted">Chưa có đánh giá nào cho sản phẩm này.</p>
                </div>
            }
            else
            {
                foreach (var r in reviews)
                {
                    <div class="review-item">
                        <div class="review-avatar">
                            @(string.IsNullOrEmpty(r.FullName) ? "U" : r.FullName.Substring(0, 1).ToUpper())
                        </div>
                        <div class="review-content">
                            <div class="review-author">
                                @r.FullName <span class="review-time">@r.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="review-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= r.Rating ? "bi-star-fill" : "bi-star")"></i>
                                }
                            </div>
                            <div class="review-text">@r.Comment</div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<script>
    const isLoggedIn = @Json.Serialize(User.Identity.IsAuthenticated);
    let maxStock = 999; 

    function updateButtons() {
        const currentQty = parseInt(document.getElementById('buyQty').value);
        document.getElementById('btnMinus').disabled = (currentQty <= 1);
        document.getElementById('btnPlus').disabled = (currentQty >= maxStock);
    }

    function changeQty(val) {
        if (!document.getElementById('selectedSize').value) {
            showToast("Vui lòng chọn kích cỡ trước!", "error"); return;
        }
        const input = document.getElementById('buyQty');
        let newVal = parseInt(input.value) + val;
        if (newVal >= 1 && newVal <= maxStock) {
            input.value = newVal;
        }
        updateButtons();
    }

    document.querySelectorAll('.size-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            maxStock = parseInt(btn.dataset.stock);
            document.getElementById('selectedSize').value = btn.dataset.size;
            document.getElementById('sizeDisplay').textContent = btn.dataset.size + " (Còn " + maxStock + " sp)";
            updateButtons();
        });
    });

    document.getElementById('btnAddCart').addEventListener('click', async () => {
        if (!document.getElementById('selectedSize').value) { showToast("Vui lòng chọn kích cỡ!", "error"); return; }
        if (!isLoggedIn) { showToast("Vui lòng đăng nhập!", "error"); return; }

        const form = document.getElementById('cartForm');
        try {
            const response = await fetch(form.action, { method: 'POST', body: new FormData(form) });
            if (response.ok) showToast("Đã thêm vào giỏ hàng!", "success");
            else showToast("Lỗi khi thêm vào giỏ!", "error");
        } catch (e) { showToast("Lỗi hệ thống!", "error"); }
    });

    function showToast(msg, type) {
        const t = document.getElementById('toast');
        t.textContent = msg; t.className = 'toast-msg ' + type;
        t.style.display = 'block';
        setTimeout(() => { t.style.display = 'none'; }, 3000);
    }

    function copyCode(code) {
        navigator.clipboard.writeText(code).then(() => showToast("Đã copy mã: " + code, "success"));
    }

    updateButtons();
</script>