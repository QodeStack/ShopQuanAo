@* @model ShopQuanAo.Models.ViewModels.ProductVM

<div class="container py-5">
    <div class="card shadow-sm border-dark rounded-0">
        <div class="card-header bg-dark text-white rounded-0 py-3">
            <h4 class="text-uppercase mb-0 fw-bold" style="letter-spacing: 2px;">Thêm Sản Phẩm Mới</h4>
        </div>
        <div class="card-body p-4 p-md-5">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-7 border-end">
                        <div class="mb-4">
                            <label class="form-label fw-bold text-uppercase small">Tên sản phẩm *</label>
                            <input asp-for="Product.Name" class="form-control rounded-0 border-dark" placeholder="VD: Áo Sơ Mi Oxford" />
                            <span asp-validation-for="Product.Name" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold text-uppercase small">Giá bán (VNĐ) *</label>
                                <input asp-for="Product.Price" type="number" class="form-control rounded-0 border-dark" />
                            </div>
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold text-uppercase small">Danh mục *</label>
                                <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList" class="form-select rounded-0 border-dark">
                                    <option disabled selected>-- Chọn loại sản phẩm --</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-uppercase small">Mô tả sản phẩm</label>
                            <textarea asp-for="Product.Description" class="form-control rounded-0 border-dark" rows="6" placeholder="Mô tả chất liệu, kiểu dáng..."></textarea>
                        </div>
                    </div>

                    <div class="col-md-5 ps-md-4">
                        <div class="mb-4">
                            <label class="form-label fw-bold text-uppercase small">Hình ảnh đại diện *</label>
                            <input type="file" name="file" class="form-control rounded-0 border-dark" id="uploadBox" onchange="previewImage(event)" />
                            <div class="mt-3 border text-center py-5" id="imagePreviewContainer" style="background-color: #f8f9fa;">
                                <img id="output" style="max-width: 100%; display: none;" />
                                <p id="previewText" class="text-muted small mb-0">Xem trước hình ảnh tại đây</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-end mt-4 pt-3 border-top">
                    <a asp-action="Index" class="btn btn-outline-dark rounded-0 px-4 text-uppercase fw-bold me-2">Quay lại</a>
                    <button type="submit" class="btn btn-dark rounded-0 px-5 text-uppercase fw-bold">Xác nhận thêm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hàm để hiển thị ảnh ngay lập tức khi Admin chọn file
        var previewImage = function(event) {
            var reader = new FileReader();
            reader.onload = function(){
                var output = document.getElementById('output');
                var text = document.getElementById('previewText');
                output.src = reader.result;
                output.style.display = 'block';
                text.style.display = 'none';
            };
            reader.readAsDataURL(event.target.files[0]);
        };
    </script>
} *@