@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    // Kiểm tra trang hiện tại để active menu
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link href="~/css/Admin_Index.css" asp-append-version="true" rel="stylesheet" />

<div class="admin-wrap">
    <div class="admin-body">
        <aside class="admin-sidebar">
            <div class="sidebar-section">
                <div class="sidebar-label">Tổng quan</div>
                <a class="sidebar-link @(currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "Admin")">
                    <span class="sidebar-icon">▣</span> Dashboard
                </a>
                <a class="sidebar-link" href="#">
                    <span class="sidebar-icon">◈</span> Doanh thu
                </a>
                <a class="sidebar-link" href="#">
                    <span class="sidebar-icon">◎</span> Đơn hàng
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Quản lý</div>
                <a class="sidebar-link @(currentAction == "Users" ? "active" : "")" href="@Url.Action("Users", "Admin")">
                    <span class="sidebar-icon">◉</span> Người dùng
                </a>
                <a class="sidebar-link @(currentAction == "Products" ? "active" : "")" href="@Url.Action("Products", "Admin")">
                    <span class="sidebar-icon">◫</span> Sản phẩm
                </a>
                <a class="sidebar-link @(currentAction == "Categories" ? "active" : "")" href="@Url.Action("Categories", "Admin")">
                    <span class="sidebar-icon">◧</span> Danh mục
                </a>
                <a class="sidebar-link @(currentAction == "Contacts" ? "active" : "")" href="@Url.Action("Contacts", "Admin")">
                    <span class="sidebar-icon">✉</span> Phản hồi khách
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Hệ thống</div>
                <a class="sidebar-link" href="@Url.Action("Index", "Home")">
                    <span class="sidebar-icon">↗</span> Về cửa hàng
                </a>
                <a class="sidebar-link" href="/Identity/Account/Manage">
                    <span class="sidebar-icon">◑</span> Tài khoản
                </a>
            </div>
        </aside>

        <main class="admin-content">
            <div class="page-title-row">
                <div>
                    <div class="page-eyebrow">Tổng quan</div>
                    <div class="page-title">Dashboard</div>
                </div>
                <div class="date-badge" id="currentDate"></div>
            </div>

            <div class="stats-grid">
                <div class="stat-card green">
                    <div class="stat-label">Doanh thu tháng</div>
                    <div class="stat-value accent" id="statRevenue">—</div>
                    <div class="stat-change up">↑ Hoạt động thực tế</div>
                </div>
                <div class="stat-card blue">
                    <div class="stat-label">Đơn hàng tháng</div>
                    <div class="stat-value" id="statOrders">—</div>
                    <div class="stat-change up">↑ Cập nhật liên tục</div>
                </div>
                <div class="stat-card white">
                    <div class="stat-label">Người dùng</div>
                    <div class="stat-value" id="statUsers">—</div>
                    <div class="stat-change">Tổng tài khoản</div>
                </div>
                <div class="stat-card red">
                    <div class="stat-label">Sản phẩm</div>
                    <div class="stat-value" id="statProducts">—</div>
                    <div class="stat-change">Đang bán trên MenShop</div>
                </div>
            </div>

            <div class="charts-row">
                <div class="panel">
                    <div class="panel-header">
                        <div class="panel-title">Doanh thu 6 tháng gần nhất</div>
                        <div class="panel-badge">Đơn vị: Triệu VND</div>
                    </div>
                    <div class="chart-bars" id="revenueChart">
                        @* Chart sẽ được load bằng Javascript bên dưới *@
                    </div>
                </div>

                <div class="panel">
                    <div class="panel-header">
                        <div class="panel-title">Phân bổ danh mục</div>
                    </div>
                    <div class="donut-wrap">
                        <div class="donut-svg-wrap">
                            <svg width="130" height="130" viewBox="0 0 130 130">
                                <circle cx="65" cy="65" r="50" fill="none" stroke="#1a1a1a" stroke-width="22" />
                                <circle cx="65" cy="65" r="50" fill="none" stroke="#c8ff00" stroke-width="22" stroke-dasharray="119.4 195.8" stroke-dashoffset="0" transform="rotate(-90 65 65)" />
                                <text x="65" y="70" text-anchor="middle" fill="#f5f5f0" font-size="16" font-family="'Space Mono'" font-weight="700">LIVE</text>
                            </svg>
                        </div>
                        <div class="donut-legend">
                            <div class="legend-item">
                                <div class="legend-dot" style="background:#c8ff00"></div>
                                <div class="legend-label">Dữ liệu hệ thống</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel orders-panel">
                <div class="panel-header">
                    <div class="panel-title">Đơn hàng mới nhất</div>
                    <a href="@Url.Action("Orders", "Admin")" style="font-family:var(--mono);font-size:0.65rem;color:var(--accent);text-decoration:none;letter-spacing:0.1em;">TẤT CẢ ĐƠN HÀNG →</a>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Số lượng</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                        </tr>
                    </thead>
                    <tbody id="ordersTableBody">
                        @if (ViewBag.RecentOrders != null && ((IEnumerable<dynamic>)ViewBag.RecentOrders).Any())
                        {
                            foreach (var order in ViewBag.RecentOrders)
                            {
                                <tr>
                                    <td class="order-id">#@order.Id</td>
                                    <td>@order.Name</td>
                                    <td>@order.OrderDetails?.Count sp</td>
                                    <td class="amount-cell">
                                        @* Tính tổng tiền thực tế từ OrderDetails *@
                                        @{
                                            decimal total = 0;
                                            if (order.OrderDetails != null)
                                            {
                                                foreach (var d in order.OrderDetails) { total += d.Price * d.Quantity; }
                                            }
                                        }
                                        @total.ToString("N0")₫
                                    </td>
                                    <td>
                                        <span class="status-badge @(order.IsPaid ? "paid" : "pend")">
                                            @(order.IsPaid ? "✓ Đã thanh toán" : "⏳ Chờ TT")
                                        </span>
                                    </td>
                                    <td>@order.CreateTime.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">Chưa có dữ liệu đơn hàng mới.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>

<script>
    // 1. Hiển thị ngày tháng tiếng Việt
    document.getElementById('currentDate').textContent =
        new Date().toLocaleDateString('vi-VN', { weekday:'long', year:'numeric', month:'long', day:'numeric' });

    // 2. Gọi API lấy thông số thực tế từ Database
    async function loadStats() {
        try {
            const res = await fetch('/Admin/GetStats');
            if (!res.ok) throw new Error();
            const d = await res.json();
            
            // Format doanh thu sang dạng triệu (M)
            const revenueM = (d.revenue / 1000000).toFixed(1);
            
            document.getElementById('statRevenue').textContent  = revenueM + 'M₫';
            document.getElementById('statOrders').textContent   = d.orders;
            document.getElementById('statUsers').textContent    = d.users;
            document.getElementById('statProducts').textContent = d.products;
        } catch (err) {
            console.error("Lỗi lấy stats:", err);
            document.getElementById('statRevenue').textContent  = '0.0M₫';
            document.getElementById('statOrders').textContent   = '0';
        }
    }
    loadStats();

    // 3. Biểu đồ doanh thu (Dữ liệu mẫu - Quốc có thể viết thêm API để truyền dữ liệu thật vào đây)
    const months = ['T11','T12','T1','T2','T3','T4'];
    const values = [42, 58, 35, 71, 63, 89]; // Đơn vị: Triệu
    const max = Math.max(...values);
    const chart = document.getElementById('revenueChart');
    
    chart.innerHTML = months.map((m,i) => {
        const h = Math.round((values[i] / max) * 130);
        const isCurrent = i === months.length - 1;
        return `
        <div class="chart-bar-wrap">
            <div class="chart-bar ${isCurrent ? 'main' : 'faded'}" style="height:${h}px">
                <div class="chart-value-tip">${values[i]}M</div>
            </div>
            <div class="chart-label">${m}</div>
        </div>`;
    }).join('');
</script>