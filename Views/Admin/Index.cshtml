@using Microsoft.AspNetCore.Identity
@using ShopQuanAo.Models.Entity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">

<style>
    :root {
        --admin-bg: #f8f9fa;
        --sidebar-bg: #ffffff;
        --text-main: #1a1a1a;
        --text-muted: #6c757d;
        --accent: #000000;
        --card-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

    body { font-family: 'DM Sans', sans-serif !important; background-color: var(--admin-bg); }

    .admin-wrap { display: flex; min-height: 100vh; padding-top: 20px; }
    .admin-body { display: grid; grid-template-columns: 260px 1fr; width: 100%; gap: 30px; padding: 0 30px; }

    /* --- SIDEBAR HIỆN ĐẠI --- */
    .admin-sidebar { background: var(--sidebar-bg); border-radius: 16px; padding: 25px; box-shadow: var(--card-shadow); height: fit-content; }
    .sidebar-section { margin-bottom: 30px; }
    .sidebar-label { font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--text-muted); letter-spacing: 1px; margin-bottom: 15px; }
    .sidebar-link { display: flex; align-items: center; padding: 10px 15px; color: var(--text-main); text-decoration: none; border-radius: 8px; font-size: 14px; margin-bottom: 5px; transition: 0.3s; }
    .sidebar-link:hover { background: #f0f0f0; }
    .sidebar-link.active { background: var(--accent); color: #fff; font-weight: 500; }
    .sidebar-icon { margin-right: 12px; font-size: 18px; width: 20px; text-align: center; }

    /* --- NỘI DUNG CHÍNH --- */
    .page-title-row { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; }
    .page-eyebrow { font-size: 13px; color: var(--text-muted); font-weight: 500; }
    .page-title { font-size: 28px; font-weight: 700; color: var(--text-main); }
    .date-badge { font-size: 13px; color: var(--text-muted); background: #fff; padding: 8px 15px; border-radius: 50px; box-shadow: var(--card-shadow); }

    /* --- STATS CARDS --- */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px; }
    .stat-card { background: #fff; padding: 25px; border-radius: 16px; box-shadow: var(--card-shadow); border: 1px solid rgba(0,0,0,0.02); }
    .stat-label { font-size: 13px; color: var(--text-muted); margin-bottom: 10px; font-weight: 500; }
    .stat-value { font-size: 24px; font-weight: 700; color: var(--text-main); margin-bottom: 5px; }
    .stat-change { font-size: 11px; font-weight: 500; padding: 4px 8px; border-radius: 4px; display: inline-block; }
    .stat-card.green .stat-value { color: #28a745; } /* Doanh thu */
    .stat-card.blue .stat-value { color: #007bff; }
    .stat-card.red .stat-value { color: #dc3545; }

    /* --- PANELS & CHARTS --- */
    .charts-row { display: grid; grid-template-columns: 2fr 1fr; gap: 25px; margin-bottom: 30px; }
    .panel { background: #fff; padding: 25px; border-radius: 16px; box-shadow: var(--card-shadow); }
    .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
    .panel-title { font-size: 16px; font-weight: 700; }
    
    /* Chart cột tinh tế hơn */
    .chart-bars { display: flex; align-items: flex-end; justify-content: space-between; height: 180px; padding-top: 20px; }
    .chart-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; }
    .chart-bar { width: 35px; background: #e9ecef; border-radius: 6px 6px 0 0; position: relative; transition: 0.5s; }
    .chart-bar.main { background: var(--accent); }
    .chart-label { margin-top: 12px; font-size: 12px; color: var(--text-muted); font-weight: 500; }

    /* --- TABLE --- */
    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th { text-align: left; padding: 15px; font-size: 12px; text-transform: uppercase; color: var(--text-muted); border-bottom: 1px solid #eee; }
    .data-table td { padding: 15px; font-size: 14px; border-bottom: 1px solid #f8f9fa; }
    .status-badge { padding: 5px 12px; border-radius: 50px; font-size: 11px; font-weight: 700; }
    .status-badge.paid { background: #e8f5e9; color: #2e7d32; }
    .status-badge.pend { background: #fff3e0; color: #ef6c00; }
</style>

<div class="admin-wrap">
    <div class="admin-body">
        <aside class="admin-sidebar">
            <div class="sidebar-section">
                <div class="sidebar-label">Tổng quan</div>
                <a class="sidebar-link @(currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "Admin")">
                    <span class="sidebar-icon">📊</span> Dashboard
                </a>
                <a class="sidebar-link @(currentAction == "Revenue" ? "active" : "")" href="@Url.Action("Revenue", "Admin")">
                    <span class="sidebar-icon">💰</span> Doanh thu
                </a>
                <a class="sidebar-link @(currentAction == "Orders" ? "active" : "")" href="@Url.Action("Orders", "Admin")">
                    <span class="sidebar-icon">📦</span> Đơn hàng
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Quản lý</div>
                <a class="sidebar-link @(currentAction == "Users" ? "active" : "")" href="@Url.Action("Users", "Admin")">
                    <span class="sidebar-icon">👥</span> Người dùng
                </a>
                <a class="sidebar-link @(currentAction == "Products" ? "active" : "")" href="@Url.Action("Products", "Admin")">
                    <span class="sidebar-icon">👕</span> Sản phẩm
                </a>
                <a class="sidebar-link @(currentAction == "Categories" ? "active" : "")" href="@Url.Action("Categories", "Admin")">
                    <span class="sidebar-icon">📁</span> Danh mục
                </a>
                <a class="sidebar-link @(currentAction == "Contacts" ? "active" : "")" href="@Url.Action("Contacts", "Admin")">
                    <span class="sidebar-icon">📩</span> Phản hồi
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Hệ thống</div>
                <a class="sidebar-link" href="@Url.Action("Index", "Home")">
                    <span class="sidebar-icon">🏠</span> Về cửa hàng
                </a>
                <a class="sidebar-link" href="/Identity/Account/Manage">
                    <span class="sidebar-icon">⚙️</span> Tài khoản
                </a>
            </div>
        </aside>

        <main class="admin-content">
            <div class="page-title-row">
                <div>
                    <div class="page-eyebrow">Hệ thống quản trị MENSHOP</div>
                    <div class="page-title">Bảng điều khiển</div>
                </div>
                <div class="date-badge" id="currentDate"></div>
            </div>

            <div class="stats-grid">
                <div class="stat-card green">
                    <div class="stat-label">Doanh thu tháng</div>
                    <div class="stat-value" id="statRevenue">—</div>
                    <div class="stat-change" style="background:#e8f5e9;color:#2e7d32">Hoạt động thực tế</div>
                </div>
                <div class="stat-card blue">
                    <div class="stat-label">Đơn hàng tháng</div>
                    <div class="stat-value" id="statOrders">—</div>
                    <div class="stat-change" style="background:#e3f2fd;color:#1565c0">Cập nhật liên tục</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Người dùng</div>
                    <div class="stat-value" id="statUsers">—</div>
                    <div class="stat-change" style="background:#f5f5f5;color:#616161">Tổng tài khoản</div>
                </div>
                <div class="stat-card red">
                    <div class="stat-label">Sản phẩm</div>
                    <div class="stat-value" id="statProducts">—</div>
                    <div class="stat-change" style="background:#ffebee;color:#c62828">Đang kinh doanh</div>
                </div>
            </div>

            <div class="charts-row">
                <div class="panel">
                    <div class="panel-header">
                        <div class="panel-title">Biểu đồ doanh thu 6 tháng gần nhất</div>
                        <div style="font-size:12px; color:var(--text-muted)">Đơn vị: Triệu VND</div>
                    </div>
                    <div class="chart-bars" id="revenueChart"></div>
                </div>

                <div class="panel">
                    <div class="panel-header">
                        <div class="panel-title">Tỷ trọng hệ thống</div>
                    </div>
                    <div style="text-align:center; padding: 20px 0;">
                        <div style="width: 120px; height: 120px; border-radius: 50%; border: 12px solid #000; border-top-color: #eee; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
                            <strong style="font-size: 18px;">LIVE</strong>
                        </div>
                        <div style="font-size: 13px; color: var(--text-muted);">Dữ liệu thời gian thực</div>
                    </div>
                </div>
            </div>

            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title">Đơn hàng mới nhất</div>
                    <a href="@Url.Action("Orders", "Admin")" style="font-size:13px; color:var(--text-main); font-weight:700; text-decoration:none;">Xem tất cả →</a>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Số lượng</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                        </tr>
                    </thead>
                    <tbody id="ordersTableBody">
                        @if (ViewBag.RecentOrders != null)
                        {
                            foreach (var order in (IEnumerable<ShopQuanAo.Models.Entity.Order>)ViewBag.RecentOrders)
                            {
                                <tr>
                                    <td style="font-weight:700">#@order.Id</td>
                                    <td>@order.Name</td>
                                    <td>@(order.OrderDetails?.Count ?? 0) sản phẩm</td>
                                    <td style="font-weight:700">
                                        @{
                                            double total = 0;
                                            if (order.OrderDetails != null)
                                            {
                                                foreach (var d in order.OrderDetails) { total += (d.UnitPrice * d.Quantity); }
                                            }
                                        }
                                        @total.ToString("N0")₫
                                    </td>
                                    <td>
                                        <span class="status-badge @(order.IsPaid ? "paid" : "pend")">
                                            @(order.IsPaid ? "Đã thanh toán" : "Chờ xử lý")
                                        </span>
                                    </td>
                                    <td>@order.CreateTime.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>

<script>
    document.getElementById('currentDate').textContent =
        new Date().toLocaleDateString('vi-VN', { weekday:'long', year:'numeric', month:'long', day:'numeric' });

    async function loadStats() {
        try {
            const res = await fetch('/Admin/GetStats');
            if (!res.ok) throw new Error();
            const d = await res.json();
            const revenueM = (d.revenue / 1000000).toFixed(1);
            
            document.getElementById('statRevenue').textContent  = revenueM + 'M₫';
            document.getElementById('statOrders').textContent   = d.orders;
            document.getElementById('statUsers').textContent    = d.users;
            document.getElementById('statProducts').textContent = d.products;
        } catch (err) {
            document.getElementById('statRevenue').textContent  = '0.0M₫';
            document.getElementById('statOrders').textContent   = '0';
        }
    }
    loadStats();

    const months = ['T11','T12','T1','T2','T3','T4'];
    const values = [42, 58, 35, 71, 63, 89]; 
    const max = Math.max(...values);
    const chart = document.getElementById('revenueChart');
    
    chart.innerHTML = months.map((m,i) => {
        const h = Math.round((values[i] / max) * 150);
        const isCurrent = i === months.length - 1;
        return `
        <div class="chart-bar-wrap">
            <div class="chart-bar ${isCurrent ? 'main' : ''}" style="height:${h}px"></div>
            <div class="chart-label">${m}</div>
        </div>`;
    }).join('');
</script>