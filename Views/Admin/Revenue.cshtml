@* Lưu ý: Không có dòng @page ở đây *@
@{
    ViewData["Title"] = "Báo cáo doanh thu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono&family=Syne:wght@700&display=swap" rel="stylesheet">

<div class="admin-wrap" style="background: #0a0a0a; min-height: 100vh; padding: 30px; color: #f5f5f0;">
    <div class="page-header" style="margin-bottom: 30px; display: flex; justify-content: space-between; align-items: flex-end;">
        <div>
            <h1 style="font-family: 'Syne'; font-size: 2.5rem; text-transform: uppercase; margin: 0;">Doanh thu hệ thống</h1>
            <p style="color: #6e6e68; font-family: 'Space Mono'; margin: 5px 0 0 0;">
                Báo cáo từ: <span id="displayDateRange" style="color: #c8ff00;">--</span>
            </p>
        </div>
    </div>

    <div class="filter-bar" style="background: #141414; border: 1px solid #222; padding: 20px; margin-bottom: 30px; display: flex; gap: 20px; align-items: flex-end; border-radius: 4px;">
        <div style="flex: 1;">
            <label style="display: block; font-family: 'Space Mono'; font-size: 0.7rem; color: #6e6e68; text-transform: uppercase; margin-bottom: 8px;">Từ ngày</label>
            <input type="date" id="startDate" style="width: 100%; background: #0a0a0a; border: 1px solid #333; color: #fff; padding: 8px; font-family: 'Space Mono';">
        </div>
        <div style="flex: 1;">
            <label style="display: block; font-family: 'Space Mono'; font-size: 0.7rem; color: #6e6e68; text-transform: uppercase; margin-bottom: 8px;">Đến ngày</label>
            <input type="date" id="endDate" style="width: 100%; background: #0a0a0a; border: 1px solid #333; color: #fff; padding: 8px; font-family: 'Space Mono';">
        </div>
        <div style="flex: 0.8; display: flex; gap: 10px;">
            <button onclick="loadData()" style="flex: 3; background: #c8ff00; color: #000; border: none; padding: 9px; font-family: 'Syne'; font-weight: bold; cursor: pointer; text-transform: uppercase;">
                Lọc dữ liệu
            </button>
            <button onclick="resetFilter()" title="Làm mới" style="flex: 1; background: #222; color: #fff; border: 1px solid #333; padding: 9px; cursor: pointer; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-arrow-clockwise" style="font-size: 1.2rem;"></i>
            </button>
        </div>
    </div>

    <div class="metrics-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 30px;">
        <div class="metric-card" style="background: #141414; border: 1px solid #222; padding: 25px; border-left: 4px solid #c8ff00;">
            <div style="color: #6e6e68; font-size: 0.7rem; text-transform: uppercase; font-family: 'Space Mono';">Tổng doanh thu</div>
            <div id="metric-revenue" style="color: #c8ff00; font-size: 2rem; font-family: 'Space Mono'; font-weight: bold; margin-top: 10px;">0đ</div>
        </div>
        <div class="metric-card" style="background: #141414; border: 1px solid #222; padding: 25px; border-left: 4px solid #3b82ff;">
            <div style="color: #6e6e68; font-size: 0.7rem; text-transform: uppercase; font-family: 'Space Mono';">Đơn hàng mới</div>
            <div id="metric-orders" style="color: #fff; font-size: 2rem; font-family: 'Space Mono'; margin-top: 10px;">0</div>
        </div>
        <div class="metric-card" style="background: #141414; border: 1px solid #222; padding: 25px; border-left: 4px solid #ff3b3b;">
            <div style="color: #6e6e68; font-size: 0.7rem; text-transform: uppercase; font-family: 'Space Mono';">Sản phẩm đã bán</div>
            <div id="metric-items" style="color: #fff; font-size: 2rem; font-family: 'Space Mono'; margin-top: 10px;">0</div>
        </div>
        <div class="metric-card" style="background: #141414; border: 1px solid #222; padding: 25px; border-left: 4px solid #ffffff;">
            <div style="color: #6e6e68; font-size: 0.7rem; text-transform: uppercase; font-family: 'Space Mono';">Khách hàng</div>
            <div id="metric-users" style="color: #fff; font-size: 2rem; font-family: 'Space Mono'; margin-top: 10px;">0</div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div style="background: #141414; border: 1px solid #222; padding: 20px; min-height: 400px;">
            <h3 style="font-family: 'Syne'; font-size: 1.2rem; color: #fff; text-transform: uppercase;">Phân bổ doanh thu theo danh mục</h3>
            <div style="height: 350px; display: flex; align-items: center; justify-content: center; color: #6e6e68;">
                <canvas id="categoryChart"></canvas>
            </div>
        </div>
        <div style="background: #141414; border: 1px solid #222; padding: 20px;">
            <h3 style="font-family: 'Syne'; font-size: 1.2rem; color: #fff; text-transform: uppercase;">Top 5 Bán chạy</h3>
            <div id="topProductsList" style="margin-top: 15px;">
            </div>
        </div>
    </div>

    <div style="background: #141414; border: 1px solid #222; padding: 20px; margin-bottom: 30px;">
        <h3 style="font-family: 'Syne'; font-size: 1.2rem; color: #fff; text-transform: uppercase;">Diễn biến doanh thu theo thời gian</h3>
        <div style="height: 300px; width: 100%; margin-top: 20px;">
            <canvas id="lineChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let myChart = null;
        let myLineChart = null;

        $(document).ready(function() {
        loadData();
        });

        // Hàm Reset dữ liệu về mặc định
        function resetFilter() {
        $('#startDate').val('');
        $('#endDate').val('');
        loadData();
        }

        function loadData() {
        const start = $('#startDate').val();
        const end = $('#endDate').val();

        $.get(`/Admin/GetRevenueData?startDate=${start}&endDate=${end}`, function(res) {
        $('#displayDateRange').text(`${res.period.start} - ${res.period.end}`);
        const formatter = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' });

        // Update Metrics
        $('#metric-revenue').animate({ counter: res.metrics.totalRevenue }, {
        duration: 1000,
        step: function (now) { $(this).text(formatter.format(now)); }
        });
        $('#metric-orders').text(res.metrics.totalOrders);
        $('#metric-items').text(res.metrics.totalItemsSold);
        $('#metric-users').text(res.metrics.totalUsers);

        // Update Top Products
        let topHtml = '';
        res.topProducts.forEach(p => {
        topHtml += `
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 15px; padding-bottom: 10px; border-bottom: 1px solid #222;">
        <img src="${p.image}" style="width: 45px; height: 45px; object-fit: cover; border: 1px solid #333;">
        <div style="flex: 1;">
        <div style="font-size: 0.85rem; color: #fff; font-weight: bold;">${p.productName}</div>
        <div style="font-size: 0.7rem; color: #6e6e68;">Đã bán: ${p.soldCount}</div>
        </div>
        <div style="color: #c8ff00; font-family: 'Space Mono'; font-size: 0.8rem;">${formatter.format(p.revenue)}</div>
        </div>`;
        });
        $('#topProductsList').html(topHtml || '<p style="color:#6e6e68;">Không có dữ liệu</p>');

        // 1. Biểu đồ tròn
        const ctx = document.getElementById('categoryChart').getContext('2d');
        if (myChart) { myChart.destroy(); }
        myChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
        labels: res.categoryData.map(c => c.name),
        datasets: [{
        data: res.categoryData.map(c => c.value),
        backgroundColor: ['#c8ff00', '#3b82ff', '#ff3b3b', '#ffffff', '#6e6e68'],
        borderWidth: 0
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: { position: 'bottom', labels: { color: '#6e6e68', font: { family: 'Space Mono', size: 10 } } }
        }
        }
        });

        // 2. Biểu đồ đường
        const lineCtx = document.getElementById('lineChart').getContext('2d');
        if (myLineChart) { myLineChart.destroy(); }
        myLineChart = new Chart(lineCtx, {
        type: 'line',
        data: {
        labels: res.dailyData.map(d => d.date),
        datasets: [{
        label: 'Doanh thu ngày',
        data: res.dailyData.map(d => d.revenue),
        borderColor: '#c8ff00',
        backgroundColor: 'rgba(200, 255, 0, 0.1)',
        fill: true,
        tension: 0.4,
        borderWidth: 3,
        pointBackgroundColor: '#c8ff00'
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
        y: { grid: { color: '#222' }, ticks: { color: '#6e6e68', font: { family: 'Space Mono' } } },
        x: { grid: { color: '#222' }, ticks: { color: '#6e6e68', font: { family: 'Space Mono' } } }
        },
        plugins: { legend: { display: false } }
        }
        });
        });
        }
    </script>
}