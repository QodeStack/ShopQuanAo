@* Lưu ý: Không có dòng @page ở đây *@
@{
    ViewData["Title"] = "Báo cáo doanh thu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --admin-bg: #f8f9fa;
        --card-bg: #ffffff;
        --text-main: #1a1a1a;
        --text-muted: #6c757d;
        --accent: #000000;
        --success: #28a745;
        --primary: #007bff;
        --danger: #dc3545;
        --border: #edf2f7;
        --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    body { 
        font-family: 'DM Sans', sans-serif !important; 
        background-color: var(--admin-bg); 
        color: var(--text-main);
    }

    .admin-wrap { padding: 40px; max-width: 1400px; margin: 0 auto; }

    /* Header & Filters */
    .page-title { font-size: 28px; font-weight: 700; margin-bottom: 5px; }
    .page-subtitle { font-size: 14px; color: var(--text-muted); margin-bottom: 30px; }
    
    .filter-bar { 
        background: var(--card-bg); 
        padding: 20px; 
        border-radius: 16px; 
        box-shadow: var(--shadow);
        display: flex; 
        gap: 20px; 
        align-items: flex-end; 
        margin-bottom: 30px;
    }

    .filter-group { flex: 1; }
    .filter-group label { 
        display: block; 
        font-size: 12px; 
        font-weight: 700; 
        color: var(--text-muted); 
        text-transform: uppercase; 
        margin-bottom: 8px; 
    }
    .filter-input { 
        width: 100%; 
        padding: 10px 15px; 
        border: 1px solid var(--border); 
        border-radius: 8px; 
        font-family: inherit;
    }

    .btn-filter { 
        background: var(--accent); 
        color: #fff; 
        border: none; 
        padding: 11px 25px; 
        border-radius: 8px; 
        font-weight: 700; 
        cursor: pointer;
    }

    /* Metrics */
    .metrics-grid { 
        display: grid; 
        grid-template-columns: repeat(4, 1fr); 
        gap: 20px; 
        margin-bottom: 30px; 
    }
    .metric-card { 
        background: var(--card-bg); 
        padding: 25px; 
        border-radius: 16px; 
        box-shadow: var(--shadow);
        transition: transform 0.2s;
    }
    .metric-card:hover { transform: translateY(-5px); }
    .metric-label { font-size: 13px; font-weight: 500; color: var(--text-muted); }
    .metric-value { font-size: 24px; font-weight: 700; margin-top: 10px; }

    /* Charts & Top Products */
    .content-grid { display: grid; grid-template-columns: 1.8fr 1.2fr; gap: 25px; margin-bottom: 25px; }
    .panel { 
        background: var(--card-bg); 
        padding: 25px; 
        border-radius: 16px; 
        box-shadow: var(--shadow); 
    }
    .panel-title { font-size: 16px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }

    .top-product-item { 
        display: flex; 
        align-items: center; 
        gap: 15px; 
        padding: 12px 0; 
        border-bottom: 1px solid var(--border); 
    }
    .top-product-item:last-child { border: none; }
    .product-img { width: 48px; height: 48px; border-radius: 8px; object-fit: cover; }
    .product-info { flex: 1; }
    .product-name { font-size: 14px; font-weight: 700; }
    .product-sold { font-size: 12px; color: var(--text-muted); }
    .product-revenue { font-size: 14px; font-weight: 700; color: var(--success); }
</style>

<div class="admin-wrap">
    <div class="page-header">
        <h1 class="page-title">Báo cáo doanh thu</h1>
        <p class="page-subtitle">
            Dữ liệu hệ thống MENSHOP: <span id="displayDateRange" style="font-weight: 700; color: var(--accent);">--</span>
        </p>
    </div>

    <div class="filter-bar">
        <div class="filter-group">
            <label>Từ ngày</label>
            <input type="date" id="startDate" class="filter-input">
        </div>
        <div class="filter-group">
            <label>Đến ngày</label>
            <input type="date" id="endDate" class="filter-input">
        </div>
        <div style="display: flex; gap: 10px;">
            <button onclick="loadData()" class="btn-filter">Lọc dữ liệu</button>
            <button onclick="resetFilter()" class="btn-filter" style="background: #e2e8f0; color: #4a5568;" title="Làm mới">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </div>

    <div class="metrics-grid">
        <div class="metric-card" style="border-top: 4px solid var(--success);">
            <div class="metric-label">TỔNG DOANH THU</div>
            <div id="metric-revenue" class="metric-value" style="color: var(--success);">0đ</div>
        </div>
        <div class="metric-card" style="border-top: 4px solid var(--primary);">
            <div class="metric-label">ĐƠN HÀNG MỚI</div>
            <div id="metric-orders" class="metric-value">0</div>
        </div>
        <div class="metric-card" style="border-top: 4px solid var(--danger);">
            <div class="metric-label">SẢN PHẨM ĐÃ BÁN</div>
            <div id="metric-items" class="metric-value">0</div>
        </div>
        <div class="metric-card" style="border-top: 4px solid var(--accent);">
            <div class="metric-label">KHÁCH HÀNG</div>
            <div id="metric-users" class="metric-value">0</div>
        </div>
    </div>

    <div class="content-grid">
        <div class="panel">
            <h3 class="panel-title"><i class="bi bi-pie-chart"></i> Phân bổ doanh thu</h3>
            <div style="height: 320px;">
                <canvas id="categoryChart"></canvas>
            </div>
        </div>
        <div class="panel">
            <h3 class="panel-title"><i class="bi bi-trophy"></i> Top 5 Bán chạy</h3>
            <div id="topProductsList"></div>
        </div>
    </div>

    <div class="panel">
        <h3 class="panel-title"><i class="bi bi-graph-up-arrow"></i> Diễn biến doanh thu theo thời gian</h3>
        <div style="height: 350px; width: 100%;">
            <canvas id="lineChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let myChart = null;
        let myLineChart = null;

        $(document).ready(function() { loadData(); });

        function resetFilter() {
            $('#startDate').val('');
            $('#endDate').val('');
            loadData();
        }

        function loadData() {
            const start = $('#startDate').val();
            const end = $('#endDate').val();

            $.get(`/Admin/GetRevenueData?startDate=${start}&endDate=${end}`, function(res) {
                $('#displayDateRange').text(`${res.period.start} - ${res.period.end}`);
                const formatter = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' });

                // Update Metrics
                $('#metric-revenue').text(formatter.format(res.metrics.totalRevenue));
                $('#metric-orders').text(res.metrics.totalOrders);
                $('#metric-items').text(res.metrics.totalItemsSold);
                $('#metric-users').text(res.metrics.totalUsers);

                // Update Top Products
                let topHtml = '';
                res.topProducts.forEach(p => {
                    topHtml += `
                    <div class="top-product-item">
                        <img src="${p.image}" class="product-img">
                        <div class="product-info">
                            <div class="product-name">${p.productName}</div>
                            <div class="product-sold">Đã bán: ${p.soldCount}</div>
                        </div>
                        <div class="product-revenue">${formatter.format(p.revenue)}</div>
                    </div>`;
                });
                $('#topProductsList').html(topHtml || '<p style="color:#6e6e68;">Không có dữ liệu</p>');

                // Doughnut Chart tinh tế hơn
                const ctx = document.getElementById('categoryChart').getContext('2d');
                if (myChart) { myChart.destroy(); }
                myChart = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: res.categoryData.map(c => c.name),
                        datasets: [{
                            data: res.categoryData.map(c => c.value),
                            backgroundColor: ['#000000', '#4a5568', '#718096', '#a0aec0', '#cbd5e0'],
                            borderWidth: 2,
                            borderColor: '#ffffff'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'right', labels: { font: { family: 'DM Sans', size: 12 } } }
                        },
                        cutout: '70%'
                    }
                });

                // Line Chart hiện đại với Gradient
                const lineCtx = document.getElementById('lineChart').getContext('2d');
                const gradient = lineCtx.createLinearGradient(0, 0, 0, 400);
                gradient.addColorStop(0, 'rgba(0, 0, 0, 0.1)');
                gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');

                if (myLineChart) { myLineChart.destroy(); }
                myLineChart = new Chart(lineCtx, {
                    type: 'line',
                    data: {
                        labels: res.dailyData.map(d => d.date),
                        datasets: [{
                            label: 'Doanh thu',
                            data: res.dailyData.map(d => d.revenue),
                            borderColor: '#000000',
                            backgroundColor: gradient,
                            fill: true,
                            tension: 0.4,
                            pointRadius: 4,
                            pointBackgroundColor: '#fff',
                            pointBorderColor: '#000',
                            pointBorderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { grid: { borderDash: [5, 5] }, ticks: { font: { family: 'DM Sans' } } },
                            x: { grid: { display: false }, ticks: { font: { family: 'DM Sans' } } }
                        },
                        plugins: { legend: { display: false } }
                    }
                });
            });
        }
    </script>
}