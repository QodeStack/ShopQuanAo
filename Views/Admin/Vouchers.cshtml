@using Microsoft.AspNetCore.Identity
@using ShopQuanAo.Models.BEAN.Entity
@model List<Voucher>
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Quản lý Mã Giảm Giá";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<link href="~/css/Admin_Index.css" asp-append-version="true" rel="stylesheet" />

<div class="admin-wrap">
    <div class="admin-body">
        <aside class="admin-sidebar shadow-sm">
            <div class="sidebar-section">
                <div class="sidebar-label">Tổng quan</div>
                <a class="sidebar-link @(currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "Admin")">
                    <span class="sidebar-icon">▣</span> Dashboard
                </a>
                <a class="sidebar-link @(currentAction == "Revenue" ? "active" : "")" href="@Url.Action("Revenue", "Admin")">
                    <span class="sidebar-icon">◈</span> Doanh thu
                </a>
                <a class="sidebar-link @(currentAction == "Orders" ? "active" : "")" href="@Url.Action("Orders", "Admin")">
                    <span class="sidebar-icon">◎</span> Đơn hàng
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Quản lý</div>
                <a class="sidebar-link @(currentAction == "Users" ? "active" : "")" href="@Url.Action("Users", "Admin")">
                    <span class="sidebar-icon">◉</span> Người dùng
                </a>
                <a class="sidebar-link @(currentAction == "Products" ? "active" : "")" href="@Url.Action("Products", "Admin")">
                    <span class="sidebar-icon">◫</span> Sản phẩm
                </a>
                <a class="sidebar-link @(currentAction == "Categories" ? "active" : "")" href="@Url.Action("Categories", "Admin")">
                    <span class="sidebar-icon">◧</span> Danh mục
                </a>
                <a class="sidebar-link @(currentAction == "Sales" ? "active" : "")" href="@Url.Action("Sales", "Admin")">
                    <span class="sidebar-icon">★</span> Khuyến mãi (Sale)
                </a>
                <a class="sidebar-link @(currentAction == "Vouchers" ? "active" : "")" href="@Url.Action("Vouchers", "Admin")">
                    <span class="sidebar-icon">🎫</span> Mã giảm giá
                </a>
                <a class="sidebar-link @(currentAction == "Contacts" ? "active" : "")" href="@Url.Action("Contacts", "Admin")">
                    <span class="sidebar-icon">✉</span> Phản hồi khách
                </a>
            </div>
        </aside>

        <main class="admin-content" style="background-color: #f4f7f6; min-height: 100vh; padding: 30px;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="fw-bolder mb-1" style="color: #1a2b4c;">Quản lý Mã giảm giá</h4>
                    <p class="text-muted small mb-0">Thiết lập và theo dõi các chương trình voucher toàn hệ thống</p>
                </div>
                <button class="btn btn-primary btn-modern shadow-sm" data-bs-toggle="modal" data-bs-target="#addVoucherModal">
                    <i class="bi bi-plus-lg me-1"></i> Thêm mã mới
                </button>
            </div>

            <div class="card border-0 modern-card">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 custom-table">
                            <thead>
                                <tr>
                                    <th class="ps-4">Mã Code</th>
                                    <th>Mức giảm</th>
                                    <th>Đơn tối thiểu</th>
                                    <th>Loại mã</th>
                                    <th>Lượt dùng</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end pe-4">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="voucher-icon-wrap me-3">
                                                        <i class="bi bi-ticket-perforated"></i>
                                                    </div>
                                                    <span class="fw-bold" style="color: #1a2b4c; letter-spacing: 0.5px;">@item.Code</span>
                                                </div>
                                            </td>
                                            <td><span class="fw-bold text-danger">@item.DiscountAmount.ToString("N0")₫</span></td>
                                            <td class="text-muted">@item.MinOrderAmount.ToString("N0")₫</td>
                                            <td>
                                                @if (item.IsPublic)
                                                {
                                                    <span class="badge rounded-pill badge-soft-info px-3 py-2"><i class="bi bi-eye"></i> Công khai</span>
                                                }
                                                else
                                                {
                                                    <span class="badge rounded-pill bg-dark text-white px-3 py-2"><i class="bi bi-eye-slash"></i> Mã ẩn</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge rounded-pill @(item.Quantity > 0 ? "badge-soft-info" : "bg-light text-muted") px-3 py-2">
                                                    <i class="bi bi-people me-1"></i> @item.Quantity lượt
                                                </span>
                                            </td>
                                            <td>
                                                @if (item.IsActive)
                                                {
                                                    <span class="badge rounded-pill badge-soft-success px-3 py-2"><span class="dot-active"></span> Đang bật</span>
                                                }
                                                else
                                                {
                                                    <span class="badge rounded-pill badge-soft-danger px-3 py-2"><span class="dot-inactive"></span> Đã tắt</span>
                                                }
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="d-inline-flex gap-2">
                                                    <button type="button" class="btn btn-sm btn-action btn-outline-primary" 
                                                            onclick="openEditModal(@item.Id, '@item.Code', @item.DiscountAmount, @item.MinOrderAmount, @item.Quantity, @item.IsActive.ToString().ToLower(), @item.IsPublic.ToString().ToLower())"
                                                            title="Sửa mã">
                                                        <i class="bi bi-pencil-square"></i> Sửa
                                                    </button>

                                                    <form asp-action="ToggleVoucher" asp-controller="Admin" method="post" class="m-0">
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-sm btn-action @(item.IsActive ? "btn-outline-secondary" : "btn-outline-success")" title="@(item.IsActive ? "Tắt mã này" : "Bật mã này")">
                                                            <i class="bi @(item.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i> @(item.IsActive ? "Tắt" : "Bật")
                                                        </button>
                                                    </form>
                                                    
                                                    <form asp-action="DeleteVoucher" asp-controller="Admin" method="post" class="m-0" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn mã @item.Code này không?');">
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-sm btn-action btn-outline-danger" title="Xóa mã">
                                                            <i class="bi bi-trash3"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-5">
                                            <div class="empty-state">
                                                <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                                                <h6 class="mt-3 fw-bold text-dark">Chưa có mã giảm giá nào</h6>
                                                <p class="text-muted small">Hãy bấm "Thêm mã mới" để bắt đầu tạo chiến dịch khuyến mãi.</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<div class="modal fade" id="addVoucherModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 modern-card">
            <form asp-action="AddVoucher" asp-controller="Admin" method="post">
                <div class="modal-header border-bottom-0 pb-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold" style="color: #1a2b4c;">✨ Tạo Mã Giảm Giá Mới</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold text-uppercase">Mã Code nhập tay</label>
                        <input type="text" name="Code" class="form-control form-control-lg bg-light border-0 text-uppercase" required placeholder="VD: FREESHIP, SALE50K" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase">Mức giảm (VNĐ)</label>
                            <div class="input-group">
                                <input type="number" name="DiscountAmount" class="form-control bg-light border-0" required min="0" step="5000" placeholder="VD: 50000" />
                                <span class="input-group-text bg-light border-0 text-muted">₫</span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase">Đơn tối thiểu</label>
                            <div class="input-group">
                                <input type="number" name="MinOrderAmount" class="form-control bg-light border-0" required min="0" step="5000" placeholder="VD: 200000" />
                                <span class="input-group-text bg-light border-0 text-muted">₫</span>
                            </div>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase">Số lượt phát hành</label>
                        <input type="number" name="Quantity" class="form-control bg-light border-0" required min="1" value="100" />
                    </div>
                    <div class="form-check form-switch custom-switch p-3 bg-light rounded-3 d-flex align-items-center mb-2">
                        <input class="form-check-input me-3 ms-0 mt-0" type="checkbox" name="IsActive" value="true" checked style="width: 40px; height: 20px; cursor: pointer;">
                        <label class="form-check-label fw-bold mb-0" style="cursor: pointer; color: #1a2b4c;">Kích hoạt mã ngay lập tức</label>
                    </div>
                    <div class="form-check form-switch custom-switch p-3 bg-light rounded-3 d-flex align-items-center">
                        <input class="form-check-input me-3 ms-0 mt-0" type="checkbox" name="IsPublic" value="true" checked style="width: 40px; height: 20px; cursor: pointer;">
                        <label class="form-check-label fw-bold mb-0" style="cursor: pointer; color: #1a2b4c;">
                            Hiển thị công khai trên web <br>
                            <small class="text-muted fw-normal" style="font-size: 0.8rem;">Tắt đi để tạo "Mã ẩn" (Chỉ nhập tay).</small>
                        </label>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                    <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary btn-modern px-5 rounded-pill">Lưu mã</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editVoucherModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 modern-card">
            <form asp-action="EditVoucher" asp-controller="Admin" method="post">
                <input type="hidden" name="Id" id="editVoucherId" />
                
                <div class="modal-header border-bottom-0 pb-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold" style="color: #1a2b4c;"><i class="bi bi-pencil-square text-primary me-2"></i>Chỉnh sửa Mã Giảm Giá</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold text-uppercase">Mã Code nhập tay</label>
                        <input type="text" name="Code" id="editCode" class="form-control form-control-lg bg-light border-0 text-uppercase" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase">Mức giảm (VNĐ)</label>
                            <div class="input-group">
                                <input type="number" name="DiscountAmount" id="editDiscountAmount" class="form-control bg-light border-0" required min="0" step="5000" />
                                <span class="input-group-text bg-light border-0 text-muted">₫</span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase">Đơn tối thiểu</label>
                            <div class="input-group">
                                <input type="number" name="MinOrderAmount" id="editMinOrderAmount" class="form-control bg-light border-0" required min="0" step="5000" />
                                <span class="input-group-text bg-light border-0 text-muted">₫</span>
                            </div>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase">Số lượt phát hành</label>
                        <input type="number" name="Quantity" id="editQuantity" class="form-control bg-light border-0" required min="0" />
                    </div>
                    <div class="form-check form-switch custom-switch p-3 bg-light rounded-3 d-flex align-items-center mb-2">
                        <input class="form-check-input me-3 ms-0 mt-0" type="checkbox" name="IsActive" id="editIsActiveCheck" value="true" style="width: 40px; height: 20px; cursor: pointer;">
                        <label class="form-check-label fw-bold mb-0" for="editIsActiveCheck" style="cursor: pointer; color: #1a2b4c;">Kích hoạt mã ngay lập tức</label>
                    </div>
                    <div class="form-check form-switch custom-switch p-3 bg-light rounded-3 d-flex align-items-center">
                        <input class="form-check-input me-3 ms-0 mt-0" type="checkbox" name="IsPublic" id="editIsPublicCheck" value="true" style="width: 40px; height: 20px; cursor: pointer;">
                        <label class="form-check-label fw-bold mb-0" for="editIsPublicCheck" style="cursor: pointer; color: #1a2b4c;">
                            Hiển thị công khai trên web <br>
                            <small class="text-muted fw-normal" style="font-size: 0.8rem;">Tắt đi để tạo "Mã ẩn" (Chỉ nhập tay).</small>
                        </label>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                    <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-primary btn-modern px-5 rounded-pill">Lưu cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    
    <script>
        // Hàm đẩy dữ liệu từ dòng vừa click vào Modal Sửa
        function openEditModal(id, code, discount, minOrder, quantity, isActive, isPublic) {
            document.getElementById('editVoucherId').value = id;
            document.getElementById('editCode').value = code;
            document.getElementById('editDiscountAmount').value = discount;
            document.getElementById('editMinOrderAmount').value = minOrder;
            document.getElementById('editQuantity').value = quantity;
            document.getElementById('editIsActiveCheck').checked = isActive;
            document.getElementById('editIsPublicCheck').checked = isPublic;

            // Gọi Modal của Bootstrap 5 lên
            var editModal = new bootstrap.Modal(document.getElementById('editVoucherModal'));
            editModal.show();
        }
    </script>

    <style>
        .modern-card { background: #ffffff; border-radius: 16px; box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04); overflow: hidden; }
        .btn-modern { background-color: #0d6efd; border: none; border-radius: 8px; font-weight: 600; padding: 10px 20px; transition: all 0.3s ease; }
        .btn-modern:hover { background-color: #0b5ed7; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2); }
        
        /* Chỉnh lại nút bo góc như cũ bạn thích */
        .btn-action { border-radius: 8px; font-weight: 600; padding: 6px 16px; transition: 0.2s; }
        .btn-action:hover { opacity: 0.8; }
        
        .custom-table thead th { background-color: #ffffff; color: #8c98a4; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 2px solid #f8f9fa; padding: 16px 12px; }
        .custom-table tbody td { vertical-align: middle; border-bottom: 1px solid #f8f9fa; padding: 16px 12px; color: #495057; }
        .custom-table tbody tr:hover { background-color: #fcfcfc; }
        .voucher-icon-wrap { width: 40px; height: 40px; border-radius: 10px; background-color: #e2e8f0; color: #475569; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
        .badge-soft-success { background-color: #d1e7dd; color: #0f5132; border: 1px solid #badbcc; }
        .badge-soft-danger { background-color: #f8d7da; color: #842029; border: 1px solid #f5c2c7; }
        .badge-soft-info { background-color: #e0f2fe; color: #0369a1; border: 1px solid #bae6fd; }
        .dot-active, .dot-inactive { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 4px; }
        .dot-active { background-color: #198754; }
        .dot-inactive { background-color: #dc3545; }
        .form-control:focus { box-shadow: none; border: 1px solid #cbd5e1 !important; background-color: #ffffff !important; }
        .custom-switch .form-check-input:checked { background-color: #0d6efd; border-color: #0d6efd; }
    </style>
}