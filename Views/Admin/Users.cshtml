@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Quản lý Người dùng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link href="~/css/Admin_Users.css" asp-append-version="true" rel="stylesheet" />

@Html.AntiForgeryToken()

<div class="admin-wrap">
    <div class="admin-body">
        <aside class="admin-sidebar">
            <div class="sidebar-section">
                <div class="sidebar-label">Tổng quan</div>
                <a class="sidebar-link" href="@Url.Action("Index", "Admin")"><span class="sidebar-icon">▣</span> Dashboard</a>
                <a class="sidebar-link" href="#"><span class="sidebar-icon">◈</span> Doanh thu</a>
                <a class="sidebar-link" href="#"><span class="sidebar-icon">◎</span> Đơn hàng</a>
            </div>
            <div class="sidebar-section">
                <div class="sidebar-label">Quản lý</div>
                <a class="sidebar-link active" href="@Url.Action("Users", "Admin")"><span class="sidebar-icon">◉</span> Người dùng</a>
                <a class="sidebar-link" href="@Url.Action("Products", "Admin")"><span class="sidebar-icon">◫</span> Sản phẩm</a>
                <a class="sidebar-link" href="#"><span class="sidebar-icon">◧</span> Danh mục</a>
            </div>
            <div class="sidebar-section">
                <div class="sidebar-label">Hệ thống</div>
                <a class="sidebar-link" href="@Url.Action("Index", "Home")"><span class="sidebar-icon">↗</span> Về cửa hàng</a>
            </div>
        </aside>

        <main class="admin-content">
            <div class="page-title-row">
                <div>
                    <div class="page-eyebrow">Quản lý</div>
                    <div class="page-title">Người dùng</div>
                </div>
                <button class="btn-primary-admin" onclick="openCreateModal()">＋ Thêm người dùng</button>
            </div>

            <div class="toolbar">
                <div class="search-input-wrap">
                    <span class="search-icon">🔍</span>
                    <input type="text" id="userSearch" placeholder="Tìm theo email, tên..." oninput="filterUsers()">
                </div>
                <select class="filter-select" id="roleFilter" onchange="filterUsers()">
                    <option value="">Tất cả vai trò</option>
                    <option value="Admin">Admin</option>
                    <option value="User">User</option>
                </select>
                <select class="filter-select" id="confirmFilter" onchange="filterUsers()">
                    <option value="">Tất cả trạng thái</option>
                    <option value="confirmed">Đã xác nhận</option>
                    <option value="pending">Chưa xác nhận</option>
                </select>
            </div>

            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title">Danh sách người dùng</div>
                    <div class="panel-count" id="userCount">—</div>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th class="sortable">Người dùng ↕</th>
                            <th class="sortable">Vai trò</th>
                            <th>Email xác nhận</th>
                            <th>Đăng nhập 2FA</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                        <tr><td colspan="5" style="text-align:center;padding:3rem;color:var(--gray-500);font-family:var(--mono);font-size:0.75rem;">Đang tải dữ liệu...</td></tr>
                    </tbody>
                </table>
                <div class="pagination-row">
                    <div class="page-info" id="pageInfo">— kết quả</div>
                    <div class="page-btns" id="pageBtns"></div>
                </div>
            </div>
        </main>
    </div>
</div>

<div class="modal-overlay" id="userModal">
    <div class="modal-box">
        <div class="modal-title" id="modalTitle">TẠO NGƯỜI DÙNG MỚI</div>
        <form id="userForm" onsubmit="submitUserForm(event)">
            <input type="hidden" id="modalUserId" value="">
            <div class="form-group">
                <label class="form-label">Email *</label>
                <input class="form-control-admin" type="email" id="modalEmail" placeholder="user@example.com" required>
            </div>
            <div class="form-group" id="passwordGroup">
                <label class="form-label">Mật khẩu *</label>
                <input class="form-control-admin" type="password" id="modalPassword" placeholder="Tối thiểu 6 ký tự">
            </div>
            <div class="form-group">
                <label class="form-label">Vai trò</label>
                <select class="form-control-admin" id="modalRole">
                    <option value="User">User</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="closeModal('userModal')">Huỷ</button>
                <button type="submit" class="btn-submit-admin">Lưu</button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="deleteModal">
    <div class="modal-box" style="width:380px">
        <div class="modal-title">XÁC NHẬN XÓA</div>
        <p style="color:var(--gray-300);font-size:0.85rem;margin-bottom:0.5rem;">Bạn sắp xóa tài khoản:</p>
        <p id="deleteUserEmail" style="font-family:var(--mono);color:#ff3b3b;font-size:0.85rem;margin-bottom:1rem;"></p>
        <p style="color:var(--gray-500);font-size:0.78rem;">Hành động này không thể hoàn tác và sẽ dọn dẹp các dữ liệu liên quan.</p>
        <div class="modal-footer">
            <button type="button" class="btn-cancel" onclick="closeModal('deleteModal')">Huỷ</button>
            <button type="button" onclick="confirmDelete()" style="background:#ff3b3b;color:#fff;border:none;border-radius:3px;font-family:var(--mono);font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:0.65rem 1.4rem;cursor:pointer;">Xóa</button>
        </div>
    </div>
</div>

<div class="admin-toast" id="adminToast"></div>

<script>
    let allUsers = [];
    let filteredUsers = [];
    let currentPage = 1;
    const pageSize = 10;
    let deleteTargetId = '';
    const avatarColors = ['#c8ff00','#3b82ff','#ff3b3b','#ffb400','#8b5cf6','#06b6d4'];

    // Lấy Token Antiforgery chuẩn từ ASP.NET Core
    function getRequestToken() {
        return document.querySelector('input[name="__RequestVerificationToken"]').value;
    }

    async function loadUsers() {
        try {
            const res = await fetch('/Admin/GetUsers');
            if (!res.ok) throw new Error();
            allUsers = await res.json();
            filterUsers();
        } catch (err) {
            console.error("Lỗi tải người dùng:", err);
            showToast("✕ Không thể kết nối server", "error");
        }
    }

    function filterUsers() {
        const q = document.getElementById('userSearch').value.trim().toLowerCase();
        const role = document.getElementById('roleFilter').value;
        const conf = document.getElementById('confirmFilter').value;

        filteredUsers = allUsers.filter(u => {
            const matchQ = !q || u.email.toLowerCase().includes(q) || (u.userName && u.userName.toLowerCase().includes(q));
            const matchRole = !role || u.roles.includes(role);
            const matchConf = !conf || (conf === 'confirmed' ? u.emailConfirmed : !u.emailConfirmed);
            return matchQ && matchRole && matchConf;
        });

        currentPage = 1;
        renderTable();
    }

    function renderTable() {
        const start = (currentPage - 1) * pageSize;
        const page = filteredUsers.slice(start, start + pageSize);
        const body = document.getElementById('usersTableBody');
        const count = document.getElementById('userCount');

        count.textContent = filteredUsers.length + ' người dùng';

        if (page.length === 0) {
            body.innerHTML = `<tr><td colspan="5" style="text-align:center;padding:3rem;color:var(--gray-500);font-family:var(--mono);font-size:0.75rem;">Không tìm thấy kết quả</td></tr>`;
        } else {
            body.innerHTML = page.map((u, i) => {
                const color = avatarColors[(start + i) % avatarColors.length];
                const initials = u.email.charAt(0).toUpperCase();
                const isAdmin = u.roles.includes('Admin');
                return `
                <tr data-id="${u.id}">
                    <td>
                        <div class="user-cell">
                            <div class="user-ava" style="background:${color}">${initials}</div>
                            <div>
                                <div class="user-name">${u.userName || u.email.split('@@')[0]}</div>
                                <div class="user-email">${u.email}</div>
                            </div>
                        </div>
                    </td>
                    <td><span class="role-badge ${isAdmin ? 'admin' : 'user'}">${isAdmin ? '★ Admin' : '◉ User'}</span></td>
                    <td><span class="confirm-badge ${u.emailConfirmed ? 'yes' : 'no'}">${u.emailConfirmed ? '✓ Đã xác nhận' : '✕ Chưa XN'}</span></td>
                    <td style="font-family:var(--mono);font-size:0.72rem;color:${u.twoFactorEnabled ? '#c8ff00' : '#666'}">
                        ${u.twoFactorEnabled ? '✓ Bật' : '— Tắt'}
                    </td>
                    <td>
                        <div class="action-btns">
                            <button class="btn-icon" onclick="openEditModal('${u.id}','${u.email}','${u.roles[0]}')" title="Chỉnh sửa">✎</button>
                            <button class="btn-icon delete" onclick="openDeleteModal('${u.id}','${u.email}')" title="Xóa">✕</button>
                        </div>
                    </td>
                </tr>`;
            }).join('');
        }
        renderPagination();
    }

    // Các hàm Pagination giữ nguyên của bạn
    function renderPagination() {
        const total = Math.ceil(filteredUsers.length / pageSize);
        const info = document.getElementById('pageInfo');
        const btns = document.getElementById('pageBtns');
        const start = filteredUsers.length ? (currentPage - 1) * pageSize + 1 : 0;
        const end = Math.min(currentPage * pageSize, filteredUsers.length);
        info.textContent = filteredUsers.length ? `${start}–${end} / ${filteredUsers.length}` : '0 kết quả';

        let html = '';
        for (let i = 1; i <= total; i++) {
            html += `<button class="page-btn ${i === currentPage ? 'active' : ''}" onclick="goPage(${i})">${i}</button>`;
        }
        btns.innerHTML = html;
    }

    function goPage(p) { currentPage = p; renderTable(); }

    // --- MODAL LOGIC ---
    function openCreateModal() {
        document.getElementById('modalTitle').textContent = 'TẠO NGƯỜI DÙNG MỚI';
        document.getElementById('modalUserId').value = '';
        document.getElementById('modalEmail').value = '';
        document.getElementById('modalPassword').value = '';
        document.getElementById('modalRole').value = 'User';
        document.getElementById('passwordGroup').style.display = 'block';
        document.getElementById('userModal').classList.add('show');
    }

    function openEditModal(id, email, role) {
        document.getElementById('modalTitle').textContent = 'CHỈNH SỬA VAI TRÒ';
        document.getElementById('modalUserId').value = id;
        document.getElementById('modalEmail').value = email;
        document.getElementById('modalEmail').disabled = true; // Không cho sửa email khi edit
        document.getElementById('modalRole').value = role || 'User';
        document.getElementById('passwordGroup').style.display = 'none';
        document.getElementById('userModal').classList.add('show');
    }

    function openDeleteModal(id, email) {
        deleteTargetId = id;
        document.getElementById('deleteUserEmail').textContent = email;
        document.getElementById('deleteModal').classList.add('show');
    }

    function closeModal(id) {
        document.getElementById(id).classList.remove('show');
        document.getElementById('modalEmail').disabled = false;
    }

    // --- API SUBMIT ---
    async function submitUserForm(e) {
        e.preventDefault();
        const id = document.getElementById('modalUserId').value;
        const email = document.getElementById('modalEmail').value;
        const pass = document.getElementById('modalPassword').value;
        const role = document.getElementById('modalRole').value;

        const url = id ? '/Admin/EditUser' : '/Admin/CreateUser';
        const body = id ? { id, role } : { email, password: pass, role };

        try {
            const res = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getRequestToken()
                },
                body: JSON.stringify(body)
            });
            const d = await res.json();
            if (d.success) {
                showToast(id ? '✓ Cập nhật thành công' : '✓ Đã gửi mã OTP tới khách', 'success');
                closeModal('userModal');
                loadUsers();
            } else {
                showToast('✕ ' + (d.message || 'Lỗi xử lý'), 'error');
            }
        } catch { showToast('✕ Lỗi kết nối server', 'error'); }
    }

    async function confirmDelete() {
        try {
            const res = await fetch('/Admin/DeleteUser', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getRequestToken()
                },
                body: JSON.stringify({ id: deleteTargetId })
            });
            const d = await res.json();
            if (d.success) {
                showToast('✓ Đã xóa tài khoản', 'success');
                closeModal('deleteModal');
                loadUsers();
            } else {
                showToast('✕ ' + (d.message || 'Lỗi khi xóa'), 'error');
            }
        } catch { showToast('✕ Lỗi kết nối server', 'error'); }
    }

    function showToast(msg, type) {
        const t = document.getElementById('adminToast');
        t.textContent = msg;
        t.className = `admin-toast ${type} show`;
        setTimeout(() => t.classList.remove('show'), 3000);
    }

    // Load dữ liệu lần đầu
    loadUsers();
</script>