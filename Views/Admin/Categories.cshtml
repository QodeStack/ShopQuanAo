@* File: Views/Admin/Categories.cshtml *@
@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<link href="~/css/Admin/Admin_Categories.css" asp-append-version="true" rel="stylesheet" />
@Html.AntiForgeryToken()

<div class="admin-wrap">
    <div class="admin-body d-flex flex-nowrap w-100">
        
        <aside class="admin-sidebar flex-shrink-0" style="width: 260px; background: #fff; border-right: 1px solid #edf2f9; padding: 20px 0; min-height: 100vh;">
            <div class="sidebar-section">
                <div class="sidebar-label" style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: #95aac9; padding: 0 25px; margin-bottom: 12px;">Tổng quan</div>
                <a class="sidebar-link @(currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "Admin")" style="display: flex; padding: 10px 25px; color: #4b5563; text-decoration: none; font-weight: 500;">
                    <span class="sidebar-icon" style="margin-right: 12px;">📊</span> Dashboard
                </a>
                <a class="sidebar-link @(currentAction == "Revenue" ? "active" : "")" href="@Url.Action("Revenue", "Admin")" style="display: flex; padding: 10px 25px; color: #4b5563; text-decoration: none; font-weight: 500;">
                    <span class="sidebar-icon" style="margin-right: 12px;">💰</span> Doanh thu
                </a>
                <a class="sidebar-link @(currentAction == "Orders" ? "active" : "")" href="@Url.Action("Orders", "Admin")" style="display: flex; padding: 10px 25px; color: #4b5563; text-decoration: none; font-weight: 500;">
                    <span class="sidebar-icon" style="margin-right: 12px;">📦</span> Đơn hàng
                </a>
            </div>

            <div class="sidebar-section" style="margin-top: 25px;">
                <div class="sidebar-label" style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: #95aac9; padding: 0 25px; margin-bottom: 12px;">Quản lý</div>
                <a class="sidebar-link @(currentAction == "Users" ? "active" : "")" href="@Url.Action("Users", "Admin")" style="display: flex; padding: 10px 25px; color: #4b5563; text-decoration: none; font-weight: 500;">
                    <span class="sidebar-icon" style="margin-right: 12px;">👥</span> Người dùng
                </a>
                <a class="sidebar-link @(currentAction == "Products" ? "active" : "")" href="@Url.Action("Products", "Admin")" style="display: flex; padding: 10px 25px; color: #4b5563; text-decoration: none; font-weight: 500;">
                    <span class="sidebar-icon" style="margin-right: 12px;">👕</span> Sản phẩm
                </a>
                <a class="sidebar-link @(currentAction == "Categories" ? "active" : "")" href="@Url.Action("Categories", "Admin")" style="display: flex; padding: 10px 25px; color: #1a2b4c; background-color: #f0f4f8; font-weight: 700; text-decoration: none; border-left: 3px solid #1a2b4c;">
                    <span class="sidebar-icon" style="margin-right: 12px;">📁</span> Danh mục
                </a>
                <a class="sidebar-link @(currentAction == "Sales" ? "active" : "")" href="@Url.Action("Sales", "Admin")" style="display: flex; padding: 10px 25px; color: #4b5563; text-decoration: none; font-weight: 500;">
                    <span class="sidebar-icon" style="margin-right: 12px;">★</span> Khuyến mãi (Sale)
                </a>
                <a class="sidebar-link @(currentAction == "Vouchers" ? "active" : "")" href="@Url.Action("Vouchers", "Admin")" style="display: flex; padding: 10px 25px; color: #4b5563; text-decoration: none; font-weight: 500;">
                    <span class="sidebar-icon" style="margin-right: 12px;">🎫</span> Mã giảm giá
                </a>
                <a class="sidebar-link @(currentAction == "Contacts" ? "active" : "")" href="@Url.Action("Contacts", "Admin")" style="display: flex; padding: 10px 25px; color: #4b5563; text-decoration: none; font-weight: 500;">
                    <span class="sidebar-icon" style="margin-right: 12px;">📩</span> Phản hồi
                </a>
            </div>

            <div class="sidebar-section" style="margin-top: 25px;">
                <div class="sidebar-label" style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: #95aac9; padding: 0 25px; margin-bottom: 12px;">Hệ thống</div>
                <a class="sidebar-link" href="@Url.Action("Index", "Home")" style="display: flex; padding: 10px 25px; color: #4b5563; text-decoration: none; font-weight: 500;">
                    <span class="sidebar-icon" style="margin-right: 12px;">🏠</span> Về cửa hàng
                </a>
                <a class="sidebar-link" href="/Identity/Account/Manage" style="display: flex; padding: 10px 25px; color: #4b5563; text-decoration: none; font-weight: 500;">
                    <span class="sidebar-icon" style="margin-right: 12px;">⚙️</span> Tài khoản
                </a>
            </div>
        </aside>

        <main class="admin-content flex-grow-1" style="background-color: #f4f7f6; min-height: 100vh; padding: 30px; width: calc(100% - 260px); overflow-x: hidden;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="fw-bolder mb-1" style="color: #1a2b4c;">Quản lý Danh mục</h4>
                    <p class="text-muted small mb-0">Thiết lập và phân loại sản phẩm trên hệ thống</p>
                </div>
                <button class="btn btn-primary btn-modern shadow-sm" style="background-color: #1a2b4c; border-color: #1a2b4c;" onclick="openAddModal()">
                    <i class="bi bi-plus-lg me-1"></i> Thêm danh mục mới
                </button>
            </div>

            <div class="card border-0 modern-card shadow-sm" style="border-radius: 12px; overflow: hidden;">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 custom-table">
                            <thead style="background-color: #f8fafc;">
                                <tr>
                                    <th class="ps-4 py-3 text-uppercase text-muted" style="font-size: 0.8rem;" width="15%">ID</th>
                                    <th class="py-3 text-uppercase text-muted" style="font-size: 0.8rem;" width="60%">Tên danh mục</th>
                                    <th class="text-end pe-4 py-3 text-uppercase text-muted" style="font-size: 0.8rem;" width="25%">Hành động</th>
                                </tr>
                            </thead>
                            <tbody id="categoryTableBody">
                                <tr><td colspan="3" class="text-center text-muted py-4">Đang tải dữ liệu...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<div class="modal fade" id="categoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 modern-card shadow-lg" style="border-radius: 12px;">
            <div class="modal-header border-bottom-0 pb-0 pt-4 px-4">
                <h5 class="modal-title fw-bold" id="categoryModalLabel" style="color: #1a2b4c;">✨ Thêm Danh Mục Mới</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="categoryId" value="0" />
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold text-uppercase">Tên danh mục <span class="text-danger">*</span></label>
                    <input type="text" class="form-control form-control-lg bg-light border-0" id="categoryName" placeholder="Nhập tên danh mục...">
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" class="btn btn-primary btn-modern px-5 rounded-pill" style="background-color: #1a2b4c; border-color: #1a2b4c;" onclick="saveCategory()">Lưu dữ liệu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <script>
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const categoryModal = new bootstrap.Modal(document.getElementById('categoryModal'));

        document.addEventListener("DOMContentLoaded", function () {
            loadCategories();
        });

        function loadCategories() {
            fetch('/Admin/GetCategories')
                .then(res => res.json())
                .then(data => {
                    const tbody = document.getElementById('categoryTableBody');
                    tbody.innerHTML = '';
                    if(data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-5"><i class="bi bi-inbox fs-1"></i><br/>Chưa có danh mục nào.</td></tr>';
                        return;
                    }

                    data.forEach(item => {
                        tbody.innerHTML += `
                            <tr>
                                <td class="ps-4 fw-bold py-3" style="color: #1a2b4c;">#${item.id}</td>
                                <td class="fw-semibold text-dark py-3">${item.categoryName}</td>
                                <td class="text-end pe-4 py-3">
                                    <div class="d-inline-flex gap-2">
                                        <button class="btn btn-sm btn-outline-primary" style="color: #1a2b4c; border-color: #1a2b4c;" onclick="openEditModal(${item.id}, '${item.categoryName}')" title="Sửa danh mục">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteCategory(${item.id})" title="Xóa danh mục">
                                            <i class="bi bi-trash3"></i> Xóa
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        `;
                    });
                });
        }

        function openAddModal() {
            document.getElementById('categoryModalLabel').innerText = "✨ Thêm Danh Mục Mới";
            document.getElementById('categoryId').value = "0";
            document.getElementById('categoryName').value = "";
            categoryModal.show();
        }

        function openEditModal(id, name) {
            document.getElementById('categoryModalLabel').innerHTML = '<i class="bi bi-pencil-square text-primary me-2"></i> Chỉnh sửa Danh Mục';
            document.getElementById('categoryId').value = id;
            document.getElementById('categoryName').value = name;
            categoryModal.show();
        }

        function saveCategory() {
            const id = document.getElementById('categoryId').value;
            const name = document.getElementById('categoryName').value.trim();
            if (!name) { alert("Vui lòng nhập tên danh mục!"); return; }

            const isEdit = id !== "0";
            const url = isEdit ? '/Admin/EditCategory' : '/Admin/AddCategory';
            
            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({ Id: parseInt(id), CategoryName: name })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) { categoryModal.hide(); loadCategories(); }
                else { alert("Lỗi: " + data.message); }
            });
        }

        function deleteCategory(id) {
            if (confirm("Bạn có chắc chắn muốn xóa danh mục này?")) {
                fetch('/Admin/DeleteCategory', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify({ Id: id.toString() })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) { loadCategories(); }
                    else { alert(data.message); }
                });
            }
        }
    </script>
}