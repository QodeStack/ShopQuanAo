@model IEnumerable<ShopQuanAo.Models.Entity.Product>
@{
    ViewData["Title"] = "Trang Chủ";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick-theme.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --torano-black: #000000;
        --torano-red: #ff0000;
        --font-main: 'Quicksand', sans-serif;
    }

    body { font-family: var(--font-main); margin: 0; padding: 0; background: #fff; overflow-x: hidden; }

    /* --- BANNER SECTION: FIX MỜ VÀ NÚT BẤM --- */
    .hero-slider-wrapper { 
        width: 100%; 
        position: relative;
        background: none;
    }

    .hero-slider .slide { outline: none; border: none; position: relative; }

    .hero-slider img { 
        width: 100%; 
        height: auto !important; 
        display: block; 
        border-radius: 0 !important;
        box-shadow: none !important;
        filter: none !important; /* Đảm bảo ảnh banner sắc nét */
    }

    .banner-nav {
        position: absolute;
        top: 50%;
        width: 100%;
        display: flex;
        justify-content: space-between;
        transform: translateY(-50%);
        z-index: 10;
        padding: 0 20px;
        pointer-events: none;
    }

    .banner-btn {
        width: 45px;
        height: 45px;
        background: rgba(255, 255, 255, 0.3);
        border: none;
        border-radius: 50%;
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
        pointer-events: auto;
    }

    .banner-btn:hover { background: rgba(0, 0, 0, 0.6); }

    /* --- SLIDER CHUNG --- */
    .section-header-flex { display: flex; justify-content: space-between; align-items: center; margin: 40px 0 20px; }
    .section-title { font-weight: 700; font-size: 22px; text-transform: uppercase; letter-spacing: 1px; margin: 0; }
    .nav-arrows { display: flex; gap: 10px; }
    .nav-btn-custom { width: 35px; height: 35px; border-radius: 50%; border: 1px solid #ddd; background: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; }
    .nav-btn-custom:hover { background: #000; color: #fff; }

    .item-wrapper { padding: 0 10px; outline: none; }
    
    /* --- DANH MỤC --- */
    .uniform-card { position: relative; aspect-ratio: 3/4; overflow: hidden; background: #f4f4f4; border-radius: 4px; }
    .uniform-card img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
    .uniform-card:hover img { transform: scale(1.08); } /* Hiệu ứng zoom khi di chuột */
    
    .cat-label { 
        position: absolute; bottom: 15px; left: 10px; right: 10px; 
        background: rgba(255,255,255,0.95); padding: 10px; text-align: center; 
        font-weight: 700; text-transform: uppercase; font-size: 13px; color: #000; 
    }

    /* --- SẢN PHẨM --- */
    .product-info { padding: 15px 0; text-align: left; }
    .p-name { font-weight: 500; text-transform: uppercase; color: #333; text-decoration: none; font-size: 14px; display: block; margin-bottom: 5px; }
    .p-price { font-weight: 700; color: var(--torano-black); font-size: 1.1rem; margin: 0; }
    .sale-tag { 
        position: absolute; top: 10px; left: 10px; 
        background: var(--torano-red); color: #fff; padding: 3px 8px; 
        font-size: 11px; font-weight: 700; z-index: 2; 
    }

    /* --- CSS BỔ SUNG CHO COMBO --- */
    .combo-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 50px; }
    .combo-item { position: relative; overflow: hidden; border-radius: 4px; aspect-ratio: 3/4; }
    .combo-item img { width: 100%; height: 100%; object-fit: cover; transition: 0.6s; }
    .combo-item:hover img { transform: scale(1.05); }
    .combo-icon { position: absolute; bottom: 15px; right: 15px; background: rgba(255,255,255,0.9); width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; color: #333; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
</style>

<div class="container-fluid p-0">
    <section class="hero-slider-wrapper">
        <div class="hero-slider">
            <div class="slide"><img src="/Image/Home_image/Baner1.jpg"></div>
            <div class="slide"><img src="/Image/Home_image/Baner2.jpg"></div>
            <div class="slide"><img src="/Image/Home_image/Baner3.jpg"></div>
            <div class="slide"><img src="/Image/Home_image/Baner4.jpg"></div>
        </div>
        <div class="banner-nav">
            <button class="banner-btn prev-banner"><i class="fa fa-chevron-left"></i></button>
            <button class="banner-btn next-banner"><i class="fa fa-chevron-right"></i></button>
        </div>
    </section>

    <section class="container">
        <div class="section-header-flex">
            <h2 class="section-title">Danh mục sản phẩm</h2>
            <div class="nav-arrows">
                <button class="nav-btn-custom prev-cat"><i class="fa-solid fa-chevron-left"></i></button>
                <button class="nav-btn-custom next-cat"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
        </div>
        <div class="category-slider">
            @{
                var cats = new[] {
                    new { n = "Áo Khoác", i = "Aokhoac.jpg" },
                    new { n = "Áo Polo", i = "Aopolo.jpg" },
                    new { n = "Áo Sơ Mi", i = "Aosomi.jpg" },
                    new { n = "Áo Thun", i = "Aothun.jpg" },
                    new { n = "Quần Jeans", i = "Quanjeans.jpg" },
                    new { n = "Quần Kaki", i = "Quankaki.jpg" },
                    new { n = "Quần Short", i = "Quanshort.jpg" },
                    new { n = "Quần Tây", i = "Quantay.jpg" }
                };
            }
            @foreach (var c in cats) {
                <div class="item-wrapper">
                    <a href="@Url.Action("Index", "Product", new { categoryName = c.n })" class="text-decoration-none">
                        <div class="uniform-card">
                            <img src="/Image/Home_image/@c.i">
                            <div class="cat-label">@c.n</div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </section>

    <section class="container py-4 my-5" style="background: #fffafb; border-radius: 15px;">
        <div class="section-header-flex">
            <h2 class="section-title" style="color: var(--torano-red);"><i class="fa-solid fa-fire"></i> Đang khuyến mãi</h2>
            <div class="nav-arrows">
                <button class="nav-btn-custom prev-sale"><i class="fa-solid fa-chevron-left"></i></button>
                <button class="nav-btn-custom next-sale"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
        </div>
        <div class="sale-slider">
            @foreach (var item in Model) {
                <div class="item-wrapper">
                    <div class="uniform-card">
                        <span class="sale-tag">SALE</span>
                        <img src="@item.Image" onerror="this.src='/Image/no-image.jpg'">
                    </div>
                    <div class="product-info">
                        <a href="@Url.Action("Details", "Product", new { id = item.Id })" class="p-name">@item.ProductName</a>
                        <p class="p-price">@item.Price.ToString("N0")₫</p>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="container mb-5">
        <div class="section-header-flex">
            <h2 class="section-title">Best Seller</h2>
            <div class="nav-arrows">
                <button class="nav-btn-custom prev-best"><i class="fa-solid fa-chevron-left"></i></button>
                <button class="nav-btn-custom next-best"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
        </div>
        <div class="best-slider">
            @* Hiển thị thêm các sản phẩm khác từ Model *@
            @foreach (var item in Model.OrderByDescending(p => p.Id).Take(10)) {
                <div class="item-wrapper">
                    <div class="uniform-card">
                        <img src="@item.Image" onerror="this.src='/Image/no-image.jpg'">
                    </div>
                    <div class="product-info">
                        <a href="@Url.Action("Details", "Product", new { id = item.Id })" class="p-name">@item.ProductName</a>
                        <p class="p-price">@item.Price.ToString("N0")₫</p>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="container mb-5">
        <h2 class="section-title mb-4">Combo Mix & Match</h2>
        <div class="combo-grid">
            <div class="combo-item">
                <img src="/Image/Home_image/Combomix1.jpg">
                <div class="combo-icon"><i class="fa-solid fa-expand"></i></div>
            </div>
            <div class="combo-item">
                <img src="/Image/Home_image/Combomix2.jpg">
                <div class="combo-icon"><i class="fa-solid fa-expand"></i></div>
            </div>
            <div class="combo-item">
                <img src="/Image/Home_image/Combomix3.jpg">
                <div class="combo-icon"><i class="fa-solid fa-expand"></i></div>
            </div>
            <div class="combo-item">
                <img src="/Image/Home_image/Combomix4.jpg">
                <div class="combo-icon"><i class="fa-solid fa-expand"></i></div>
            </div>
        </div>
    </section>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.9.0/slick.min.js"></script>

<script>
    $(document).ready(function(){
        // 1. Banner chính
        var $hero = $('.hero-slider').slick({ 
            autoplay: true, 
            dots: true, 
            arrows: false, 
            fade: true, 
            adaptiveHeight: true, 
            autoplaySpeed: 5000 
        });
        $('.prev-banner').click(function() { $hero.slick('slickPrev'); });
        $('.next-banner').click(function() { $hero.slick('slickNext'); });

        // 2. Slider Danh mục
        var $cat = $('.category-slider').slick({
            slidesToShow: 4, 
            slidesToScroll: 1, 
            arrows: false,
            responsive: [{ breakpoint: 992, settings: { slidesToShow: 2 } }]
        });
        $('.prev-cat').click(function() { $cat.slick('slickPrev'); });
        $('.next-cat').click(function() { $cat.slick('slickNext'); });

        // 3. Slider Khuyến mãi
        var $sale = $('.sale-slider').slick({
            slidesToShow: 4, 
            slidesToScroll: 1, 
            arrows: false, 
            autoplay: true,
            responsive: [{ breakpoint: 992, settings: { slidesToShow: 2 } }]
        });
        $('.prev-sale').click(function() { $sale.slick('slickPrev'); });
        $('.next-sale').click(function() { $sale.slick('slickNext'); });

        // 4. Slider Best Seller (Mới)
        var $best = $('.best-slider').slick({
            slidesToShow: 4, 
            slidesToScroll: 1, 
            arrows: false, 
            autoplay: true,
            responsive: [{ breakpoint: 992, settings: { slidesToShow: 2 } }]
        });
        $('.prev-best').click(function() { $best.slick('slickPrev'); });
        $('.next-best').click(function() { $best.slick('slickNext'); });
    });
</script>