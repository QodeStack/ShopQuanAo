@using ShopQuanAo.Models
@model IEnumerable<ShopQuanAo.Models.BEAN.Entity.Contacts>

@{
    ViewData["Title"] = "Quản lý Phản hồi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

@Html.AntiForgeryToken()
<link href="~/css/Admin/Admin_Contact.css" asp-append-version="true" rel="stylesheet" />

<div class="admin-wrap">
    <div class="admin-body">
        <!-- SIDEBAR -->
        <aside class="admin-sidebar">
            <div class="sidebar-section">
                <div class="sidebar-label">Tổng quan</div>
                <a class="sidebar-link @(currentAction == "Index" ? "active" : "")" href="@Url.Action("Index", "Admin")">
                    <span class="sidebar-icon">📊</span> Dashboard
                </a>
                <a class="sidebar-link @(currentAction == "Revenue" ? "active" : "")" href="@Url.Action("Revenue", "Admin")">
                    <span class="sidebar-icon">💰</span> Doanh thu
                </a>
                <a class="sidebar-link @(currentAction == "Orders" ? "active" : "")" href="@Url.Action("Orders", "Admin")">
                    <span class="sidebar-icon">📦</span> Đơn hàng
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Quản lý</div>
                <a class="sidebar-link @(currentAction == "Users" ? "active" : "")" href="@Url.Action("Users", "Admin")">
                    <span class="sidebar-icon">👥</span> Người dùng
                </a>
                <a class="sidebar-link @(currentAction == "Products" ? "active" : "")" href="@Url.Action("Products", "Admin")">
                    <span class="sidebar-icon">👕</span> Sản phẩm
                </a>
                <a class="sidebar-link @(currentAction == "Categories" ? "active" : "")" href="@Url.Action("Categories", "Admin")">
                    <span class="sidebar-icon">📁</span> Danh mục
                </a>
                <a class="sidebar-link @(currentAction == "Sales" ? "active" : "")" href="@Url.Action("Sales", "Admin")">
                    <span class="sidebar-icon">★</span> Khuyến mãi (Sale)
                </a>
                <a class="sidebar-link @(currentAction == "Vouchers" ? "active" : "")" href="@Url.Action("Vouchers", "Admin")">
                    <span class="sidebar-icon">🎫</span> Mã giảm giá
                </a>
                <a class="sidebar-link @(currentAction == "Contacts" ? "active" : "")" href="@Url.Action("Contacts", "Admin")">
                    <span class="sidebar-icon">📩</span> Phản hồi
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-label">Hệ thống</div>
                <a class="sidebar-link" href="@Url.Action("Index", "Home")">
                    <span class="sidebar-icon">🏠</span> Về cửa hàng
                </a>
                <a class="sidebar-link" href="/Identity/Account/Manage">
                    <span class="sidebar-icon">⚙️</span> Tài khoản
                </a>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="admin-content">
            <!-- PAGE HEADER -->
            <div class="page-header">
                <div>
                    <h1 class="page-title">Quản lý Phản hồi</h1>
                </div>
                <div class="total-badge" id="totalBadge">
                    TỔNG: @Model.Count() TIN NHẮN
                </div>
            </div>

            <!-- TABLE PANEL -->
            <div class="panel">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Khách hàng</th>
                            <th>Nội dung</th>
                            <th>Ngày gửi</th>
                            <th>Trạng thái</th>
                            <th style="text-align: right;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr id="row-@item.Id">
                                    <td>
                                        <div class="customer-name">@item.FullName</div>
                                        <div class="customer-email">@item.Email</div>
                                    </td>
                                    
                                    <td>
                                        <div class="msg-content"
                                             onclick="toggleMessage(this)"
                                             title="Click để xem đầy đủ hoặc thu gọn">
                                            @item.Message
                                        </div>
                                    </td>

                                    <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                                    
                                    <td>
                                        @if (item.IsRead)
                                        {
                                            <span class="status-badge processed">✓ Đã xử lý</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge pending">⏳ Chưa xử lý</span>
                                        }
                                    </td>
                                    
                                    <td style="text-align: right;">
                                        <button class="btn-action btn-reply"
                                                data-id="@item.Id"
                                                data-msg="@item.Message"
                                                data-email="@item.Email"
                                                data-name="@item.FullName"
                                                title="Phản hồi">
                                            💬 Trả lời
                                        </button>
                                        <button class="btn-action btn-delete"
                                                onclick="deleteMsg(@item.Id)"
                                                title="Xóa">
                                            🗑️ Xóa
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" style="text-align: center; padding: 40px;">
                                    <div class="empty-state">
                                        <div class="empty-state-icon">📭</div>
                                        <p class="empty-state-text">Chưa có phản hồi nào từ khách hàng</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>

<!-- REPLY MODAL -->
<div class="modal-overlay" id="replyModal">
    <div class="modal-box">
        <div class="modal-header">
            <div>
                <div style="font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 5px;">Phản hồi liên hệ</div>
                <h2 class="modal-title">Gửi tin nhắn trả lời</h2>
            </div>
            <button class="modal-close" onclick="closeModal()">&times;</button>
        </div>

        <div class="modal-body">
            <!-- Customer Message Display -->
            <div class="form-group">
                <label>Tin nhắn từ khách hàng</label>
                <div class="form-display" id="txtCustomerMsg"></div>
            </div>

            <!-- Reply Message -->
            <div class="form-group">
                <label>Phản hồi của bạn</label>
                <textarea class="form-control"
                          id="adminReply"
                          rows="6"
                          placeholder="Nhập nội dung phản hồi của bạn..."></textarea>
            </div>
        </div>

        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal()">Hủy bỏ</button>
            <button class="btn btn-primary" id="btnSend" onclick="sendReply()">Gửi phản hồi</button>
        </div>

        <input type="hidden" id="hdnId" />
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Toggle message expansion
        function toggleMessage(element) {
        $(element).toggleClass('expanded');
        }

        // Open reply modal
        $(document).on('click', '.btn-reply', function() {
        const id = $(this).data('id');
        const msg = $(this).data('msg');
            
        $('#hdnId').val(id);
        $('#txtCustomerMsg').text(msg);
        $('#adminReply').val('').focus();
        $('#replyModal').addClass('show');
        });

        // Close modal
        function closeModal() {
        $('#replyModal').removeClass('show');
        }

        // Close modal when clicking overlay
        $('#replyModal').on('click', function(e) {
        if ($(e.target).is('#replyModal')) {
        closeModal();
        }
        });

        // Send reply
        function sendReply() {
        const id = $('#hdnId').val();
        const reply = $('#adminReply').val().trim();
            
        if (!reply) {
        alert('Vui lòng nhập nội dung phản hồi!');
        return;
        }

        const $btn = $('#btnSend');
        $btn.prop('disabled', true).text('Đang gửi...');

        $.ajax({
        url: '/Admin/ReplyContact',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({
        Id: parseInt(id),
        AdminReply: reply
        }),
        success: function(res) {
        if (res.success) {
        alert('✓ Gửi phản hồi thành công!');
        closeModal();
        location.reload();
        } else {
        alert('✕ ' + (res.message || 'Lỗi không xác định'));
        $btn.prop('disabled', false).text('Gửi phản hồi');
        }
        },
        error: function() {
        alert('✕ Lỗi kết nối với máy chủ');
        $btn.prop('disabled', false).text('Gửi phản hồi');
        }
        });
        }

        // Delete message
        function deleteMsg(id) {
        if (!confirm('Bạn có chắc chắn muốn xóa tin nhắn này không?')) {
        return;
        }

        const token = $('input[name="__RequestVerificationToken"]').val();
            
        $.ajax({
        url: '/Admin/DeleteContact',
        type: 'POST',
        contentType: 'application/json',
        headers: {
        'RequestVerificationToken': token
        },
        data: JSON.stringify({ id: id.toString() }),
        success: function(res) {
        if (res.success) {
        $('#row-' + id).fadeOut(300, function() {
        $(this).remove();
                            
        // Update badge
        let countText = $('#totalBadge').text();
        let count = parseInt(countText.replace(/[^0-9]/g, ''));
        count = Math.max(0, count - 1);
        $('#totalBadge').text('TỔNG: ' + count + ' TIN NHẮN');
        });
        } else {
        alert('✕ ' + (res.message || 'Lỗi khi xóa'));
        }
        },
        error: function() {
        alert('✕ Lỗi kết nối hoặc chưa đăng nhập');
        }
        });
        }

        // Close modal with Escape key
        $(document).on('keydown', function(e) {
        if (e.key === 'Escape' && $('#replyModal').hasClass('show')) {
        closeModal();
        }
        });
    </script>
}
