@using ShopQuanAo.Models
@model IEnumerable<ShopQuanAo.Models.Entity.Contacts>

@{
    ViewData["Title"] = "Quản lý phản hồi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Thêm dòng này để tạo mã bảo mật *@
@Html.AntiForgeryToken()

<link href="https://fonts.googleapis.com/css2?family=Space+Mono&family=Syne:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/Admin_Index.css" asp-append-version="true" />

<div class="admin-wrap" style="background: #0a0a0a; min-height: 100vh; padding: 30px; color: #f5f5f0;">
    <div class="page-header" style="margin-bottom: 30px; display: flex; justify-content: space-between; align-items: flex-end;">
        <div>
            <h1 style="font-family: 'Syne'; font-size: 2.5rem; text-transform: uppercase; margin: 0;">Quản lý liên hệ</h1>
        </div>
        <div style="font-family: 'Space Mono'; color: #c8ff00; border: 1px solid #c8ff00; padding: 5px 15px; font-size: 0.8rem;">
            TỔNG: @Model.Count() TIN NHẮN
        </div>
    </div>

    <div class="panel" style="background: #141414; border: 1px solid #222; padding: 0;">
        <table class="data-table" style="width: 100%; border-collapse: collapse; font-family: 'Space Mono';">
            <thead>
                <tr style="border-bottom: 1px solid #222; text-align: left; color: #6e6e68; font-size: 0.7rem; text-transform: uppercase;">
                    <th style="padding: 20px;">Khách hàng</th>
                    <th style="padding: 20px;">Nội dung gửi</th>
                    <th style="padding: 20px;">Ngày gửi</th>
                    <th style="padding: 20px;">Trạng thái</th>
                    <th style="padding: 20px; text-align: right;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr id="row-@item.Id" style="border-bottom: 1px solid #1a1a1a; transition: 0.3s;">
                        <td style="padding: 20px;">
                            <div style="color: #c8ff00; font-weight: bold;">@item.FullName</div>
                            <div style="font-size: 0.75rem; color: #6e6e68;">@item.Email</div>
                        </td>
                        <td style="padding: 20px; font-size: 0.85rem; max-width: 300px;">@item.Message</td>
                        <td style="padding: 20px; font-size: 0.8rem; color: #6e6e68;">@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                        <td style="padding: 20px;">
                            @if (item.IsRead)
                            {
                                <span style="color: #3b82ff; font-size: 0.7rem; border: 1px solid #3b82ff; padding: 2px 8px;">ĐÃ XỬ LÝ</span>
                            }
                            else
                            {
                                <span style="color: #ff3b3b; font-size: 0.7rem; border: 1px solid #ff3b3b; padding: 2px 8px;">CHƯA XỬ LÝ</span>
                            }
                        </td>
                        <td style="padding: 20px; text-align: right;">
                            @* Đã bọc dữ liệu vào hàm để tránh lỗi dấu nháy *@
                            <button onclick="openReply(@item.Id, `@Html.Raw(item.Message)`)" style="background:none; border:none; color:#f5f5f0; cursor:pointer; margin-right:10px;">Reply</button>
                            <button onclick="deleteMsg(@item.Id)" style="background:none; border:none; color:#ff3b3b; cursor:pointer;">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* --- MODAL PHẢN HỒI --- *@
<div id="modalReply" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:999; align-items:center; justify-content:center;">
    <div style="background:#141414; border:1px solid #c8ff00; width:500px; padding:30px; font-family:'Space Mono';">
        <h3 style="color:#c8ff00; margin-top:0;">PHẢN HỒI KHÁCH HÀNG</h3>
        <p id="txtCustomerMsg" style="color:#6e6e68; font-size:0.8rem; border-left:2px solid #333; padding-left:15px;"></p>
        <textarea id="adminReply" style="width:100%; background:#0a0a0a; border:1px solid #222; color:#fff; padding:10px; margin:20px 0;" rows="5" placeholder="Gõ nội dung phản hồi..."></textarea>
        <div style="display:flex; justify-content:flex-end; gap:10px;">
            <button onclick="closeModal()" style="background:none; border:1px solid #6e6e68; color:#6e6e68; padding:8px 20px; cursor:pointer;">ĐÓNG</button>
            <button id="btnSend" style="background:#c8ff00; border:none; color:#000; padding:8px 20px; font-weight:bold; cursor:pointer;">GỬI PHẢN HỒI</button>
        </div>
        <input type="hidden" id="hdnId" />
    </div>
</div>

@section Scripts {
    @* Quan trọng: Phải có thư viện jQuery này thì các hàm $.ajax mới chạy được *@
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        // 1. Hàm mở Modal để nhập phản hồi
        function openReply(id, msg) {
        document.getElementById('hdnId').value = id;
        document.getElementById('txtCustomerMsg').innerText = msg;
        document.getElementById('adminReply').value = ''; // Xóa nội dung cũ
        document.getElementById('modalReply').style.display = 'flex';
        }

        // 2. Hàm đóng Modal
        function closeModal() {
        document.getElementById('modalReply').style.display = 'none';
        }

        // 3. Xử lý khi nhấn nút "GỬI PHẢN HỒI"
        document.getElementById('btnSend').onclick = function() {
        const id = document.getElementById('hdnId').value;
        const reply = document.getElementById('adminReply').value;
            
        // Lấy mã Token bảo mật tự động từ trang web
        const token = $('input[name="__RequestVerificationToken"]').val();

        if (!reply.trim()) {
        alert("Bạn chưa nhập nội dung phản hồi!");
        return;
        }

        $.ajax({
        url: '/Admin/ReplyContact',
        type: 'POST',
        data: {
        id: id,
        adminReply: reply,
        "__RequestVerificationToken": token
        },
        success: function(res) {
        if (res.success) {
        alert("Đã gửi phản hồi thành công!");
        location.reload(); // Load lại trang để cập nhật trạng thái "Đã xử lý"
        } else {
        alert("Lỗi: " + res.message);
        }
        },
        error: function() {
        alert("Lỗi kết nối! Hãy kiểm tra lại file AdminController.");
        }
        });
        }
        
        // 4. Xử lý khi nhấn nút "Delete"
        function deleteMsg(id) {
        if (confirm("Bạn có chắc chắn muốn xóa yêu cầu này không?")) {
        const token = $('input[name="__RequestVerificationToken"]').val();
                
        $.post('/Admin/DeleteContact', {
        id: id,
        "__RequestVerificationToken": token
        }, function(res) {
        if (res.success) {
        $('#row-' + id).fadeOut(); // Làm mờ và xóa dòng đó đi
        alert("Đã xóa thành công!");
        } else {
        alert("Không thể xóa lúc này.");
        }
        });
        }
        }
    </script>
}