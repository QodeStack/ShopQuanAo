@using ShopQuanAo.Models
@model IEnumerable<ShopQuanAo.Models.Entity.Contacts>

@{
    ViewData["Title"] = "Quản lý phản hồi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.AntiForgeryToken()
<link href="https://fonts.googleapis.com/css2?family=Space+Mono&family=Syne:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/Admin_Index.css" asp-append-version="true" />

<div class="admin-wrap" style="background: #0a0a0a; min-height: 100vh; padding: 30px; color: #f5f5f0;">
    <div class="page-header" style="margin-bottom: 30px; display: flex; justify-content: space-between; align-items: flex-end;">
        <div>
            <h1 style="font-family: 'Syne'; font-size: 2.5rem; text-transform: uppercase; margin: 0;">Quản lý liên hệ</h1>
        </div>
        <div id="totalBadge" style="font-family: 'Space Mono'; color: #c8ff00; border: 1px solid #c8ff00; padding: 5px 15px; font-size: 0.8rem;">
            TỔNG: @Model.Count() TIN NHẮN
        </div>
    </div>

    <div class="panel" style="background: #141414; border: 1px solid #222; padding: 0;">
        <table class="data-table" style="width: 100%; border-collapse: collapse; font-family: 'Space Mono';">
            <thead>
                <tr style="border-bottom: 1px solid #222; text-align: left; color: #6e6e68; font-size: 0.7rem; text-transform: uppercase;">
                    <th style="padding: 20px;">Khách hàng</th>
                    <th style="padding: 20px; width: 40%;">Nội dung gửi</th>
                    <th style="padding: 20px;">Ngày gửi</th>
                    <th style="padding: 20px;">Trạng thái</th>
                    <th style="padding: 20px; text-align: right;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr id="row-@item.Id" style="border-bottom: 1px solid #1a1a1a; transition: 0.3s;">
                        <td style="padding: 20px; vertical-align: top;">
                            <div style="color: #c8ff00; font-weight: bold;">@item.FullName</div>
                            <div style="font-size: 0.75rem; color: #6e6e68;">@item.Email</div>
                        </td>
                        
                        <td style="padding: 20px; font-size: 0.85rem; vertical-align: top;">
                            <div class="msg-content"
                                 style="cursor: pointer; transition: all 0.3s ease; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; word-break: break-all; line-height: 1.5;"
                                 onclick="toggleMessage(this)"
                                 title="Click để xem đầy đủ hoặc thu gọn">
                                @item.Message
                            </div>
                        </td>

                        <td style="padding: 20px; font-size: 0.8rem; color: #6e6e68; vertical-align: top;">@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                        <td style="padding: 20px; vertical-align: top;">
                            @if (item.IsRead)
                            {
                                <span style="color: #3b82ff; font-size: 0.7rem; border: 1px solid #3b82ff; padding: 2px 8px;">ĐÃ XỬ LÝ</span>
                            }
                            else
                            {
                                <span style="color: #ff3b3b; font-size: 0.7rem; border: 1px solid #ff3b3b; padding: 2px 8px;">CHƯA XỬ LÝ</span>
                            }
                        </td>
                        <td style="padding: 20px; text-align: right; vertical-align: top;">
                            <button class="btn-reply"
                                    data-id="@item.Id"
                                    data-msg="@item.Message"
                                    style="background:none; border:none; color:#f5f5f0; cursor:pointer; margin-right:10px;">
                                Reply
                            </button>
                            <button onclick="deleteMsg(@item.Id)" style="background:none; border:none; color:#ff3b3b; cursor:pointer;">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Modal phản hồi *@
<div id="modalReply" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:999; align-items:center; justify-content:center;">
    <div style="background:#141414; border:1px solid #c8ff00; width:600px; padding:30px; font-family:'Space Mono';">
        <h3 style="color:#c8ff00; margin-top:0; border-bottom:1px solid #222; padding-bottom:10px;">PHẢN HỒI LIÊN HỆ</h3>
        <div style="margin-bottom: 15px;">
            <label style="color:#6e6e68; font-size:0.7rem; text-transform:uppercase; display:block; margin-bottom:5px;">Tin nhắn khách:</label>
            <div id="txtCustomerMsg" style="color:#fff; font-size:0.85rem; background:#0a0a0a; border-left:2px solid #c8ff00; padding:15px; max-height:180px; overflow-y:auto; white-space: pre-wrap; word-break: break-all;"></div>
        </div>
        <div style="margin-bottom: 20px;">
            <label style="color:#6e6e68; font-size:0.7rem; text-transform:uppercase; display:block; margin-bottom:5px;">Phản hồi:</label>
            <textarea id="adminReply" style="width:100%; background:#0a0a0a; border:1px solid #222; color:#fff; padding:10px;" rows="5" placeholder="Gõ phản hồi..."></textarea>
        </div>
        <div style="display:flex; justify-content:flex-end; gap:10px;">
            <button onclick="closeModal()" style="background:none; border:1px solid #6e6e68; color:#6e6e68; padding:8px 20px; cursor:pointer;">ĐÓNG</button>
            <button id="btnSend" style="background:#c8ff00; border:none; color:#000; padding:8px 20px; font-weight:bold; cursor:pointer;">GỬI PHẢN HỒI</button>
        </div>
        <input type="hidden" id="hdnId" />
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function toggleMessage(element) {
        const el = $(element);
        if (el.css('-webkit-line-clamp') === '2') {
        el.css({ '-webkit-line-clamp': 'unset', 'display': 'block', 'background': '#1a1a1a', 'padding': '10px', 'border-radius': '4px' });
        } else {
        el.css({ '-webkit-line-clamp': '2', 'display': '-webkit-box', 'background': 'transparent', 'padding': '0' });
        }
        }

        $(document).on('click', '.btn-reply', function() {
        const id = $(this).data('id');
        const msg = $(this).data('msg');
        $('#hdnId').val(id);
        $('#txtCustomerMsg').text(msg);
        $('#adminReply').val('');
        $('#modalReply').css('display', 'flex');
        });

        function closeModal() { $('#modalReply').hide(); }

        $('#btnSend').click(function() {
        const id = $('#hdnId').val();
        const reply = $('#adminReply').val();
        if (!reply.trim()) return alert("Nhập nội dung!");
            
        $(this).prop('disabled', true).text('ĐANG GỬI...');
        $.ajax({
        url: '/Admin/ReplyContact',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ Id: parseInt(id), AdminReply: reply }),
        success: function(res) {
        if (res.success) { alert("Thành công!"); location.reload(); }
        else { alert(res.message); $('#btnSend').prop('disabled', false).text('GỬI PHẢN HỒI'); }
        }
        });
        });

        // --- HÀM XÓA ĐÃ SỬA LẠI ---
        function deleteMsg(id) {
        if (confirm("Xóa tin nhắn này?")) {
        const token = $('input[name="__RequestVerificationToken"]').val();
                
        $.ajax({
        url: '/Admin/DeleteContact',
        type: 'POST',
        contentType: 'application/json', // Bắt buộc phải có để Controller nhận [FromBody]
        headers: {
        "RequestVerificationToken": token // Gửi token lên Header
        },
        data: JSON.stringify({ id: id.toString() }), // Chuyển sang JSON string
        success: function(res) {
        if (res.success) {
        $('#row-' + id).fadeOut(400, function() {
        $(this).remove();
        let countText = $('#totalBadge').text();
        let count = parseInt(countText.replace(/[^0-9]/g, ''));
        $('#totalBadge').text('TỔNG: ' + (count > 0 ? count - 1 : 0) + ' TIN NHẮN');
        });
        } else {
        alert(res.message || "Lỗi khi xóa!");
        }
        },
        error: function() {
        alert("Lỗi hệ thống hoặc chưa đăng nhập!");
        }
        });
        }
        }
    </script>
}