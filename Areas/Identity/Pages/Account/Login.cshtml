@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="login-page-wrapper">
    <div class="container">
        <div class="row justify-content-center align-items-center" style="min-height: 80vh;">
            <div class="col-md-5 col-lg-4">
                <div class="login-box shadow-sm border p-4 p-md-5 bg-white">
                    
                    @* HIỂN THỊ THÔNG BÁO TỪ TRANG ĐĂNG KÝ/OTP *@
                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show rounded-0 small mb-4" role="alert" style="border-left: 4px solid #198754;">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["StatusMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-uppercase" style="letter-spacing: 3px;">Đăng Nhập</h2>
                        <p class="text-muted small">Chào mừng bạn quay trở lại với MenShop</p>
                    </div>

                    @* ========== FORM LOGIN CHÍNH ========== *@
                    <form id="account" method="post">
                        @* Hiển thị lỗi đăng nhập (sai pass, sai email) *@
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-0 small mb-3" role="alert"></div>
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control rounded-0 border-dark" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-uppercase small fw-bold">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="form-floating mb-2">
                            <input asp-for="Input.Password" class="form-control rounded-0 border-dark" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="text-uppercase small fw-bold">Mật khẩu</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="checkbox small">
                                <label asp-for="Input.RememberMe" class="form-label mb-0">
                                    <input class="form-check-input border-dark" asp-for="Input.RememberMe" />
                                    Duy trì đăng nhập
                                </label>
                            </div>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="small text-dark text-decoration-none border-bottom border-dark">Quên mật khẩu?</a>
                        </div>

                        <button id="login-submit" type="submit" class="btn btn-dark w-100 rounded-0 py-3 fw-bold text-uppercase mb-3" style="letter-spacing: 2px;">
                            Đăng nhập ngay
                        </button>
                    </form>
                    @* ===== KẾT THÚC FORM LOGIN ===== *@

                    @* ========== FORM GOOGLE LOGIN - TÁCH RIÊNG ========== *@
                    <div class="text-center my-3">
                        <p class="text-muted small">Hoặc đăng nhập bằng:</p>
                    </div>

                    <form method="post" asp-page-handler="ExternalLogin" class="mb-3">
                        <button type="submit" name="provider" value="Google" class="btn btn-outline-danger w-100 rounded-0 py-2 fw-bold d-flex align-items-center justify-content-center gap-2" style="border-width: 2px;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
                                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                            </svg>
                            Đăng nhập Google
                        </button>
                    </form>
                    @* ===================================*@

                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="small text-muted mb-1">Chưa có tài khoản?</p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold text-dark text-decoration-none text-uppercase small border-bottom border-dark">Tạo tài khoản mới</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
