@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Hoàn tất đăng ký";
}

<div class="login-page-wrapper">
    <div class="container">
        <div class="row justify-content-center align-items-center" style="min-height: 80vh;">
            <div class="col-md-6 col-lg-5">
                <div class="login-box shadow-sm border p-4 p-md-5 bg-white">
                    
                    @* Tiêu đề *@
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-uppercase" style="letter-spacing: 2px;">Xác nhận tài khoản</h2>
                        <p class="text-muted small">
                            Bạn đã xác thực thành công với <strong class="text-dark">@Model.ProviderDisplayName</strong>.
                        </p>
                    </div>

                    <div class="alert alert-info rounded-0 small mb-4" style="border-left: 4px solid #0dcaf0;">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Vui lòng xác nhận địa chỉ email bên dưới để hoàn tất việc tạo tài khoản tại <strong>MenShop</strong>.
                    </div>

                    @* Form xác nhận *@
                    <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-0 small mb-3" role="alert"></div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="Input.Email" class="form-control rounded-0 border-dark" autocomplete="email" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-uppercase small fw-bold">Địa chỉ Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 rounded-0 py-3 fw-bold text-uppercase" style="letter-spacing: 2px;">
                            Hoàn tất đăng ký
                        </button>
                    </form>

                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="small text-muted mb-0">Hủy bỏ quá trình và quay lại <a asp-page="./Login" class="text-dark fw-bold text-decoration-none border-bottom border-dark">Đăng nhập</a></p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}