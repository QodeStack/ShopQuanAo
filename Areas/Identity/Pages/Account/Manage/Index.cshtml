@page
@using ShopQuanAo.Areas.Identity.Pages.Account.Manage
@using ShopQuanAo.Models
@* Sử dụng đường dẫn đầy đủ để tránh lỗi service *@
@model ShopQuanAo.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="container mt-4">
    <h3 class="fw-bold text-uppercase" style="letter-spacing: 1px;">@ViewData["Title"]</h3>
    <hr />
    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-3 p-4">
                <form id="profile-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    
                    <div class="form-group mb-4">
                        <label asp-for="Username" class="form-label fw-bold small text-muted">TÊN ĐĂNG NHẬP</label>
                        <input asp-for="Username" class="form-control bg-light border-0 py-2" placeholder="Tên đăng nhập" disabled />
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.PhoneNumber" class="form-label fw-bold small text-muted">SỐ ĐIỆN THOẠI</label>
                        <input asp-for="Input.PhoneNumber" class="form-control border-0 bg-light py-2" placeholder="Nhập số điện thoại của bạn." />
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                    </div>

                    <button id="update-profile-button" type="submit" class="w-100 btn btn-dark py-2 fw-bold text-uppercase" style="border-radius: 8px;">
                        Lưu thay đổi
                    </button>
                </form>
            </div>
        </div>
        
        <div class="col-md-6 d-none d-md-block border-start ps-5">
            <h5 class="fw-bold">Thông tin tài khoản</h5>
            <p class="text-muted small">Chào mừng bạn quay trở lại với <b>MenShop</b>. Tại đây bạn có thể cập nhật thông tin liên lạc để chúng tôi hỗ trợ giao hàng tốt nhất.</p>
            <div class="alert alert-info border-0 small">
                <i class="bi bi-info-circle me-2"></i> Mọi thay đổi về số điện thoại sẽ được cập nhật ngay lập tức vào hệ thống đơn hàng.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}